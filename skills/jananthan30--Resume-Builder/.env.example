# =============================================================================
# Anthropic API Key (required for LLM scoring and Claude-based features)
# =============================================================================
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model for LLM-augmented scoring (optional, defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# Cloud Scoring API (optional — enables cloud-first scoring via MCP)
# =============================================================================
# Sign up at https://resume-scorer-web.streamlit.app to get an API key.
# With cloud enabled, MCP tools try the cloud API first and fall back to local
# scoring if the cloud is unavailable. Without these, scoring runs 100% locally.
#
# SCORER_CLOUD_URL=https://resume-scorer.fly.dev
# SCORER_CLOUD_API_KEY=rb_your_api_key_here
