<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:dc="http://purl.org/dc/elements/1.1/">

  <owl:Ontology rdf:about="http://example.org/mini">
    <owl:versionInfo>0.1.0</owl:versionInfo>
    <dc:title>Mini Test Ontology</dc:title>
    <dc:description>A small ontology fixture for deterministic eval checks.</dc:description>
  </owl:Ontology>

  <owl:Class rdf:about="http://example.org/mini/Material">
    <rdfs:label>Material</rdfs:label>
    <rdfs:comment>A substance described by the ontology.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/mini/CrystallineMaterial">
    <rdfs:label>Crystalline Material</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/mini/Material"/>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/mini/UnitCell">
    <rdfs:label>Unit Cell</rdfs:label>
  </owl:Class>

  <owl:ObjectProperty rdf:about="http://example.org/mini/hasUnitCell">
    <rdfs:label>has unit cell</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/mini/CrystallineMaterial"/>
    <rdfs:range rdf:resource="http://example.org/mini/UnitCell"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mini/hasLatticeConstant">
    <rdfs:label>has lattice constant</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/mini/UnitCell"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>

</rdf:RDF>
