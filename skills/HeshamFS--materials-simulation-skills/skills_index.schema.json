{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/HeshamFS/materials-simulation-skills/skills_index.schema.json",
  "title": "Materials Simulation Skills index",
  "description": "Machine-readable catalog of skills and installable bundles, generated by tools/build_index.py.",
  "type": "object",
  "required": ["schema", "repository", "summary", "skills", "bundles"],
  "properties": {
    "schema": {"const": "materials-simulation-skills.index.v1"},
    "repository": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["skills", "scripts", "eval_cases", "deterministic_checks", "eval_coverage", "categories"],
      "properties": {
        "skills": {"type": "integer", "minimum": 0},
        "scripts": {"type": "integer", "minimum": 0},
        "eval_cases": {"type": "integer", "minimum": 0},
        "deterministic_checks": {"type": "integer", "minimum": 0},
        "eval_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "categories": {"type": "array", "items": {"type": "string"}}
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "category", "path", "description", "version", "security_tier",
                     "allowed_tools", "scripts", "eval_cases", "deterministic_checks", "eval_coverage", "standards"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9]([a-z0-9-]{0,62}[a-z0-9])?$"},
          "category": {"type": "string"},
          "path": {"type": "string"},
          "description": {"type": "string", "maxLength": 1024},
          "version": {"type": "string"},
          "security_tier": {"type": "string", "enum": ["low", "medium", "high", ""]},
          "allowed_tools": {"type": "array", "items": {"type": "string"}},
          "scripts": {"type": "integer", "minimum": 0},
          "eval_cases": {"type": "integer", "minimum": 0},
          "deterministic_checks": {"type": "integer", "minimum": 0},
          "eval_coverage": {"type": "number", "minimum": 0, "maximum": 1},
          "last_evaluated": {"type": "string"},
          "standards": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    },
    "bundles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "description", "skills"],
        "properties": {
          "name": {"type": "string"},
          "kind": {"type": "string", "enum": ["category", "curated"]},
          "description": {"type": "string"},
          "skills": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
