# agency-docs-updater environment configuration
# Copy to .env and adjust paths for your setup

# Obsidian vault where Fathom transcripts and videos are stored
VAULT_DIR=~/Brains/brain

# agency-docs Next.js site root
DOCS_SITE_DIR=~/Sites/agency-docs

# YouTube uploader project (https://github.com/glebis/youtube-uploader)
YOUTUBE_UPLOADER_DIR=~/ai_projects/youtube-uploader

# Claude Code Lab presentations repo
PRESENTATIONS_DIR=~/ai_projects/claude-code-lab

# Skills directories
SKILLS_REPO_DIR=~/ai_projects/claude-skills
SKILLS_LOCAL_DIR=~/.claude/skills

# Zoom credentials directory
ZOOM_CREDENTIALS_DIR=~/.zoom_credentials

# GitHub repo for deploy status checks (owner/repo)
GITHUB_REPO=glebis/agency-docs

# Production site domain
SITE_DOMAIN=agency-lab.glebkalinin.com
