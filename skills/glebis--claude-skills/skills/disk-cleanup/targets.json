{
  "schema_version": 1,
  "allowed_roots": [
    "~/Library", "~/.cache", "~/.npm", "~/.cargo", "~/go", "~/.gradle", "~/.m2",
    "~/.ollama", "~/ai_projects", "~/Downloads", "~/.Trash", "/private/var/folders"
  ],
  "presets": {
    "safe": ["safe"],
    "full": ["safe", "medium"]
  },
  "min_size_mb": 10,
  "targets": [
    {"id": "crashpad-dumps", "category": "crash-dumps", "risk": "safe", "method": "find-trash",
     "find": {"root": "~/Library/Application Support", "maxdepth": 4, "name": "Crashpad", "min_mb": 50},
     "regenerates": true, "priority": 100,
     "note": "crash dumps; if >1GB FLAG the app is crash-looping (suggest update/reinstall)"},

    {"id": "chrome-on-device-model", "category": "browser", "risk": "safe", "method": "trash", "priority": 90,
     "paths": ["~/Library/Application Support/Google/Chrome/OptGuideOnDeviceModel"],
     "regenerates": true, "note": "Chrome on-device ML optimization models — re-fetched on demand"},
    {"id": "chrome-component-cache", "category": "browser", "risk": "safe", "method": "trash",
     "paths": ["~/Library/Application Support/Google/Chrome/component_crx_cache"], "regenerates": true,
     "note": "Chrome component-extension cache"},
    {"id": "browser-caches", "category": "browser", "risk": "safe", "method": "trash",
     "paths": ["~/Library/Caches/Google", "~/Library/Caches/company.thebrowser.Browser",
               "~/Library/Application Support/Google/Chrome/Default/Service Worker/CacheStorage",
               "~/Library/Application Support/Google/Chrome Beta/Default/Service Worker/CacheStorage"],
     "regenerates": true, "note": "browser disk caches (NOT the whole Chrome dir — history/extensions live there)"},

    {"id": "npx-cache", "category": "package-manager", "risk": "safe", "method": "trash", "priority": 80,
     "paths": ["~/.npm/_npx"], "regenerates": true, "note": "npx tool cache — rebuilt on next npx"},
    {"id": "npm-logs", "category": "package-manager", "risk": "safe", "method": "trash",
     "paths": ["~/.npm/_logs"], "regenerates": true, "note": "npm debug logs"},
    {"id": "cargo-registry-cache", "category": "package-manager", "risk": "safe", "method": "trash", "priority": 75,
     "paths": ["~/.cargo/registry/cache", "~/.cargo/registry/src",
               "~/.cargo/advisory-dbs", "~/.cargo/advisory-db"],
     "regenerates": true, "note": "Rust crate cache + sources — re-fetched from crates.io"},
    {"id": "go-mod-cache", "category": "package-manager", "risk": "safe", "method": "trash", "priority": 70,
     "paths": ["~/go/pkg/mod/cache/download"], "regenerates": true,
     "note": "Go module download cache — `go mod download` rebuilds it"},
    {"id": "npm-cache", "category": "package-manager", "risk": "safe", "method": "command",
     "command": ["npm", "cache", "clean", "--force"], "scope_path": "~/.npm/_cacache",
     "note": "npm content cache"},
    {"id": "pip-cache", "category": "package-manager", "risk": "safe", "method": "command",
     "command": ["pip", "cache", "purge"], "scope_path": "~/Library/Caches/pip", "note": "pip wheel cache"},
    {"id": "uv-cache", "category": "package-manager", "risk": "safe", "method": "command",
     "command": ["uv", "cache", "clean"], "scope_path": "~/.cache/uv", "note": "uv build cache (NOT uv/tools)"},
    {"id": "brew-cache", "category": "package-manager", "risk": "safe", "method": "command",
     "command": ["brew", "cleanup", "-s"], "note": "Homebrew downloads/old versions; reports its own freed bytes"},

    {"id": "app-updater-caches", "category": "updater", "risk": "safe", "method": "trash",
     "paths": ["~/Library/Caches/ms-playwright", "~/Library/Caches/pencil-updater",
               "~/Library/Caches/superpowers", "~/Library/Caches/com.electron.wispr-flow.ShipIt",
               "~/Library/Caches/timebuzzer-updater", "~/Library/Caches/notion.id.ShipIt",
               "~/Library/Caches/@granolaelectron-updater",
               "~/Library/Application Support/Caches"],
     "regenerates": true, "note": "app self-update download caches"},

    {"id": "xcode-derived-data", "category": "dev", "risk": "safe", "method": "trash", "priority": 60,
     "paths": ["~/Library/Developer/Xcode/DerivedData"], "regenerates": true, "note": "Xcode build products"},
    {"id": "dev-tool-caches", "category": "dev", "risk": "safe", "method": "trash",
     "paths": ["~/.cache/codex-runtimes", "~/Library/Caches/node-chromium",
               "~/Library/Caches/com.apple.dt.Xcode", "~/Library/Developer/CoreSimulator/Caches",
               "~/Library/Caches/ollama"],
     "regenerates": true, "note": "assorted dev tool caches"},
    {"id": "clang-tmp-cache", "category": "dev", "risk": "safe", "method": "trash",
     "paths": ["/private/var/folders/*/*/C/clang"], "regenerates": true,
     "note": "clang module cache in per-user temp"},

    {"id": "system-caches", "category": "system", "risk": "safe", "method": "trash",
     "paths": ["~/Library/Caches/SiriTTS", "~/Library/Caches/CloudKit", "~/Library/Caches/GeoServices",
               "~/Library/Caches/com.googlecode.iterm2", "~/Library/Caches/com.raycast.macos",
               "~/Library/Caches/com.raycast-x.macos", "~/Library/Caches/com.obsproject.obs-studio",
               "~/Library/Containers/com.apple.AMPArtworkAgent/Data/Documents/artwork"],
     "regenerates": true, "note": "regenerable system/app caches"},
    {"id": "logs", "category": "logs", "risk": "safe", "method": "trash",
     "paths": ["~/Library/Logs/zoom.us", "~/Library/Logs/Figma", "~/Library/Logs/Notion"],
     "regenerates": true, "note": "app debug logs"},

    {"id": "huggingface-models", "category": "ml-model", "risk": "medium", "method": "trash",
     "paths": ["~/.cache/huggingface", "~/.cache/kokoro-onnx", "~/.cache/qmd"],
     "regenerates": true, "note": "ML models — re-download (can be large/slow)"},
    {"id": "ollama-models", "category": "ml-model", "risk": "medium", "method": "trash",
     "paths": ["~/.ollama/models"], "regenerates": true,
     "note": "local LLM weights — re-download is large/slow; confirm before clearing"},
    {"id": "xcode-device-support", "category": "dev", "risk": "medium", "method": "trash",
     "paths": ["~/Library/Developer/Xcode/iOS DeviceSupport",
               "~/Library/Developer/Xcode/watchOS DeviceSupport",
               "~/Library/Developer/Xcode/tvOS DeviceSupport"],
     "regenerates": true, "note": "re-copied on next physical-device connect (a few min)"},

    {"id": "node-modules-projects", "category": "project-build", "risk": "medium", "method": "find-trash",
     "find": {"root": "~/ai_projects", "maxdepth": 3, "name": "node_modules", "min_mb": 50},
     "regenerates": true, "note": "regenerable via npm/pnpm install — but only in projects you've finished with"},

    {"id": "simulators-unavailable", "category": "dev", "risk": "safe", "method": "simctl",
     "regenerates": true, "priority": 40,
     "note": "removes ONLY simulators for runtimes Xcode no longer has installed (xcrun simctl delete unavailable)"},

    {"id": "downloads-old", "category": "downloads", "risk": "medium", "method": "downloads-scan",
     "regenerates": false, "priority": 30,
     "note": "Downloads files >180d old, EXCLUDING genome/legal/financial/personal (config exclude_patterns). Dry-run shows the list first."},

    {"id": "uv-installed", "category": "app-data", "risk": "never", "method": "advisory",
     "paths": ["~/Library/Application Support/uv/tools", "~/Library/Application Support/uv/python"],
     "note": "INSTALLED CLI tools + Python interpreters, NOT cache. Never delete. uv cache is ~/.cache/uv."},
    {"id": "rustup-toolchains", "category": "app-data", "risk": "never", "method": "advisory",
     "paths": ["~/.rustup/toolchains"], "note": "installed Rust toolchains — prune manually with rustup, never auto"},
    {"id": "runtimes-installed", "category": "app-data", "risk": "never", "method": "advisory",
     "paths": ["~/.bun/install", "~/.deno/bin"], "note": "installed runtimes — not cache"},
    {"id": "telegram-media", "category": "advisory", "risk": "never", "method": "advisory",
     "note": "clear from Telegram > Settings > Data and Storage > Storage Usage, not the terminal"},
    {"id": "simulators-devices", "category": "advisory", "risk": "never", "method": "advisory",
     "paths": ["~/Library/Developer/CoreSimulator/Devices"],
     "note": "real simulators w/ installed apps. Use `xcrun simctl delete unavailable`, never trash"},
    {"id": "xcode-archives", "category": "advisory", "risk": "never", "method": "advisory",
     "paths": ["~/Library/Developer/Xcode/Archives"],
     "note": "release/distribution archives — needed for crash symbolication / resubmit. Ask, never auto"}
  ]
}
