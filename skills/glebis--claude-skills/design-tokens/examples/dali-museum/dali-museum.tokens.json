{
  "color": {
    "$type": "color",
    "void-950": { "$value": "#070613" },
    "abyss-900": { "$value": "#082224" },
    "ink-900": { "$value": "#0b0e12" },
    "teal-700": { "$value": "#023350" },
    "teal-500": { "$value": "#02708d" },
    "cyan-400": { "$value": "#2fb9ca" },
    "cyan-200": { "$value": "#9adfe7" },
    "coral-500": { "$value": "#e4501b" },
    "gold-500": { "$value": "#de8103" },
    "crimson-500": { "$value": "#c4151f" },
    "orchid-300": { "$value": "#fbbbfe" },
    "acid-400": { "$value": "#faff00" },
    "paper-50": { "$value": "#fefefe" },
    "mist-100": { "$value": "#f3f4f4" },
    "slate-900": { "$value": "#1a1b1d" },
    "slate-500": { "$value": "#5f5f60" },

    "primary": { "$value": "{color.coral-500}" },
    "accent": { "$value": "{color.cyan-400}" },
    "highlight": { "$value": "{color.orchid-300}" },
    "warning": { "$value": "{color.acid-400}" },
    "danger": { "$value": "{color.crimson-500}" },
    "muted": { "$value": "{color.slate-500}" },
    "background": { "$value": "{color.void-950}" },
    "surface": { "$value": "{color.abyss-900}" },
    "text": { "$value": "{color.paper-50}" },
    "text-ink": { "$value": "{color.slate-900}" }
  },
  "space": {
    "$type": "dimension",
    "xs": { "$value": { "value": 4, "unit": "px" } },
    "sm": { "$value": { "value": 8, "unit": "px" } },
    "md": { "$value": { "value": 16, "unit": "px" } },
    "lg": { "$value": { "value": 32, "unit": "px" } },
    "xl": { "$value": { "value": 64, "unit": "px" } },
    "2xl": { "$value": { "value": 128, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": { "value": 2, "unit": "px" } },
    "md": { "$value": { "value": 4, "unit": "px" } }
  },
  "type": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Playfair Display",
        "fontSize": { "value": 72, "unit": "px" },
        "fontWeight": 500,
        "lineHeight": 1.0
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Oswald",
        "fontSize": { "value": 40, "unit": "px" },
        "fontWeight": 700,
        "lineHeight": 1.05
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": { "value": 18, "unit": "px" },
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": { "value": 12, "unit": "px" },
        "fontWeight": 500,
        "lineHeight": 1.4,
        "letterSpacing": { "value": 0.15, "unit": "em" }
      }
    }
  }
}
