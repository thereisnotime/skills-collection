{
  "color": {
    "$type": "color",
    "neon": { "$value": "#F5B8A5" },
    "neon-dark": { "$value": "#86412E" },
    "argon": { "$value": "#F1E170" },
    "argon-dark": { "$value": "#7D6E2F" },
    "xenon": { "$value": "#B6D162" },
    "xenon-dark": { "$value": "#4D5C2A" },
    "radon": { "$value": "#82D2CF" },
    "radon-dark": { "$value": "#3B5E60" },
    "krypton": { "$value": "#BC9AFA" },
    "krypton-dark": { "$value": "#3B2772" },
    "canvas": { "$value": "#0D1117" },
    "ink": { "$value": "#FFFFFF" },
    "muted": { "$value": "#B7BFC8" },
    "border": { "$value": "#2F353C" },
    "primary": { "$value": "{color.neon}" },
    "accent": { "$value": "{color.krypton}" },
    "success": { "$value": "{color.xenon}" },
    "warning": { "$value": "{color.argon}" },
    "text": { "$value": "{color.ink}" },
    "background": { "$value": "{color.canvas}" }
  },
  "font": {
    "$type": "fontFamily",
    "neon": { "$value": ["Monaspace Neon", "ui-monospace", "monospace"] },
    "argon": { "$value": ["Monaspace Argon", "ui-monospace", "monospace"] },
    "xenon": { "$value": ["Monaspace Xenon", "ui-monospace", "serif"] },
    "radon": { "$value": ["Monaspace Radon", "cursive"] },
    "krypton": { "$value": ["Monaspace Krypton", "ui-monospace", "monospace"] }
  },
  "space": {
    "$type": "dimension",
    "xs": { "$value": { "value": 4, "unit": "px" } },
    "sm": { "$value": { "value": 8, "unit": "px" } },
    "md": { "$value": { "value": 16, "unit": "px" } },
    "lg": { "$value": { "value": 24, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": { "value": 4, "unit": "px" } },
    "md": { "$value": { "value": 8, "unit": "px" } },
    "lg": { "$value": { "value": 16, "unit": "px" } },
    "xl": { "$value": { "value": 24, "unit": "px" } }
  },
  "type": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Monaspace Xenon",
        "fontSize": { "value": 32, "unit": "px" },
        "fontWeight": 700,
        "lineHeight": 1.1
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Monaspace Neon",
        "fontSize": { "value": 16, "unit": "px" },
        "fontWeight": 300,
        "lineHeight": 1.5
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Monaspace Argon",
        "fontSize": { "value": 14, "unit": "px" },
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    }
  }
}
