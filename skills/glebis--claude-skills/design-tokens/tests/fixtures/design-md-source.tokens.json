{
  "color": {
    "$type": "color",
    "brand": { "$value": "#1A73E8" },
    "action": { "primary": { "$value": "{color.brand}" } }
  },
  "space": {
    "$type": "dimension",
    "sm": { "$value": { "value": 8, "unit": "px" } },
    "md": { "$value": { "value": 16, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": { "value": 4, "unit": "px" } }
  },
  "type": {
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": { "value": 16, "unit": "px" },
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    }
  }
}
