// markdownlint-cli2 configuration for claude-code-plugins-plus-skills
//
// Single source of truth for markdown lint rules applied to:
//   - plugins/**/SKILL.md (3000+ skill instruction files)
//   - plugins/**/README.md (1500+ plugin READMEs)
//   - marketplace/src/content/**/*.md (blog posts, content pages)
//   - root-level: README.md, CLAUDE.md, CONTRIBUTING.md, CHANGELOG.md
//
// Policy: external PR gating + internal cleanliness. We are the marketplace
// standard for skills; our own markdown holds the same bar.
//
// Reference: https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
{
  "config": {
    "default": true,

    // Disable rules incompatible with this codebase by design:

    // MD013 (line-length) — skill descriptions, frontmatter blobs, and prose
    // paragraphs in SKILL.md are intentionally long. Prose markdown without
    // hard-wrap is the convention here.
    "MD013": false,

    // MD024 (no-duplicate-heading) — SKILL.md files commonly repeat
    // section headings like "## Overview" across nested levels.
    "MD024": { "siblings_only": true },

    // MD033 (no-inline-html) — TOC <details>, badges, tables, anchor spans
    // are intentional in plugin READMEs and SKILL.md.
    "MD033": false,

    // MD041 (first-line-heading) — YAML frontmatter is the first line in
    // every SKILL.md and agent.md; rule misfires.
    "MD041": false,

    // MD036 (no-emphasis-as-heading) — bolded labels like **Author:** in
    // metadata blocks are intentional, not headings.
    "MD036": false,

    // MD026 (no-trailing-punctuation in headings) — questions in section
    // headings ("How does this work?") are intentional.
    "MD026": false,

    // MD034 (no-bare-urls) — too many auto-linked URLs in skill docs and
    // changelog; angle-bracketing every one is noise.
    "MD034": false,

    // MD060 (table-column-style) — pure stylistic noise: enforces that
    // every table pipe uses identical spacing throughout the file. Real
    // tables with varying content widths produce thousands of false
    // positives. Auto-fix doesn't reliably handle it. Not part of any
    // widely-used markdownlint preset.
    "MD060": false,

    // MD040 (fenced-code-language) — real bug-prevention rule but the
    // existing 3000+ SKILL.md files have thousands of bare ``` blocks
    // for plain text snippets, ascii diagrams, sample output. Adding
    // language tags to all of them is a separate cleanup wave. Tracking
    // bead claude-* for the future cleanup; enable when ready.
    "MD040": false,

    // MD025 (single-h1) — blog posts in marketplace/src/content/ have
    // both a frontmatter `title:` and a body `# Title` (standard Astro
    // convention). Many plugin READMEs/SKILL.md also legitimately use
    // multiple top-level headings (one per logical section). Disabling
    // outright; tracking real "two h1 lines in one document" via review.
    "MD025": false,

    // Rules we KEEP enforced (real-markdown-bugs):
    // MD009 — trailing whitespace
    // MD011 — reversed link syntax
    // MD012 — multiple consecutive blank lines
    // MD018-MD021 — space requirements around heading markers
    // MD022 — heading blank-line context
    // MD030 — list marker spacing
    // MD031 — fenced-code blank-line context
    // MD032 — list blank-line context
    // MD040 — fenced code requires language tag
    // MD047 — file ends with single newline
  },
  "globs": [
    "plugins/**/*.md",
    "marketplace/src/content/**/*.md",
    "README.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "AGENTS.md",
    "RELEASING.md",
    "SECURITY.md"
  ],
  "ignores": [
    "node_modules/**",
    "**/node_modules/**",
    "dist/**",
    "**/dist/**",
    "marketplace/backup-*/**",
    "backups/**",
    "claudes-docs/**",
    "000-docs/**",
    "tests/**",
    ".forge/**",
    "**/.forge/**",

    // ─── Upstream-synced plugin paths (from sources.yaml) ───
    // These dirs are auto-synced from external repos by
    // scripts/sync-external.mjs on the weekly cron. Their markdown
    // style is the upstream maintainer's choice, not ours. Linting
    // them here would force us to fix files the next sync overwrites.
    //
    // Keep this list in sync with sources.yaml target_path entries.
    // Regenerate via:
    //   python3 -c "import yaml; [print(s['target_path']+'/**') for s in yaml.safe_load(open('sources.yaml'))['sources']]"
    "plugins/ai-agency/hyperflow/**",
    "plugins/ai-agency/tonone/**",
    "plugins/business-tools/wondelai-blue-ocean-strategy/**",
    "plugins/business-tools/wondelai-contagious/**",
    "plugins/business-tools/wondelai-cro-methodology/**",
    "plugins/business-tools/wondelai-crossing-the-chasm/**",
    "plugins/business-tools/wondelai-drive-motivation/**",
    "plugins/business-tools/wondelai-hundred-million-offers/**",
    "plugins/business-tools/wondelai-influence-psychology/**",
    "plugins/business-tools/wondelai-jobs-to-be-done/**",
    "plugins/business-tools/wondelai-made-to-stick/**",
    "plugins/business-tools/wondelai-negotiation/**",
    "plugins/business-tools/wondelai-obviously-awesome/**",
    "plugins/business-tools/wondelai-one-page-marketing/**",
    "plugins/business-tools/wondelai-predictable-revenue/**",
    "plugins/business-tools/wondelai-scorecard-marketing/**",
    "plugins/business-tools/wondelai-storybrand-messaging/**",
    "plugins/business-tools/wondelai-traction-eos/**",
    "plugins/community/ejentum-anti-deception/**",
    "plugins/community/ejentum-code/**",
    "plugins/community/ejentum-memory/**",
    "plugins/community/ejentum-reasoning/**",
    "plugins/community/gastown/**",
    "plugins/community/zai-cli/**",
    "plugins/crypto/aomi/**",
    "plugins/design/wondelai-design-everyday-things/**",
    "plugins/design/wondelai-hooked-ux/**",
    "plugins/design/wondelai-ios-hig-design/**",
    "plugins/design/wondelai-refactoring-ui/**",
    "plugins/design/wondelai-top-design/**",
    "plugins/design/wondelai-ux-heuristics/**",
    "plugins/design/wondelai-web-typography/**",
    "plugins/devops/sugar/**",
    "plugins/mcp/beads-dolt/**",
    "plugins/mcp/governed-second-brain/**",
    "plugins/mcp/pr-to-spec/**",
    "plugins/mcp/slack-channel/**",
    "plugins/mcp/x-bug-triage/**",
    "plugins/productivity/box-cloud-filesystem/**",
    "plugins/productivity/claude-workflow-skills/**",
    "plugins/productivity/claudebase/**",
    "plugins/productivity/cli-power-skills/**",
    "plugins/productivity/obsidian-project-documentation/**",
    "plugins/productivity/over-50s-health/**",
    "plugins/productivity/pair-programmer/**",
    "plugins/productivity/publishing-skills/**",
    "plugins/productivity/skyvern/**",
    "plugins/productivity/wondelai-design-sprint/**",
    "plugins/productivity/wondelai-lean-startup/**",
    "plugins/testing/cli-ux-tester/**",
    "plugins/testing/kobiton-automate/**"
  ]
}
