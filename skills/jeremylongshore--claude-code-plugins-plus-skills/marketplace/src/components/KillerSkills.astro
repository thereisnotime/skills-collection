---
import spotlightData from '../data/spotlights.json';

const skill = spotlightData.spotlight;
const week = spotlightData.week;
const isExternal = skill.link.startsWith('http');
---

<div
  class="killer-card"
  style="cursor: pointer;"
  data-href={skill.link}
  data-slug={skill.pluginSlug}
  data-week={week}
  data-external={isExternal ? 'true' : 'false'}
>
  <div class="killer-top">
    <span class="killer-grade">{skill.grade}</span>
    <span class="killer-category">{skill.category}</span>
  </div>

  <h3 class="killer-headline">{skill.headline}</h3>
  <p class="killer-why">{skill.whyKiller}</p>

  {skill.quote && (
    <blockquote class="killer-quote">{skill.quote}</blockquote>
  )}

  <div class="killer-meta">
    <a
      href={`https://github.com/${skill.authorGithub}`}
      target="_blank"
      rel="noopener noreferrer"
      class="killer-author"
    >
      <img
        src={`https://github.com/${skill.authorGithub}.png?size=80`}
        alt={skill.author}
        class="killer-avatar"
        width="40"
        height="40"
        loading="lazy"
      />
      <span class="killer-author-name">{skill.author}</span>
    </a>
    {skill.skillCount && (
      <span class="killer-skills">{skill.skillCount} skills</span>
    )}
  </div>

  <div class="killer-actions">
    {isExternal ? (
      <a href={skill.link} class="killer-cta-primary" target="_blank" rel="noopener noreferrer">View on GitHub &rarr;</a>
    ) : (
      <a href={skill.link} class="killer-cta-primary">View Plugin &rarr;</a>
    )}
    {!isExternal && (
      <a
        href={`/downloads/plugins/${skill.pluginSlug}.zip`}
        class="killer-cta-secondary"
        download
      >Download for Cowork</a>
    )}
  </div>
</div>

<style>
  .killer-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
    transition: transform var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
    position: relative;
    overflow: hidden;
    margin-top: 1.5rem;
  }

  /* Always-visible 3px primary gradient top bar */
  .killer-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
  }

  .killer-card:hover {
    transform: translateY(-3px);
    border-color: var(--primary-border);
    box-shadow: 0 8px 24px oklch(0% 0 0 / 0.25), 0 0 0 1px var(--primary-tint);
  }

  .killer-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .killer-grade {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--primary);
    color: white;
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 8px;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .killer-category {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    background: var(--surface-3);
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
  }

  .killer-headline {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    margin: 0;
  }

  .killer-why {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-2);
    margin: 0;
  }

  .killer-quote {
    margin: 0;
    padding: 0.75rem 1rem;
    border-left: 3px solid var(--primary);
    background: var(--primary-tint);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-2);
  }

  .killer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .killer-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .killer-author:hover {
    color: var(--primary);
  }

  .killer-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--primary-border);
    flex-shrink: 0;
  }

  .killer-author-name {
    font-size: 0.9rem;
    color: var(--text-2);
    transition: color var(--duration-fast);
  }

  .killer-author:hover .killer-author-name {
    color: var(--primary);
  }

  .killer-skills {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--primary);
    background: var(--primary-tint);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .killer-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .killer-cta-primary {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    transition: letter-spacing var(--duration-fast), opacity var(--duration-fast);
  }

  .killer-cta-primary:hover {
    letter-spacing: 0.04em;
    opacity: 0.85;
  }

  .killer-cta-secondary {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    background: var(--surface-3);
    border: 1px solid var(--border);
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }

  .killer-cta-secondary:hover {
    border-color: var(--primary-border);
    color: var(--text);
  }

  @media (max-width: 768px) {
    .killer-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
    }
  }
</style>

<script is:inline>
  (function() {
    var card = document.querySelector('.killer-card');
    if (!card) return;
    card.addEventListener('click', function(e) {
      if (e.target.closest('a')) {
        return;
      }
      var slug = card.dataset.slug;
      var week = card.dataset.week;
      if (window.trackEvent) {
        window.trackEvent('killer_skill_click', { slug: slug, week: week });
      }
      if (window.logFirebaseEvent) {
        window.logFirebaseEvent('killer_skill_click', { slug: slug, week: week });
      }
      var href = card.dataset.href;
      if (href) {
        if (card.dataset.external === 'true') {
          window.open(href, '_blank', 'noopener,noreferrer');
        } else {
          window.location.href = href;
        }
      }
    });
  })();
</script>
