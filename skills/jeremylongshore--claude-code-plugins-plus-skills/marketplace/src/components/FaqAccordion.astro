---
/**
 * FaqAccordion — Exclusive accordion for FAQ / troubleshooting items.
 * Accessible: <button> triggers, aria-expanded, keyboard support.
 * Clicking one item closes the others.
 */

interface FaqItem {
  question: string;
  answer: string; // HTML
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="faq-accordion" data-faq-group>
  {items.map((item, i) => (
    <div class="faq-item" data-faq-item>
      <button
        class="faq-trigger"
        aria-expanded="false"
        aria-controls={`faq-answer-${i}`}
        id={`faq-trigger-${i}`}
      >
        <svg class="faq-chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
          <path d="M4 2 L10 6 L4 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="faq-question">{item.question}</span>
      </button>
      <div
        class="faq-answer"
        id={`faq-answer-${i}`}
        role="region"
        aria-labelledby={`faq-trigger-${i}`}
        hidden
      >
        <div class="faq-answer-inner" set:html={item.answer} />
      </div>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll('[data-faq-group]').forEach(group => {
    const triggers = group.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('[data-faq-item]');
        const answer = item?.querySelector('.faq-answer') as HTMLElement;
        if (!answer) return;

        const isOpen = trigger.getAttribute('aria-expanded') === 'true';

        // Close all items in this group (exclusive)
        group.querySelectorAll('[data-faq-item]').forEach(other => {
          const otherTrigger = other.querySelector('.faq-trigger');
          const otherAnswer = other.querySelector('.faq-answer') as HTMLElement;
          if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
          if (otherAnswer) otherAnswer.hidden = true;
        });

        // Toggle clicked item (if it was closed, open it)
        if (!isOpen) {
          trigger.setAttribute('aria-expanded', 'true');
          answer.hidden = false;
        }
      });
    });
  });
</script>

<style>
  .faq-accordion {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid var(--border, var(--brand-light-gray));
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-trigger {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 0.5rem;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text, var(--brand-dark));
    transition: color var(--duration-fast) var(--ease-out);
    border-left: 3px solid transparent;
  }

  .faq-trigger:hover {
    color: var(--primary, var(--brand-orange));
  }

  .faq-trigger:focus-visible {
    outline: 2px solid var(--primary, var(--brand-orange));
    outline-offset: -2px;
    border-radius: var(--radius-sm);
  }

  .faq-trigger[aria-expanded="true"] {
    border-left-color: var(--primary, var(--brand-orange));
    color: var(--primary, var(--brand-orange));
  }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--text-3, var(--brand-mid-gray));
    transition: transform var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
  }

  .faq-trigger[aria-expanded="true"] .faq-chevron {
    transform: rotate(90deg);
    color: var(--primary, var(--brand-orange));
  }

  .faq-question {
    flex: 1;
  }

  .faq-answer {
    padding: 0 0.5rem 1rem 2.25rem;
    color: var(--text-2, var(--brand-mid-gray));
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .faq-answer-inner :global(p) {
    margin-bottom: 0.75rem;
  }

  .faq-answer-inner :global(p:last-child) {
    margin-bottom: 0;
  }

  .faq-answer-inner :global(code) {
    background: var(--surface-3, var(--brand-light-gray));
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-family: 'DM Mono', 'SF Mono', Monaco, monospace;
    font-size: 0.85rem;
  }

  .faq-answer-inner :global(pre) {
    background: var(--brand-dark);
    color: var(--brand-light, #f5f5f5);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    overflow-x: auto;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
  }

  .faq-answer-inner :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .faq-answer-inner :global(a) {
    color: var(--primary, var(--brand-orange));
    text-decoration: underline;
  }
</style>
