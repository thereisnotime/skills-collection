---
/**
 * DetailCta — Bottom call-to-action for plugin/skill detail pages.
 * Primary: copy install command. Secondary: view on GitHub.
 */

interface Props {
  installCommand: string;
  pluginName: string;
  repositoryUrl?: string;
}

const { installCommand, pluginName, repositoryUrl } = Astro.props;
---

<section class="detail-cta">
  <h2 class="detail-cta__headline">Ready to use {pluginName}?</h2>
  <div class="detail-cta__actions">
    <button class="detail-cta__primary" data-copy-install={installCommand}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M3 11V3a1 1 0 011-1h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span class="detail-cta__btn-text">Copy Install Command</span>
    </button>
    {repositoryUrl && (
      <a href={repositoryUrl} class="detail-cta__secondary" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        View on GitHub
      </a>
    )}
  </div>
</section>

<script>
  document.querySelectorAll('[data-copy-install]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const command = (btn as HTMLElement).dataset.copyInstall || '';
      await navigator.clipboard.writeText(command);

      const textEl = btn.querySelector('.detail-cta__btn-text');
      if (textEl) {
        const original = textEl.textContent;
        textEl.textContent = 'Copied!';
        btn.classList.add('copied');

        if ((window as any).trackEvent) {
          (window as any).trackEvent('install_copied', {
            plugin_name: command.split(' ').pop() || '',
            source: 'detail_cta'
          });
        }

        setTimeout(() => {
          textEl.textContent = original;
          btn.classList.remove('copied');
        }, 2000);
      }
    });
  });
</script>

<style>
  .detail-cta {
    background: var(--surface-3, var(--brand-light-gray));
    border-top: 1px solid var(--border, var(--brand-light-gray));
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem;
    margin-top: 2rem;
    text-align: center;
  }

  .detail-cta__headline {
    font-family: 'Instrument Sans', 'Source Sans 3', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--text, var(--brand-dark));
    margin-bottom: 1.25rem;
  }

  .detail-cta__actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .detail-cta__primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: var(--primary, var(--brand-orange));
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }

  .detail-cta__primary:hover {
    background: var(--primary-dark, var(--brand-orange-dark));
    transform: translateY(-1px);
  }

  .detail-cta__primary.copied {
    background: var(--positive, var(--brand-green));
  }

  .detail-cta__secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: var(--text, var(--brand-dark));
    border: 1px solid var(--border, var(--brand-mid-gray));
    border-radius: var(--radius-md);
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
  }

  .detail-cta__secondary:hover {
    border-color: var(--primary, var(--brand-orange));
    color: var(--primary, var(--brand-orange));
  }

  @media (max-width: 480px) {
    .detail-cta__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .detail-cta__primary,
    .detail-cta__secondary {
      justify-content: center;
    }
  }
</style>
