---
/**
 * PartnerBar — homepage hero partner row.
 *
 * Source of truth: src/data/partners.json.
 * Renders 3-up at desktop, 2-up at mobile. NO marquee / infinite scroll —
 * with <5 partners, looping is a sparseness illusion.
 *
 * Each partner gets a 44×44 minimum touch target on mobile.
 */
import partnersData from '../data/partners.json';

const { partners } = partnersData;
---

<div class="partner-band" aria-label="Strategic partners">
  <span class="sr-only">Partners</span>
  <div class={`partner-bar-row partner-bar-count-${partners.length}`}>
    {partners.map((p) => (
      <a
        class="partner-link"
        href={p.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${p.name} (opens in new tab)`}
        style={p.accentColor ? `--partner-accent: ${p.accentColor};` : undefined}
      >
        {p.logoLight || p.logoDark ? (
          <span class="partner-logo-wrap" aria-hidden="false">
            {p.logoDark && (
              <img
                class="partner-logo partner-logo-dark"
                src={p.logoDark}
                alt={`${p.name} logo`}
                loading="eager"
                decoding="async"
                width="120"
                height="32"
              />
            )}
            {p.logoLight && (
              <img
                class="partner-logo partner-logo-light"
                src={p.logoLight}
                alt={p.logoDark ? '' : `${p.name} logo`}
                aria-hidden={p.logoDark ? 'true' : 'false'}
                loading="eager"
                decoding="async"
                width="120"
                height="32"
              />
            )}
          </span>
        ) : (
          <span class="partner-wordmark">{p.wordmark}</span>
        )}
        {p.tagline && <span class="partner-tagline">{p.tagline}</span>}
      </a>
    ))}
  </div>
</div>

<style>
  /* Full-bleed band — exits the hero, sits as its own row below.
     No max-width / centering inside; just border-top, border-bottom,
     vertical breathing room. The row inside is the constrained part. */
  .partner-band {
    width: 100%;
    padding: 1.5rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: flex;
    justify-content: center;
    background: var(--bg);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .partner-bar-row {
    display: grid;
    gap: 3rem;
    width: 100%;
    max-width: 1280px;
    padding: 0 var(--space-5);
  }

  /* 1, 2, 3, 4+ count layouts — explicit, never marquee */
  .partner-bar-count-1 { grid-template-columns: 1fr; }
  .partner-bar-count-2 { grid-template-columns: repeat(2, 1fr); }
  .partner-bar-count-3 { grid-template-columns: repeat(3, 1fr); }
  .partner-bar-count-4 { grid-template-columns: repeat(4, 1fr); }

  .partner-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    min-height: 44px;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    background: var(--panel);
    color: var(--ink);
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }

  .partner-link:hover {
    border-color: var(--partner-accent, var(--signal-edge));
    background: var(--panel-2);
    color: var(--ink);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .partner-logo-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .partner-logo {
    height: 28px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    display: block;
  }

  /* Default (dark theme): show the -dark variant (white/light fill), hide -light */
  .partner-logo-light { display: none; }
  .partner-logo-dark  { display: block; }

  /* Light theme: swap — show -light variant (dark/colored fill), hide -dark */
  :global([data-theme="light"]) .partner-logo-dark  { display: none; }
  :global([data-theme="light"]) .partner-logo-light { display: block; }

  .partner-wordmark {
    font-family: 'Inter Tight', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .partner-tagline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }

  /* Tablet — keep 3-up if 3 partners, else collapse to 2 */
  @media (max-width: 1024px) {
    .partner-bar-count-4 { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile — 2-up regardless of partner count, except n=1 stays 1-up */
  @media (max-width: 768px) {
    .partner-bar-row {
      gap: 1rem;
      padding: 0 var(--space-4);
    }
    .partner-bar-count-3,
    .partner-bar-count-4 {
      grid-template-columns: repeat(2, 1fr);
    }
    .partner-link {
      padding: var(--space-3);
    }
    .partner-wordmark {
      font-size: 0.85rem;
    }
    .partner-tagline {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .partner-band {
      padding: 1rem 0;
    }
    .partner-logo {
      max-height: 24px;
      height: 24px;
    }
  }
</style>
