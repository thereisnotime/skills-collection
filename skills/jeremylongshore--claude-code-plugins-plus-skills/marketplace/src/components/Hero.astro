---
interface Props {
  totalPlugins: number;
  totalCategories: number;
}

const { totalPlugins, totalCategories } = Astro.props;
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        Claude Code plugins.
        <br />
        <span class="hero-count">{totalPlugins}</span> of them.
      </h1>
      <p class="hero-subtitle">
        Open-source marketplace. {totalPlugins} plugins across {totalCategories} categories. 100% inspectable, 100% free.
      </p>

      <div class="quick-install">
        <div class="install-label">install</div>
        <div class="install-code-wrapper">
          <pre class="install-code"><code>/plugin marketplace add jeremylongshore/claude-code-plugins</code></pre>
          <button class="copy-btn" onclick="navigator.clipboard.writeText('/plugin marketplace add jeremylongshore/claude-code-plugins').then(() => { const btn = this; btn.textContent = 'copied'; setTimeout(() => btn.textContent = 'copy', 2000); })">
            copy
          </button>
        </div>
        <p class="install-note">
          Switching from the legacy slug? Run <code>/plugin marketplace remove claude-code-plugins</code> first, then add the marketplace again to pick up <code>claude-code-plugins-plus</code>.
        </p>
        <p class="intent-note">
          Need broader AI delivery or MCP services? See partner offerings at <a href="https://www.intentsolutions.io/" target="_blank" rel="noopener noreferrer">Intent Solutions</a>.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 0 3rem;
    position: relative;
  }

  .hero-content {
    position: relative;
    text-align: left;
    max-width: 900px;
  }

  .hero-title {
    font-family: 'Inter Tight', sans-serif;
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    color: var(--ink);
  }

  .hero-count {
    color: var(--primary);
  }

  .hero-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: var(--text-lg);
    color: var(--ink-2);
    margin-bottom: 2.5rem;
    line-height: 1.5;
    max-width: 640px;
  }

  .quick-install {
    max-width: 600px;
  }

  .install-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ink-3);
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .install-code-wrapper {
    position: relative;
    background: var(--panel);
    border: 1px solid var(--rule);
    border-radius: 0;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .install-code-wrapper:hover {
    border-color: var(--rule-bright);
  }

  .install-code {
    flex: 1;
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    font-size: 0.875rem;
    overflow-x: auto;
    white-space: nowrap;
  }

  .install-code code {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--ink);
    font-size: 0.875rem;
    font-family: var(--font-mono);
  }

  .copy-btn {
    flex-shrink: 0;
    background: var(--primary);
    color: #0a0a0c;
    border: none;
    padding: 0.4rem 0.9rem;
    border-radius: 0;
    font-weight: 600;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: var(--font-mono);
    text-transform: lowercase;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .copy-btn:hover {
    background: var(--primary-dark);
  }

  .install-note,
  .intent-note {
    margin-top: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: var(--ink-2);
    line-height: 1.55;
  }

  .install-note code {
    background: var(--panel-2);
    color: var(--ink);
    padding: 0.1rem 0.35rem;
    border-radius: 0;
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .intent-note a {
    color: var(--primary);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid rgb(250 255 105 / 0.40);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .intent-note a:hover {
    border-bottom-color: rgb(250 255 105 / 0.80);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0;
    }

    .install-code-wrapper {
      flex-direction: column;
      align-items: stretch;
    }

    .copy-btn {
      width: 100%;
    }
  }
</style>
