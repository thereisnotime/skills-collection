---
// PlaybookTemplate.astro — reusable template for playbook pages.
// Wraps content in BaseLayout so every playbook gets the site nav, footer,
// theme system, and SEO — same pattern as DocsTemplate.astro.
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  wordCount: number;
  slug: string;
}

const { title, description, category, wordCount, slug } = Astro.props;

// Navigation data for prev/next
const playbooks = [
  { slug: '01-multi-agent-rate-limits', title: 'Multi-Agent Rate Limits' },
  { slug: '02-cost-caps', title: 'Cost Caps & Budget Management' },
  { slug: '03-mcp-reliability', title: 'MCP Server Reliability' },
  { slug: '04-ollama-migration', title: 'Ollama Migration Guide' },
  { slug: '05-incident-debugging', title: 'Incident Debugging Playbook' },
  { slug: '06-self-hosted-stack', title: 'Self-Hosted Stack Setup' },
  { slug: '07-compliance-audit', title: 'Compliance & Audit Guide' },
  { slug: '08-team-presets', title: 'Team Presets & Workflows' },
  { slug: '09-cost-attribution', title: 'Cost Attribution System' },
  { slug: '10-progressive-enhancement', title: 'Progressive Enhancement Patterns' },
  { slug: '11-advanced-tool-use', title: 'Advanced Tool Use' },
  { slug: '12-beginner-onboarding', title: 'Beginner Onboarding' },
  { slug: '13-production-setup', title: 'Production Setup' },
  { slug: '14-troubleshooting', title: 'Troubleshooting' }
];

const currentIndex = playbooks.findIndex(p => p.slug === slug);
const prevPlaybook = currentIndex > 0 ? playbooks[currentIndex - 1] : null;
const nextPlaybook = currentIndex < playbooks.length - 1 ? playbooks[currentIndex + 1] : null;
---

<BaseLayout title={`${title} | Production Playbooks`} description={description}>
  <div class="playbook-page">
    <header class="playbook-header">
      <div class="container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb-separator">/</span>
          <a href="/playbooks">Playbooks</a>
          <span class="breadcrumb-separator">/</span>
          <span class="breadcrumb-current">{title}</span>
        </nav>

        <div class="playbook-hero">
          <span class="category-badge">{category}</span>
          <h1 class="playbook-title">{title}</h1>
          <p class="playbook-description">{description}</p>
          <div class="playbook-meta">
            <span class="meta-item">~{Math.round(wordCount / 200)} min read</span>
            <span class="meta-divider">•</span>
            <span class="meta-item">{wordCount.toLocaleString()} words</span>
            <span class="meta-divider">•</span>
            <span class="meta-item">Production-Ready</span>
          </div>
        </div>
      </div>
    </header>

    <main class="playbook-main">
      <div class="container">
        <div class="playbook-layout">
          <aside class="toc-sidebar" id="toc-sidebar">
            <div class="toc-sticky">
              <h2 class="toc-title">Table of Contents</h2>
              <nav class="toc-nav" id="toc-nav" aria-label="Section navigation">
                <!-- Populated by script below -->
              </nav>
            </div>
          </aside>

          <article class="playbook-content">
            <slot />
          </article>
        </div>
      </div>
    </main>

    <footer class="playbook-footer">
      <div class="container">
        <div class="footer-nav">
          {prevPlaybook && (
            <a href={`/playbooks/${prevPlaybook.slug}`} class="nav-link nav-prev">
              <span class="nav-label">Previous</span>
              <span class="nav-title">{prevPlaybook.title}</span>
            </a>
          )}
          {nextPlaybook && (
            <a href={`/playbooks/${nextPlaybook.slug}`} class="nav-link nav-next">
              <span class="nav-label">Next</span>
              <span class="nav-title">{nextPlaybook.title}</span>
            </a>
          )}
        </div>

        <div class="back-to-index">
          <a href="/playbooks" class="back-link">← Back to All Playbooks</a>
        </div>
      </div>
    </footer>
  </div>

  <style>
    .playbook-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Header */
    .playbook-header {
      background: var(--surface, var(--brand-light));
      border-bottom: 1px solid var(--border, var(--brand-light-gray));
      padding: 2rem 0;
    }

    .breadcrumbs {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      margin-bottom: 2rem;
      color: var(--text-3, var(--brand-mid-gray));
    }

    .breadcrumbs a {
      color: var(--text-3, var(--brand-mid-gray));
      transition: color var(--transition-fast, 150ms ease);
    }

    .breadcrumbs a:hover { color: var(--primary, var(--brand-orange)); }
    .breadcrumb-separator { color: var(--text-3, var(--brand-mid-gray)); }
    .breadcrumb-current { color: var(--text, var(--brand-dark)); }

    .playbook-hero { max-width: 800px; }

    .category-badge {
      display: inline-block;
      background: var(--primary-tint, rgba(217, 119, 87, 0.1));
      color: var(--primary, var(--brand-orange));
      padding: 0.375rem 0.75rem;
      border-radius: 0.375rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border: 1px solid var(--primary-border, rgba(217, 119, 87, 0.2));
      margin-bottom: 1rem;
    }

    .playbook-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900;
      color: var(--text, var(--brand-dark));
      margin-bottom: 1rem;
      line-height: 1.1;
    }

    .playbook-description {
      font-size: 1.125rem;
      color: var(--text-2, var(--brand-mid-gray));
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .playbook-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.875rem;
      color: var(--text-3, var(--brand-mid-gray));
    }

    .meta-divider { color: var(--border, var(--brand-light-gray)); }

    /* Main layout */
    .playbook-main { flex: 1; padding: 3rem 0; }

    .playbook-layout {
      display: grid;
      grid-template-columns: 250px 1fr;
      gap: 3rem;
      align-items: start;
    }

    /* Table of Contents */
    .toc-sidebar { position: relative; }
    .toc-sticky { position: sticky; top: 2rem; }

    .toc-title {
      font-size: 0.875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-3, var(--brand-mid-gray));
      margin-bottom: 1rem;
    }

    .toc-nav { display: flex; flex-direction: column; gap: 0.5rem; }

    .toc-nav a {
      display: block;
      color: var(--text-2, var(--brand-mid-gray));
      font-size: 0.875rem;
      padding: 0.375rem 0.75rem;
      border-left: 2px solid var(--border, var(--brand-light-gray));
      transition: all var(--transition-fast, 150ms ease);
    }

    .toc-nav a:hover {
      color: var(--primary, var(--brand-orange));
      border-left-color: var(--primary, var(--brand-orange));
      background: var(--primary-tint, rgba(217, 119, 87, 0.05));
    }

    .toc-nav a.active {
      color: var(--primary, var(--brand-orange));
      border-left-color: var(--primary, var(--brand-orange));
      font-weight: 600;
    }

    /* Content typography */
    .playbook-content { max-width: 800px; }

    .playbook-content :global(h2) {
      font-size: 2rem;
      font-weight: 800;
      color: var(--text, var(--brand-dark));
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--border, var(--brand-light-gray));
      scroll-margin-top: 2rem;
    }

    .playbook-content :global(h3) {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text, var(--brand-dark));
      margin-top: 2rem;
      margin-bottom: 1rem;
      scroll-margin-top: 2rem;
    }

    .playbook-content :global(h4) {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text, var(--brand-dark));
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      scroll-margin-top: 2rem;
    }

    .playbook-content :global(p) {
      margin-bottom: 1.25rem;
      line-height: 1.7;
      color: var(--text, var(--brand-dark));
    }

    .playbook-content :global(a) {
      color: var(--primary, var(--brand-orange));
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .playbook-content :global(a:hover) { color: var(--primary-dark, var(--brand-orange-dark)); }

    .playbook-content :global(ul),
    .playbook-content :global(ol) { margin-bottom: 1.25rem; padding-left: 1.5rem; }

    .playbook-content :global(li) {
      margin-bottom: 0.5rem;
      line-height: 1.7;
      color: var(--text, var(--brand-dark));
    }

    .playbook-content :global(table) {
      width: 100%;
      margin: 2rem 0;
      border-collapse: collapse;
      background: var(--card, var(--brand-light));
      border: 1px solid var(--border, var(--brand-light-gray));
      border-radius: 0.5rem;
      overflow: hidden;
    }

    .playbook-content :global(th) {
      background: var(--surface-2, var(--brand-light-gray));
      color: var(--text, var(--brand-dark));
      font-weight: 600;
      text-align: left;
      padding: 0.75rem 1rem;
      border-bottom: 2px solid var(--border, var(--brand-light-gray));
    }

    .playbook-content :global(td) {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border, var(--brand-light-gray));
      color: var(--text, var(--brand-dark));
    }

    .playbook-content :global(tr:last-child td) { border-bottom: none; }

    .playbook-content :global(pre) {
      background: var(--surface-2, var(--brand-light));
      border: 1px solid var(--border, var(--brand-light-gray));
      border-radius: 0.5rem;
      padding: 1.5rem;
      overflow-x: auto;
      margin: 1.5rem 0;
      font-size: 0.875rem;
      line-height: 1.6;
      color: var(--text, var(--brand-dark));
    }

    .playbook-content :global(code) {
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      font-size: 0.875em;
    }

    .playbook-content :global(:not(pre) > code) {
      background: var(--surface-2, var(--brand-light-gray));
      color: var(--text, var(--brand-dark));
      padding: 0.15em 0.4em;
      border-radius: 0.25rem;
      border: 1px solid var(--border, var(--brand-light-gray));
    }

    .playbook-content :global(blockquote) {
      border-left: 4px solid var(--primary, var(--brand-orange));
      background: var(--primary-tint, rgba(217, 119, 87, 0.05));
      padding: 1rem 1.5rem;
      margin: 1.5rem 0;
      color: var(--text, var(--brand-dark));
      font-style: italic;
    }

    .playbook-content :global(hr) {
      border: none;
      border-top: 1px solid var(--border, var(--brand-light-gray));
      margin: 3rem 0;
    }

    /* Footer nav */
    .playbook-footer {
      background: var(--surface, var(--brand-light));
      border-top: 1px solid var(--border, var(--brand-light-gray));
      padding: 2rem 0;
      margin-top: 4rem;
    }

    .footer-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .nav-link {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem;
      background: var(--card, var(--brand-light-gray));
      border: 1px solid var(--border, var(--brand-light-gray));
      border-radius: 0.75rem;
      transition: all var(--transition-base, 200ms ease);
    }

    .nav-link:hover {
      border-color: var(--primary, var(--brand-orange));
      box-shadow: 0 0 0 1px var(--primary, var(--brand-orange));
      transform: translateY(-2px);
    }

    .nav-prev { text-align: left; }
    .nav-next { text-align: right; margin-left: auto; }

    .nav-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-3, var(--brand-mid-gray));
    }

    .nav-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text, var(--brand-dark));
    }

    .back-to-index {
      text-align: center;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border, var(--brand-light-gray));
    }

    .back-link {
      color: var(--primary, var(--brand-orange));
      font-weight: 600;
      transition: color var(--transition-fast, 150ms ease);
    }

    .back-link:hover { color: var(--primary-dark, var(--brand-orange-light)); }

    /* Responsive */
    @media (max-width: 1024px) {
      .playbook-layout { grid-template-columns: 1fr; gap: 2rem; }
      .toc-sidebar { display: none; }
    }

    @media (max-width: 640px) {
      .playbook-header { padding: 1.5rem 0; }
      .playbook-main { padding: 2rem 0; }
      .footer-nav { grid-template-columns: 1fr; }
      .nav-next { margin-left: 0; }
      .playbook-meta { flex-wrap: wrap; }
    }
  </style>

  <script>
    // Generate Table of Contents from h2 and h3 headings within playbook content.
    function generateTOC() {
      const content = document.querySelector('.playbook-content');
      const tocNav = document.getElementById('toc-nav');
      if (!content || !tocNav) return;

      const headings = content.querySelectorAll('h2, h3');
      headings.forEach((heading, index) => {
        if (!heading.id) heading.id = `section-${index}`;
        const link = document.createElement('a');
        link.href = `#${heading.id}`;
        link.textContent = heading.textContent;
        link.style.paddingLeft = heading.tagName === 'H3' ? '1.5rem' : '0.75rem';
        tocNav.appendChild(link);
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocNav.querySelectorAll('a').forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
            });
          }
        });
      }, { rootMargin: '-100px 0px -66%' });

      headings.forEach(heading => observer.observe(heading));
    }

    document.addEventListener('DOMContentLoaded', generateTOC);
  </script>
</BaseLayout>
