---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Browse 244 searchable agent skills and 259 plugins. Fuzzy search, interactive tutorials, and production-ready tools for Claude Code.", image = "/og-image.png" } = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content="Intent Solutions IO">
    <meta name="theme-color" content="#0a0a0c">
    <link rel="canonical" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <!-- Theme: prevent FOUC by setting data-theme before first paint -->
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(!t){t=window.matchMedia('(prefers-color-scheme:light)').matches?'light':'dark'}document.documentElement.setAttribute('data-theme',t)})();
    </script>

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN">
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:site_name" content="Claude Code Plugins">
    <meta property="og:image" content={`https://tonsofskills.com${image}`}>
    <meta property="og:image:alt" content={title}>
    <meta property="og:locale" content="en_US">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={`https://tonsofskills.com${image}`}>
    <meta name="twitter:creator" content="@jeremylshore">

    <slot name="head" />

    <!-- Umami Analytics (self-hosted, privacy-friendly, no cookies, GDPR-clean by design)
         Source of truth for site-id mapping: ~/.claude/skills/web-analytics/references/site-registry.md
         Backend: analytics.intentsolutions.io (Contabo VPS, Watchtower-updated) -->
    <script defer src="https://analytics.intentsolutions.io/script.js" data-website-id="0cee47ed-bee5-48da-8fed-46b3d8a2ddd3" data-domains="tonsofskills.com,www.tonsofskills.com"></script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9Z1DTMTT44"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9Z1DTMTT44');
    </script>

    <!-- Unified Analytics Helper -->
    <script is:inline src="/scripts/analytics.js"></script>

    <!-- Fonts: Inter Tight (display), Inter (body, with tnum), JetBrains Mono (mono).
         Family: Data-Dense Pro. See marketplace/DESIGN.md § Typography. -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        @import '../styles/tokens.css';

        /* ========================================
           DARK THEME (default) — Data-Dense Pro
           Surface aliases map to the new --bg / --panel system in tokens.css.
           Components referencing --surface*, --text*, --border* keep working.
           ======================================== */
        :root {
            /* Surface aliases → new family tokens */
            --surface:   var(--bg);          /* page canvas */
            --surface-1: var(--panel);       /* card / panel */
            --surface-2: var(--panel-2);     /* hover state */
            --surface-3: var(--panel-2);     /* unused tertiary; mapped to panel-2 */

            /* Legacy accent aliases */
            --navy:  var(--panel);
            --red:   var(--alert);
            --gold:  var(--signal);

            /* Borders → rule */
            --border:        var(--rule);
            --border-bright: var(--rule-bright);

            /* Text aliases → ink scale */
            --text:   var(--ink);
            --text-2: var(--ink-2);
            --text-3: var(--ink-3);

            /* Cards */
            --card:       var(--panel);
            --card-hover: var(--panel-2);

            /* Legacy brand-* aliases (also defined in global.css) */
            --brand-dark:         var(--bg);
            --brand-light:        var(--ink);
            --brand-mid-gray:     var(--ink-2);
            --brand-light-gray:   var(--rule);
            --brand-orange:       var(--signal);
            --brand-orange-dark:  var(--signal-deep);
            --brand-orange-light: var(--signal-edge);
            --brand-blue:         var(--ink-link);
            --brand-green:        var(--positive);

            --transition-smooth: var(--ease-out);
            --body-weight: 400;
        }

        /* ========================================
           LIGHT THEME — high-contrast off-white reskin
           ======================================== */
        :global([data-theme="light"]) {
            --surface:   var(--bg);
            --surface-1: var(--panel);
            --surface-2: var(--panel-2);
            --surface-3: var(--panel-2);

            --navy:  var(--panel);
            --red:   var(--alert);
            --gold:  var(--signal-deep);

            --border:        var(--rule);
            --border-bright: var(--rule-bright);

            --text:   var(--ink);
            --text-2: var(--ink-2);
            --text-3: var(--ink-3);

            --card:       var(--panel);
            --card-hover: var(--panel-2);

            --brand-dark:         var(--ink);
            --brand-light:        var(--panel);
            --brand-mid-gray:     var(--ink-2);
            --brand-light-gray:   var(--rule);
            --brand-orange:       var(--signal-deep);
            --brand-orange-dark:  #a3a302;
            --brand-orange-light: var(--signal-edge);
            --brand-blue:         var(--ink-link);
            --brand-green:        var(--positive);

            --body-weight: 400;
        }

        :global(*), :global(*::before), :global(*::after) {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :global(html), :global(body) {
            overflow-x: hidden;
            max-width: 100%;
            scroll-behavior: smooth;
            scroll-padding-top: 90px;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            font-weight: var(--body-weight, 400);
            background-color: var(--surface-1);
            color: var(--text);
            line-height: 1.7;
        }

        h1, h2 {
            font-family: 'Inter Tight', system-ui, sans-serif;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        h3, h4, h5, h6 {
            font-family: 'Inter Tight', system-ui, sans-serif;
            font-weight: 600;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 0.75rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            background: transparent;
            border-bottom: 1px solid transparent;
            backdrop-filter: blur(12px);
            transition: background var(--duration-fast) var(--ease-out),
                        border-color var(--duration-fast) var(--ease-out),
                        box-shadow var(--duration-fast) var(--ease-out);
        }

        nav.scrolled {
            background: var(--surface);
            border-bottom-color: var(--border);
            
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 600;
            font-size: 1.1rem;
            letter-spacing: -0.02em;
            color: var(--text);
            text-decoration: none;
            font-family: 'Inter', system-ui, sans-serif;
        }

        .logo-title {
            font-family: 'Inter Tight', system-ui, sans-serif;
            font-weight: 700;
            font-size: 1.2rem;
            letter-spacing: -0.01em;
            color: var(--ink);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
            align-items: center;
            font-family: 'Inter', system-ui, sans-serif;
        }

        .nav-links a {
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: color var(--duration-fast) var(--ease-out);
        }

        .nav-links a:hover {
            color: var(--text);
        }

        .nav-links a[aria-current="page"] {
            color: var(--ink);
            border-bottom: 1px solid var(--signal);
            padding-bottom: 2px;
        }

        /* nav-cta is the canonical primary CTA — signal yellow on near-black */
        .nav-cta {
            background: var(--signal);
            color: #0a0a0c;
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            font-weight: 600;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            transition: all var(--duration-fast) var(--ease-out);
        }

        .nav-cta:hover {
            background: #ffffa1;
            color: #0a0a0c;
            transform: translateY(-1px);
        }

        /* Nav Right (toggle + hamburger) */
        .nav-right {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Theme Toggle */
        .theme-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-2);
            cursor: pointer;
            transition: all var(--duration-fast) var(--ease-out);
        }

        .theme-toggle:hover {
            color: var(--ink);
            border-color: var(--rule-bright);
            background: var(--panel-2);
        }

        /* Show sun in dark mode, moon in light mode */
        .theme-icon-sun { display: block; }
        .theme-icon-moon { display: none; }
        :global([data-theme="light"]) .theme-icon-sun { display: none; }
        :global([data-theme="light"]) .theme-icon-moon { display: block; }

        /* Mobile Menu */
        .mobile-menu-toggle {
            display: none;
            background: none;
            border: none;
            color: var(--text);
            cursor: pointer;
            padding: 0.5rem;
        }

        .mobile-menu-toggle svg {
            width: 24px;
            height: 24px;
        }

        /* Main Content */
        main {
            padding-top: 72px;
            min-height: calc(100vh - 72px);
        }

        /* ========================================
           FOOTER — semantic columns
           ======================================== */
        footer {
            background: var(--surface);
            color: var(--text-2);
            margin-top: var(--space-10);
            padding: var(--space-8) var(--space-6) var(--space-6);
            border-top: 1px solid var(--border);
        }

        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
        }

        .footer-signup-row {
            margin-bottom: var(--space-6);
            padding-bottom: var(--space-6);
            border-bottom: 1px solid var(--border);
            text-align: center;
        }

        .footer-signup-row h4 {
            color: var(--ink-2);
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-family: 'JetBrains Mono', monospace;
            margin-bottom: 0.75rem;
        }

        .footer-signup-form {
            display: flex;
            gap: 0.5rem;
            max-width: 400px;
            margin: 0 auto;
        }

        .footer-signup-form input {
            flex: 1;
            padding: 0.6rem 0.75rem;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            font-size: 0.85rem;
            font-family: 'Inter', system-ui, sans-serif;
            outline: none;
            transition: border-color var(--duration-fast);
        }

        .footer-signup-form input:focus {
            border-color: var(--signal);
        }

        .footer-signup-form button {
            padding: 0.6rem 1rem;
            background: var(--signal);
            color: #0a0a0c;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
            min-height: 44px;
            cursor: pointer;
            font-family: 'Inter', system-ui, sans-serif;
            transition: all var(--duration-fast);
            white-space: nowrap;
        }

        .footer-signup-form button:hover {
            background: #ffffa1;
            color: #0a0a0c;
        }

        .footer-form-note {
            margin-top: 0.5rem;
            font-size: 0.7rem;
            color: var(--text-3);
            font-family: 'JetBrains Mono', monospace;
            text-align: center;
        }

        .footer-columns {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-6);
            margin-bottom: var(--space-6);
        }

        .footer-col h5 {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-3);
            margin-bottom: var(--space-3);
        }

        .footer-col ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-col li {
            margin-bottom: var(--space-2);
        }

        .footer-col a {
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.85rem;
            transition: color var(--duration-fast);
        }

        .footer-col a:hover {
            color: var(--text);
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: var(--space-5);
            border-top: 1px solid var(--border);
            flex-wrap: wrap;
            gap: var(--space-3);
        }

        .footer-blurb {
            font-size: 0.8rem;
            line-height: 1.6;
            color: var(--text-3);
            max-width: 480px;
        }

        .footer-blurb a {
            color: var(--text-2);
            text-decoration: underline;
        }

        .footer-copyright {
            font-size: 0.75rem;
            color: var(--text-3);
        }

        .footer-copyright a {
            color: var(--text-2);
            text-decoration: none;
        }

        .footer-copyright a:hover {
            color: var(--text);
        }

        /* Mobile Styles */
        @media (max-width: 768px) {
            nav {
                padding: 0.75rem 1.5rem;
            }

            .mobile-menu-toggle {
                display: block;
            }

            .nav-links {
                display: none;
                position: fixed;
                top: 0;
                right: -100%;
                width: 80%;
                max-width: 300px;
                height: 100vh;
                background: var(--surface-1);
                border-left: 1px solid var(--border);
                flex-direction: column;
                gap: 0;
                padding: 5rem 0 2rem;
                transition: right var(--duration-normal) var(--ease-out);
                overflow-y: auto;
                z-index: 999;
                
            }

            .nav-links.active {
                display: flex;
                right: 0;
            }

            .nav-links li {
                width: 100%;
            }

            .nav-links a {
                display: block;
                padding: 1rem 2rem;
                border-bottom: 1px solid var(--border);
            }

            .nav-cta {
                margin: 1rem 2rem;
                text-align: center;
                display: block;
            }

            main {
                padding-top: 64px;
            }

            .footer-columns {
                grid-template-columns: repeat(2, 1fr);
                gap: var(--space-5);
            }

            .footer-bottom {
                flex-direction: column;
                text-align: center;
            }

            .footer-blurb {
                max-width: 100%;
            }
        }

        @media (max-width: 480px) {
            .footer-columns {
                grid-template-columns: 1fr;
            }
        }

        /* Prevent body scroll when mobile menu is open */
        body.menu-open {
            overflow: hidden;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <a href="/" class="logo">
            <span class="logo-title">Tons of Skills</span>
        </a>
        <div class="nav-right">
        <button class="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark mode">
            <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="mobile-menu-toggle" aria-label="Toggle menu">
            <svg class="menu-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
