---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Browse 244 searchable agent skills and 259 plugins. Fuzzy search, interactive tutorials, and production-ready tools for Claude Code.", image = "/og-image.png" } = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content="Intent Solutions IO">
    <meta name="theme-color" content="#1a1816">
    <link rel="canonical" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <!-- Theme: prevent FOUC by setting data-theme before first paint -->
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(!t){t=window.matchMedia('(prefers-color-scheme:light)').matches?'light':'dark'}document.documentElement.setAttribute('data-theme',t)})();
    </script>

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN">
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:site_name" content="Claude Code Plugins">
    <meta property="og:image" content={`https://tonsofskills.com${image}`}>
    <meta property="og:image:alt" content={title}>
    <meta property="og:locale" content="en_US">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={`https://tonsofskills.com${image}`}>
    <meta name="twitter:creator" content="@jeremylshore">

    <slot name="head" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9Z1DTMTT44"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9Z1DTMTT44');
    </script>

    <!-- Firebase Analytics -->
    <script type="module" is:inline define:vars={{ firebaseConfigJson: import.meta.env.PUBLIC_FIREBASE_CONFIG || '{}' }}>
      import { initializeApp } from 'https://www.gstatic.com/firebasejs/11.8.1/firebase-app.js';
      import { getAnalytics, logEvent } from 'https://www.gstatic.com/firebasejs/11.8.1/firebase-analytics.js';

      // Config injected from Secret Manager at build time
      const firebaseConfig = JSON.parse(firebaseConfigJson);

      if (firebaseConfig.apiKey) {
        const app = initializeApp(firebaseConfig);
        const analytics = getAnalytics(app);

        // Log page view with UTM attribution
        const urlParams = new URLSearchParams(window.location.search);
        const pageViewParams = {
          page_path: window.location.pathname,
          page_title: document.title
        };
        const utmSource = urlParams.get('utm_source');
        const utmMedium = urlParams.get('utm_medium');
        if (utmSource) pageViewParams.source = utmSource;
        if (utmMedium) pageViewParams.medium = utmMedium;
        logEvent(analytics, 'page_view', pageViewParams);

        // Make analytics available globally for custom events
        window.firebaseAnalytics = analytics;
        window.logFirebaseEvent = (eventName, params) => logEvent(analytics, eventName, params);
      }
    </script>

    <!-- Unified Analytics Helper -->
    <script is:inline src="/scripts/analytics.js"></script>

    <!-- Fonts: Instrument Sans (display), Source Sans 3 (body), DM Mono (mono/labels) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">

    <style>
        @import '../styles/tokens.css';

        /* ========================================
           DARK THEME (default)
           ======================================== */
        :root {
            /* Core surface palette — warm-tinted, never pure black */
            --surface:   oklch(12% 0.010 60);
            --surface-1: oklch(14% 0.010 60);
            --surface-2: oklch(18% 0.010 60);
            --surface-3: oklch(22% 0.010 60);

            /* Legacy accent aliases — map to new OKLCH tokens */
            --navy:  oklch(20% 0.010 60);
            --red:   var(--danger);
            --gold:  var(--primary);

            /* Borders */
            --border:        oklch(30% 0.008 60);
            --border-bright: oklch(38% 0.008 60);

            /* Text */
            --text:   oklch(92% 0.005 60);
            --text-2: oklch(65% 0.008 60);
            --text-3: oklch(50% 0.008 60);

            /* Cards */
            --card: oklch(18% 0.010 60);
            --card-hover: oklch(22% 0.010 60);

            /* Status */
            --positive: oklch(65% 0.18 145);
            --warning:  oklch(75% 0.15 85);
            --danger:   oklch(60% 0.20 25);

            /* Legacy brand-* aliases */
            --brand-dark:         oklch(12% 0.010 60);
            --brand-light:        oklch(92% 0.005 60);
            --brand-mid-gray:     oklch(65% 0.008 60);
            --brand-light-gray:   oklch(30% 0.008 60);
            --brand-orange:       oklch(62% 0.16 35);
            --brand-orange-dark:  oklch(48% 0.14 35);
            --brand-orange-light: oklch(78% 0.10 35);
            --brand-blue:         oklch(62% 0.15 250);
            --brand-green:        oklch(65% 0.18 145);

            --transition-smooth: var(--ease-out);

            /* Dark mode: lighter font weight */
            --body-weight: 350;
        }

        /* ========================================
           LIGHT THEME
           ======================================== */
        :global([data-theme="light"]) {
            /* Core surface palette */
            --surface:   oklch(94% 0.005 60);
            --surface-1: oklch(99% 0.002 60);
            --surface-2: oklch(97% 0.004 60);
            --surface-3: oklch(93% 0.005 60);

            /* Accent adjustment for light bg */
            --gold:  oklch(52% 0.14 35);

            /* Borders */
            --border:        oklch(82% 0.005 60);
            --border-bright: oklch(72% 0.005 60);

            /* Text */
            --text:   oklch(18% 0.010 60);
            --text-2: oklch(45% 0.008 60);
            --text-3: oklch(58% 0.008 60);

            /* Cards */
            --card: oklch(99% 0.002 60);
            --card-hover: oklch(97% 0.004 60);

            /* Status (vibrant on light) */
            --positive: oklch(48% 0.18 145);
            --warning:  oklch(55% 0.15 85);
            --danger:   oklch(50% 0.22 25);

            /* Legacy brand-* aliases for light */
            --brand-dark:         oklch(18% 0.010 60);
            --brand-light:        oklch(99% 0.002 60);
            --brand-mid-gray:     oklch(45% 0.008 60);
            --brand-light-gray:   oklch(82% 0.005 60);
            --brand-orange:       oklch(55% 0.16 35);
            --brand-orange-dark:  oklch(45% 0.14 35);
            --brand-orange-light: oklch(70% 0.10 35);
            --brand-blue:         oklch(50% 0.15 250);
            --brand-green:        oklch(48% 0.18 145);

            --body-weight: 400;
        }

        :global(*), :global(*::before), :global(*::after) {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :global(html), :global(body) {
            overflow-x: hidden;
            max-width: 100%;
            scroll-behavior: smooth;
            scroll-padding-top: 90px;
        }

        body {
            font-family: 'Source Sans 3', system-ui, sans-serif;
            font-weight: var(--body-weight, 400);
            background-color: var(--surface-1);
            color: var(--text);
            line-height: 1.7;
        }

        h1, h2 {
            font-family: 'Instrument Sans', system-ui, sans-serif;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        h3, h4, h5, h6 {
            font-family: 'Instrument Sans', system-ui, sans-serif;
            font-weight: 600;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 0.75rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            background: transparent;
            border-bottom: 1px solid transparent;
            backdrop-filter: blur(12px);
            transition: background var(--duration-fast) var(--ease-out),
                        border-color var(--duration-fast) var(--ease-out),
                        box-shadow var(--duration-fast) var(--ease-out);
        }

        nav.scrolled {
            background: var(--surface);
            border-bottom-color: var(--border);
            box-shadow: 0 1px 4px oklch(0% 0 0 / 0.2);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 600;
            font-size: 1.1rem;
            letter-spacing: -0.02em;
            color: var(--text);
            text-decoration: none;
            font-family: 'Source Sans 3', system-ui, sans-serif;
        }

        .logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .logo-title {
            font-family: 'Instrument Sans', system-ui, sans-serif;
            font-weight: 700;
            font-size: 1.2rem;
            letter-spacing: -0.01em;
            color: var(--primary);
        }

        .logo-subtitle {
            font-size: 0.65rem;
            font-weight: 400;
            color: var(--text-3);
            letter-spacing: 0.02em;
            font-family: 'DM Mono', monospace;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--primary);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--surface);
            font-weight: 700;
            font-size: 1.2rem;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
            align-items: center;
            font-family: 'Source Sans 3', system-ui, sans-serif;
        }

        .nav-links a {
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: color var(--duration-fast) var(--ease-out);
        }

        .nav-links a:hover {
            color: var(--text);
        }

        .nav-links a[aria-current="page"] {
            color: var(--primary);
        }

        .nav-cta {
            background: var(--accent);
            color: var(--surface);
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            font-weight: 600;
            transition: all var(--duration-fast) var(--ease-out);
        }

        .nav-cta:hover {
            opacity: 0.9;
            color: var(--surface);
            transform: translateY(-1px);
        }

        /* Nav Right (toggle + hamburger) */
        .nav-right {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Theme Toggle */
        .theme-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-2);
            cursor: pointer;
            transition: all var(--duration-fast) var(--ease-out);
        }

        .theme-toggle:hover {
            color: var(--primary);
            border-color: var(--primary);
            background: oklch(62% 0.16 35 / 0.1);
        }

        /* Show sun in dark mode, moon in light mode */
        .theme-icon-sun { display: block; }
        .theme-icon-moon { display: none; }
        :global([data-theme="light"]) .theme-icon-sun { display: none; }
        :global([data-theme="light"]) .theme-icon-moon { display: block; }

        /* Mobile Menu */
        .mobile-menu-toggle {
            display: none;
            background: none;
            border: none;
            color: var(--text);
            cursor: pointer;
            padding: 0.5rem;
        }

        .mobile-menu-toggle svg {
            width: 24px;
            height: 24px;
        }

        /* Main Content */
        main {
            padding-top: 72px;
            min-height: calc(100vh - 72px);
        }

        /* ========================================
           FOOTER — semantic columns
           ======================================== */
        footer {
            background: var(--surface);
            color: var(--text-2);
            margin-top: var(--space-10);
            padding: var(--space-8) var(--space-6) var(--space-6);
            border-top: 1px solid var(--border);
        }

        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
        }

        .footer-signup-row {
            margin-bottom: var(--space-6);
            padding-bottom: var(--space-6);
            border-bottom: 1px solid var(--border);
            text-align: center;
        }

        .footer-signup-row h4 {
            color: var(--primary);
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-family: 'DM Mono', monospace;
            margin-bottom: 0.75rem;
        }

        .footer-signup-form {
            display: flex;
            gap: 0.5rem;
            max-width: 400px;
            margin: 0 auto;
        }

        .footer-signup-form input {
            flex: 1;
            padding: 0.6rem 0.75rem;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            font-size: 0.85rem;
            font-family: 'Source Sans 3', system-ui, sans-serif;
            outline: none;
            transition: border-color var(--duration-fast);
        }

        .footer-signup-form input:focus {
            border-color: var(--primary);
        }

        .footer-signup-form button {
            padding: 0.6rem 1rem;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            font-family: 'Source Sans 3', system-ui, sans-serif;
            transition: all var(--duration-fast);
            white-space: nowrap;
        }

        .footer-signup-form button:hover {
            opacity: 0.9;
        }

        .footer-form-note {
            margin-top: 0.5rem;
            font-size: 0.7rem;
            color: var(--text-3);
            font-family: 'DM Mono', monospace;
            text-align: center;
        }

        .footer-columns {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-6);
            margin-bottom: var(--space-6);
        }

        .footer-col h5 {
            font-family: 'DM Mono', monospace;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-3);
            margin-bottom: var(--space-3);
        }

        .footer-col ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-col li {
            margin-bottom: var(--space-2);
        }

        .footer-col a {
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.85rem;
            transition: color var(--duration-fast);
        }

        .footer-col a:hover {
            color: var(--text);
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: var(--space-5);
            border-top: 1px solid var(--border);
            flex-wrap: wrap;
            gap: var(--space-3);
        }

        .footer-blurb {
            font-size: 0.8rem;
            line-height: 1.6;
            color: var(--text-3);
            max-width: 480px;
        }

        .footer-blurb a {
            color: var(--text-2);
            text-decoration: underline;
        }

        .footer-copyright {
            font-size: 0.75rem;
            color: var(--text-3);
        }

        .footer-copyright a {
            color: var(--text-2);
            text-decoration: none;
        }

        .footer-copyright a:hover {
            color: var(--text);
        }

        /* Mobile Styles */
        @media (max-width: 768px) {
            nav {
                padding: 0.75rem 1.5rem;
            }

            .mobile-menu-toggle {
                display: block;
            }

            .nav-links {
                display: none;
                position: fixed;
                top: 0;
                right: -100%;
                width: 80%;
                max-width: 300px;
                height: 100vh;
                background: var(--surface-1);
                border-left: 1px solid var(--border);
                flex-direction: column;
                gap: 0;
                padding: 5rem 0 2rem;
                transition: right var(--duration-normal) var(--ease-out);
                overflow-y: auto;
                z-index: 999;
                box-shadow: -4px 0 20px rgba(0, 0, 0, 0.5);
            }

            .nav-links.active {
                display: flex;
                right: 0;
            }

            .nav-links li {
                width: 100%;
            }

            .nav-links a {
                display: block;
                padding: 1rem 2rem;
                border-bottom: 1px solid var(--border);
            }

            .nav-cta {
                margin: 1rem 2rem;
                text-align: center;
                display: block;
            }

            main {
                padding-top: 64px;
            }

            .logo-subtitle {
                display: none;
            }

            .footer-columns {
                grid-template-columns: repeat(2, 1fr);
                gap: var(--space-5);
            }

            .footer-bottom {
                flex-direction: column;
                text-align: center;
            }

            .footer-blurb {
                max-width: 100%;
            }
        }

        @media (max-width: 480px) {
            .footer-columns {
                grid-template-columns: 1fr;
            }
        }

        /* Prevent body scroll when mobile menu is open */
        body.menu-open {
            overflow: hidden;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <a href="/" class="logo">
            <div class="logo-icon">&#8984;</div>
            <div class="logo-text">
                <span class="logo-title">Tons of Skills</span>
            </div>
        </a>
        <div class="nav-right">
        <button class="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark mode">
            <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="mobile-menu-toggle" aria-label="Toggle menu">
            <svg class="menu-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="close-icon" style="display: none;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        <ul class="nav-links">
            <li><a href="/explore" aria-current={currentPath.startsWith('/explore') ? 'page' : undefined}>Explore</a></li>
            <li><a href="/skills" aria-current={currentPath.startsWith('/skills') ? 'page' : undefined}>Skills</a></li>
            <li><a href="/docs" aria-current={currentPath.startsWith('/docs') ? 'page' : undefined}>Docs</a></li>
            <li><a href="/learning" aria-current={currentPath.startsWith('/learning') ? 'page' : undefined}>Learn</a></li>
            <li><a href="/cowork" aria-current={currentPath.startsWith('/cowork') ? 'page' : undefined}>Cowork</a></li>
            <li><a href="/community" aria-current={currentPath.startsWith('/community') ? 'page' : undefined}>Community</a></li>
            <li><a href="/blog" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Work Diary</a></li>
            <li><a href="/getting-started" class="nav-cta">Get Started</a></li>
        </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        <slot />
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-inner">
            <div class="footer-signup-row">
                <h4>Stay in the Loop</h4>
                <form data-signup-form="footer" class="footer-signup-form">
                    <input type="email" name="email" placeholder="you@example.com" required />
                    <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" />
                    <button type="submit">Subscribe</button>
                </form>
                <p class="footer-form-note">No spam. Unsubscribe anytime.</p>
            </div>

            <div class="footer-columns">
                <div class="footer-col">
                    <h5>Product</h5>
                    <ul>
                        <li><a href="/explore">Explore</a></li>
                        <li><a href="/skills">Skills</a></li>
                        <li><a href="/cowork">Cowork</a></li>
                        <li><a href="/compare-marketplaces">Compare</a></li>
                        <li><a href="/tools">Tools</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h5>Resources</h5>
                    <ul>
                        <li><a href="/docs">Docs</a></li>
                        <li><a href="/changelog">Changelog</a></li>
                        <li><a href="/collections">Collections</a></li>
                        <li><a href="/playbooks">Playbooks</a></li>
                        <li><a href="/research">Research</a></li>
                        <li><a href="/learning">Learning</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h5>Company</h5>
                    <ul>
                        <li><a href="/community">Community</a></li>
                        <li><a href="/community#hall-of-fame">Hall of Fame</a></li>
                        <li><a href="https://github.com/jeremylongshore/claude-code-plugins" target="_blank">GitHub</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h5>Legal</h5>
                    <ul>
                        <li><a href="/privacy">Privacy</a></li>
                        <li><a href="/terms">Terms</a></li>
