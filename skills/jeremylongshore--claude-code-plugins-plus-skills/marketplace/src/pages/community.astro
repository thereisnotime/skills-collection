---
import BaseLayout from '../layouts/BaseLayout.astro';
import searchIndex from '../data/unified-search-index.json';
import spotlightData from '../data/spotlights.json';
const hallOfFame = spotlightData.hallOfFame || [];

const pageTitle = 'Community Contributors';
const pageDescription = 'Meet the community contributors who build and share plugins for the Claude Code ecosystem.';

// Compute community stats from search index
const allPlugins = searchIndex.items.filter(i => i.type === 'plugin');
const communityPlugins = allPlugins.filter(p => p.authorType === 'community');
const officialPlugins = allPlugins.filter(p => p.authorType === 'official');

// Group community plugins by contributor
const contributorMap = new Map();
communityPlugins.forEach(plugin => {
  const name = plugin.author?.name || 'Unknown';
  if (!contributorMap.has(name)) {
    contributorMap.set(name, { name, plugins: [], email: plugin.author?.email || '' });
  }
  contributorMap.get(name).plugins.push(plugin);
});
const contributors = [...contributorMap.values()].sort((a, b) => b.plugins.length - a.plugins.length);

function getContributionSummary(plugins: any[]): string {
  if (plugins.length === 1) {
    const desc = plugins[0].description || '';
    const sentence = desc.split('.')[0];
    return sentence ? `${sentence}.` : 'Contributed a community plugin.';
  }
  const catMap = new Map();
  plugins.forEach(p => {
    const cat = p.category?.replace(/-/g, ' ') || 'general';
    catMap.set(cat, (catMap.get(cat) || 0) + 1);
  });
  const cats = [...catMap.entries()].sort((a, b) => b[1] - a[1]);
  const topCats = cats.slice(0, 2).map(([cat, n]: [string, number]) => n > 1 ? `${n} ${cat}` : cat);
  const suffix = cats.length > 2 ? ' and more' : '';
  return `Contributed ${plugins.length} plugins: ${topCats.join(' and ')}${suffix}.`;
}
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <style>
    /* ── Hero ── */
    .community-hero {
      background: linear-gradient(135deg, var(--navy) 0%, var(--surface) 100%);
      color: var(--text);
      padding: 3rem 2rem 2rem;
      text-align: center;
    }

    .community-title {
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 700;
      margin-bottom: 0.75rem;
      line-height: 1.1;
    }

    .community-subtitle {
      font-size: 1.1rem;
      color: var(--text-2);
      max-width: 600px;
      margin: 0 auto;
    }

    .hero-stats-row {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      margin-top: 1.5rem;
      font-size: 0.85rem;
      color: var(--text-2);
    }

    .hero-stat {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      border-radius: var(--radius-md, 8px);
      padding: 0.75rem 1.25rem;
      text-align: center;
    }

    .hero-stat span {
      font-weight: 700;
      font-size: 1.3rem;
      display: block;
      color: var(--gold);
      line-height: 1.2;
    }

    /* ── Layout ── */
    .section-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    .section-heading {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 2rem;
      text-align: center;
    }

    /* ── Contributor Cards ── */
    .contributors-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(var(--grid-min-card, 300px), 1fr));
      gap: var(--grid-gap, 1.5rem);
      margin-bottom: 4rem;
    }

    .contributor-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--card-standard-radius, 12px);
      padding: var(--card-standard-padding, 1.5rem);
      transition: var(--card-transition, border-color 0.2s ease);
      cursor: pointer;
    }

    .contributor-card:hover {
      border-color: var(--gold);
      transform: var(--card-hover-lift, translateY(-2px));
      box-shadow: var(--card-hover-shadow-accent, 0 4px 16px rgba(234, 170, 0, 0.08));
    }

    .contributor-card:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 2px;
    }

    .contributor-card.expanded {
      border-color: var(--border-bright);
    }

    .contributor-header {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .contributor-info {
      flex: 1;
      min-width: 0;
    }

    .contributor-name {
      font-size: var(--text-card-title, 1.1rem);
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .contributor-summary {
      font-size: var(--text-card-desc, 0.875rem);
      color: var(--text-2);
      line-height: var(--text-line-height, 1.5);
      margin-top: 0.25rem;
    }

    .contributor-count {
      font-size: var(--text-card-meta, 0.8rem);
      color: var(--gold);
      font-weight: 600;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .toggle-chevron {
      color: var(--text-3);
      transition: transform var(--duration-fast) var(--ease-out);
      flex-shrink: 0;
      font-size: 1rem;
    }

    .contributor-card.expanded .toggle-chevron {
      transform: rotate(90deg);
    }

    /* ── Expanded Plugin List ── */
    .contributor-detail {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows var(--duration-normal) var(--ease-out);
    }

    .contributor-card.expanded .contributor-detail {
      grid-template-rows: 1fr;
    }

    .contributor-plugin-list {
      overflow: hidden;
      margin-top: 1rem;
      border-top: 1px solid var(--border);
      padding-top: 0.75rem;
    }

    .contributor-plugin-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      color: inherit;
      transition: background var(--duration-fast) var(--ease-out);
    }

    .contributor-plugin-row:last-child {
      border-bottom: none;
    }

    .contributor-plugin-row:hover {
      background: var(--surface-2);
      margin: 0 -0.5rem;
      padding: 0.5rem;
      border-radius: var(--radius-sm, 6px);
    }

    .plugin-row-info {
      flex: 1;
      min-width: 0;
    }

    .plugin-row-name {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .plugin-row-desc {
      font-size: 0.8rem;
      color: var(--text-2);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-top: 0.125rem;
    }

    .plugin-row-arrow {
      color: var(--text-3);
      flex-shrink: 0;
      font-size: 0.875rem;
    }

    /* ── Community Plugin Grid ── */
    .plugins-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(var(--grid-min-card, 300px), 1fr));
      gap: var(--grid-gap, 1.5rem);
      margin-bottom: 4rem;
    }

    .plugin-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--card-standard-radius, 12px);
      padding: var(--card-standard-padding, 1.5rem);
      text-decoration: none;
      color: inherit;
      display: block;
      transition: var(--card-transition, border-color 0.2s ease);
    }

    .plugin-card:hover {
      border-color: var(--gold);
      transform: var(--card-hover-lift, translateY(-2px));
      box-shadow: var(--card-hover-shadow-accent, 0 4px 16px rgba(234, 170, 0, 0.08));
    }

    .plugin-card-name {
      font-size: var(--text-card-title, 1.1rem);
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.5rem;
    }

    .plugin-card-desc {
      font-size: var(--text-card-desc, 0.875rem);
      color: var(--text-2);
      line-height: var(--text-line-height, 1.5);
      margin-bottom: 0.75rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .plugin-card-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: var(--text-card-meta, 0.8rem);
      color: var(--text-3);
    }

    .plugin-card-category {
      text-transform: capitalize;
    }

    /* ── CTA Section ── */
    .cta-section {
      background: var(--surface-1);
      border: 2px solid var(--border);
      border-radius: var(--card-featured-radius, 16px);
      padding: var(--card-featured-padding, 2rem);
      text-align: center;
      margin-bottom: 3rem;
    }

    .cta-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 1rem;
    }

    .cta-text {
      color: var(--text-2);
      max-width: 600px;
      margin: 0 auto 1.5rem;
      line-height: 1.6;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: var(--radius-md, 8px);
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      transition: all var(--duration-fast) var(--ease-out);
    }

    .cta-btn-primary {
      background: var(--gold);
      color: var(--navy);
    }

    .cta-btn-primary:hover {
      filter: brightness(1.1);
    }

    .cta-btn-secondary {
      background: var(--surface-2);
      color: var(--text);
      border: 1px solid var(--border);
    }

    .cta-btn-secondary:hover {
      border-color: var(--gold);
    }

    /* ── Hall of Fame ── */
    .hof-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
      margin-bottom: 2rem;
    }

    .hof-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: border-color 0.2s ease, transform 0.2s ease;
      position: relative;
      overflow: hidden;
    }

    .hof-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, var(--gold) 0%, oklch(75% 0.15 85) 100%);
    }

    .hof-card:hover {
      border-color: var(--gold);
      transform: translateY(-2px);
    }

    .hof-top {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .hof-grade {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      background: var(--gold);
      color: var(--navy);
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      border-radius: 6px;
    }

    .hof-week {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-3);
    }

    .hof-category {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-2);
      background: var(--surface-2);
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      margin-left: auto;
    }

    .hof-headline {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
      margin: 0;
    }

    .hof-description {
      font-size: 0.85rem;
      line-height: 1.55;
      color: var(--text-2);
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .hof-quote {
      margin: 0;
      padding: 0.6rem 0.85rem;
      border-left: 3px solid var(--primary);
      background: var(--primary-tint);
      border-radius: 0 8px 8px 0;
      font-style: italic;
      font-size: 0.8rem;
      line-height: 1.5;
      color: var(--text-2);
    }

    .hof-author {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: var(--text-2);
    }

    .hof-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
    }

    .hof-author-link {
      color: var(--text-2);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .hof-author-link:hover {
      color: var(--primary);
    }

    .hof-skills {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: var(--gold);
      margin-left: auto;
    }

    .hof-link {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--gold);
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .community-hero { padding: 2.5rem 1rem 1.5rem; }
      .hero-stats-row { gap: 0.75rem; flex-wrap: wrap; }
      .hero-stat { padding: 0.5rem 0.75rem; flex: 1; min-width: 80px; }
      .hero-stat span { font-size: 1.1rem; }
      .section-container { padding: 2rem 1rem; }
      .contributors-grid { grid-template-columns: 1fr; }
      .contributor-card { padding: 1rem 1.25rem; }
      .contributor-name { font-size: 1rem; }
      .contributor-summary { font-size: 0.8rem; }
      .plugins-grid { grid-template-columns: 1fr; }
      .hof-grid { grid-template-columns: 1fr; }
    }
  </style>

  <!-- Hero Section -->
  <section class="community-hero">
    <h1 class="community-title">Community Contributors</h1>
    <p class="community-subtitle">
      {communityPlugins.length} plugins from {contributors.length} contributors
    </p>

    <div class="hero-stats-row">
      <div class="hero-stat">
        <span>{contributors.length}</span>
        Authors
      </div>
      <div class="hero-stat">
        <span>{communityPlugins.length}</span>
        Community
      </div>
      <div class="hero-stat">
        <span>{officialPlugins.length}+</span>
        Official
      </div>
    </div>
  </section>

  {hallOfFame.length > 0 && (
    <div class="section-container" style="padding-bottom: 0;">
      <h2 class="section-heading">Hall of Fame</h2>
      <p style="text-align: center; color: var(--text-2); margin: -1rem auto 2rem; max-width: 550px; font-size: 0.95rem;">Past Killer Skill of the Week spotlights — the best work from the community.</p>
      <div class="hof-grid">
        {hallOfFame.map(item => {
          const isExternal = item.link.startsWith('http');
          return (
            <a href={item.link} class="hof-card" target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
              <div class="hof-top">
                <span class="hof-grade">{item.grade}</span>
                <span class="hof-week">{item.week}</span>
                <span class="hof-category">{item.category}</span>
              </div>
              <h3 class="hof-headline">{item.headline}</h3>
              {item.whyKiller && <p class="hof-description">{item.whyKiller}</p>}
              {item.quote && <blockquote class="hof-quote">{item.quote}</blockquote>}
              <div class="hof-author">
                <img src={`https://github.com/${item.authorGithub}.png?size=64`} alt={item.author} class="hof-avatar" width="32" height="32" loading="lazy" />
                <a href={`https://github.com/${item.authorGithub}`} class="hof-author-link" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation();">{item.author}</a>
                {item.skillCount && <span class="hof-skills">{item.skillCount} skills</span>}
              </div>
              <span class="hof-link">{isExternal ? 'View on GitHub →' : 'View plugin →'}</span>
            </a>
          );
        })}
      </div>
    </div>
  )}

  <!-- Contributors Section -->
  <div class="section-container">
    <h2 class="section-heading">Contributors</h2>
    <div class="contributors-grid">
      {contributors.map(contrib => (
        <div
          class="contributor-card"
          role="button"
          tabindex="0"
          aria-expanded="false"
          aria-label={`${contrib.name}, ${contrib.plugins.length} plugins`}
        >
          <div class="contributor-header">
            <div class="contributor-info">
              <div class="contributor-name">{contrib.name}</div>
              <div class="contributor-summary">{getContributionSummary(contrib.plugins)}</div>
            </div>
            <div class="contributor-count">
              {contrib.plugins.length} plugin{contrib.plugins.length !== 1 ? 's' : ''}
            </div>
            <span class="toggle-chevron" aria-hidden="true">&#9656;</span>
          </div>
          <div class="contributor-detail">
            <div class="contributor-plugin-list">
              {contrib.plugins.map(p => (
                <a href={`/plugins/${p.name}/`} class="contributor-plugin-row">
                  <div class="plugin-row-info">
                    <div class="plugin-row-name">{p.displayName || p.name}</div>
                    <div class="plugin-row-desc">{p.description}</div>
                  </div>
                  <span class="plugin-row-arrow" aria-hidden="true">&#8594;</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Community Plugins Grid -->
    <h2 class="section-heading">Community Plugins</h2>
    <div class="plugins-grid">
      {communityPlugins.map(plugin => (
        <a href={`/plugins/${plugin.name}/`} class="plugin-card">
          <div class="plugin-card-name">{plugin.displayName || plugin.name}</div>
          <p class="plugin-card-desc">{plugin.description}</p>
          <div class="plugin-card-meta">
            <span class="plugin-card-category">{plugin.category?.replace(/-/g, ' ')}</span>
            <span>{plugin.author?.name || 'Community'}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="cta-section">
      <h2 class="cta-title">Submit Your Plugin</h2>
      <p class="cta-text">
        Built something useful? Share it with the community. Every plugin goes through quality validation and gets listed in the marketplace.
      </p>
      <div class="cta-buttons">
        <a href="https://github.com/jeremylongshore/claude-code-plugins/pulls" class="cta-btn cta-btn-primary" target="_blank">
          Open a Pull Request
        </a>
        <a href="/getting-started" class="cta-btn cta-btn-secondary">
          Read the Guide
        </a>
      </div>
    </div>
  </div>

  <!-- Expand/Collapse Script -->
  <script is:inline>
    document.querySelectorAll('.contributor-card').forEach(function(card) {
      function toggle(e) {
        // Don't toggle when clicking plugin links
        if (e.target.closest('a')) return;

        var expanded = card.classList.contains('expanded');
        card.classList.toggle('expanded', !expanded);
        card.setAttribute('aria-expanded', String(!expanded));
      }

      card.addEventListener('click', toggle);
      card.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggle(e);
        }
      });
    });
  </script>
</BaseLayout>
