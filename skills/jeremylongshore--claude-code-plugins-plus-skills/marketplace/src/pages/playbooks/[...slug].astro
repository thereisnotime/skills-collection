---
import PlaybookTemplate from '../../components/PlaybookTemplate.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const playbooks = await getCollection('playbooks');
  return playbooks.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, category, wordCount } = entry.data;
---

<PlaybookTemplate title={title} description={description} category={category} wordCount={wordCount} slug={entry.id}>
  <Content />
</PlaybookTemplate>
