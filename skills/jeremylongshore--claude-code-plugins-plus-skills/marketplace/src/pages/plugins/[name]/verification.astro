---
import { readFileSync } from 'fs';
import { join } from 'path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import jrigData from '../../../data/jrig-data.json';

export async function getStaticPaths() {
  const catalogPath = join(process.cwd(), '../.claude-plugin/marketplace.extended.json');
  const catalog = JSON.parse(readFileSync(catalogPath, 'utf-8'));

  return catalog.plugins.map((plugin: any) => ({
    params: { name: plugin.name },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;
const jrig = jrigData[plugin.name] ?? null;

const title = `${plugin.name} — JRig Verification | Tons of Skills`;
const description = jrig?.verified
  ? `${plugin.name} passed all ${jrig.layers_passed ?? 7} JRig behavioral evaluation layers across Haiku, Sonnet, and Opus. Last verified ${jrig.verified_at ?? 'recently'}.`
  : `${plugin.name} hasn't yet completed JRig 7-layer behavioral evaluation. Verification status will appear here once a forge or eval run posts results.`;

// 7-layer eval framework — for description, not real per-plugin data.
// Real per-layer pass/fail data lives in JRig's own SQLite (separate
// from forge_proofs); this page intentionally summarizes the framework
// rather than per-skill detail until JRig's report API is wired in.
const layers = [
  { num: 1, name: 'Package Integrity', focus: 'Does it parse, validate, and reference real files?' },
  { num: 2, name: 'Trigger Quality', focus: 'Does it fire on the right prompts and stay silent on the wrong ones?' },
  { num: 3, name: 'Functional Quality', focus: 'Does it complete its task and produce correct artifacts?' },
  { num: 4, name: 'Regression Protection', focus: 'Did this change break anything that previously worked?' },
  { num: 5, name: 'Baseline Value', focus: 'Does the skill actually outperform the naked model?' },
  { num: 6, name: 'Model Variance', focus: 'Does it work across Haiku, Sonnet, and Opus?' },
  { num: 7, name: 'Rollout Safety', focus: 'Any prompt leakage, overreach, or unsafe automation?' },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": title,
      "description": description,
      "about": { "@type": "SoftwareApplication", "name": plugin.name },
    })} />
  </Fragment>

  <div class="page">
    <div class="container">
      <Breadcrumbs crumbs={[
        { label: plugin.category.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()), href: `/explore?category=${plugin.category}` },
        { label: plugin.name, href: `/plugins/${plugin.name}` },
        { label: 'Verification' },
      ]} />

      <header class="header">
        <h1>JRig Verification — <code>{plugin.name}</code></h1>
        {jrig?.verified ? (
          <div class="status verified">
            <span class="status-dot" aria-hidden="true"></span>
            <strong>JRig-Verified</strong>
            <span class="status-detail">{jrig.layers_passed ?? '?'}/{jrig.total_layers ?? 7} layers passed</span>
            {jrig.baseline_delta != null && (
              <span class="status-detail">{Number(jrig.baseline_delta) > 0 ? '+' : ''}{(Number(jrig.baseline_delta) * 100).toFixed(1)}% vs. naked Claude</span>
            )}
          </div>
        ) : (
          <div class="status unverified">
            <span class="status-dot" aria-hidden="true"></span>
            <strong>Not yet evaluated</strong>
            <span class="status-detail">No JRig run on record for this plugin yet</span>
          </div>
        )}
      </header>

      <section class="layers">
        <h2>The 7 layers</h2>
        <p class="lede">JRig evaluates each plugin against seven binary criteria. To pass, every layer must clear the threshold across all three models in the matrix (Haiku, Sonnet, Opus). This is what the JRig-Verified badge represents.</p>
        <ol class="layer-list">
          {layers.map((layer) => (
            <li class="layer">
              <span class="layer-num">L{layer.num}</span>
              <div class="layer-body">
                <span class="layer-name">{layer.name}</span>
                <span class="layer-focus">{layer.focus}</span>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <section class="meta">
        <h2>What this verification means</h2>
        <p>JRig is the Intent Solutions binary evaluation harness. It runs deterministic checks (Layer 1 package integrity), behavioral checks against expected outcomes (Layers 2–4), comparative checks against the naked model (Layer 5), cross-model checks (Layer 6), and safety checks (Layer 7).</p>
        <p>A passing verdict isn't a one-shot test — it's a regression-protected suite. Re-runs against new model releases or skill changes detect drift in either direction.</p>

        {jrig?.verified ? (
          <div class="evidence">
            <h3>This plugin's evidence</h3>
            <dl>
              <dt>Layers passed</dt>
              <dd>{jrig.layers_passed ?? '?'} / {jrig.total_layers ?? 7}</dd>
              {jrig.baseline_delta != null && (
                <>
                  <dt>Baseline delta</dt>
                  <dd>{Number(jrig.baseline_delta) > 0 ? '+' : ''}{(Number(jrig.baseline_delta) * 100).toFixed(1)}% vs. naked Claude on the same prompts</dd>
                </>
              )}
              {jrig.verified_at && (
                <>
                  <dt>Verified at</dt>
                  <dd>{new Date(jrig.verified_at).toISOString().slice(0, 10)}</dd>
                </>
              )}
            </dl>
          </div>
        ) : (
          <div class="evidence pending">
            <h3>Why this plugin isn't verified yet</h3>
            <p>JRig verification is opt-in and runs through one of two paths:</p>
            <ol>
              <li><strong>Forge generation</strong>: plugins produced by <code>/skill-creator --forge</code> run JRig as the final gate. The Tier 3 verdict is written to <code>forge_proofs</code> automatically.</li>
              <li><strong>Manual eval</strong>: maintainers can run <code>j-rig eval &lt;skill-dir&gt; --models haiku,sonnet,opus --db freshie/inventory.sqlite</code> to post results.</li>
            </ol>
            <p>Until one of those paths fires, the plugin's grade and Tier 2 production-gate results are still authoritative — JRig adds behavioral verification on top.</p>
          </div>
        )}
      </section>

      <section class="back">
        <a href={`/plugins/${plugin.name}`} class="back-link">← Back to {plugin.name}</a>
      </section>
    </div>
  </div>

  <style>
    .page {
      padding: 3rem 2rem;
      background: var(--bg, var(--surface));
      min-height: 60vh;
    }
    .container {
      max-width: 880px;
      margin: 0 auto;
    }
    .header {
      margin: 1.5rem 0 2.5rem;
      border-bottom: 1px solid var(--rule, var(--border));
      padding-bottom: 1.5rem;
    }
    h1 {
      font-family: 'Inter Tight', system-ui, sans-serif;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
    }
    h1 code {
      background: var(--panel, var(--surface-2));
      padding: 0.1em 0.4em;
      border-radius: 6px;
      font-size: 0.85em;
      color: var(--ink, var(--text));
    }
    .status {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
      font-size: 0.95rem;
    }
    .status strong {
      font-size: 1rem;
    }
    .status-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .status.verified .status-dot { background: rgb(34, 197, 94); box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2); }
    .status.unverified .status-dot { background: var(--ink-2, var(--text-2)); opacity: 0.5; }
    .status.verified strong { color: rgb(22, 163, 74); }
    .status.unverified strong { color: var(--ink-2, var(--text-2)); }
    .status-detail {
      color: var(--ink-2, var(--text-2));
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
    }
    .layers, .meta {
      margin: 2.5rem 0;
    }
    h2 {
      font-family: 'Inter Tight', system-ui, sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      margin: 0 0 0.75rem;
    }
    .lede {
      color: var(--ink-2, var(--text-2));
      max-width: 65ch;
      line-height: 1.55;
      margin: 0 0 1.5rem;
    }
    .layer-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.75rem;
    }
    .layer {
      display: flex;
      gap: 0.75rem;
      align-items: baseline;
      padding: 0.85rem 1rem;
      background: var(--panel, var(--surface-2));
      border: 1px solid var(--rule, var(--border));
      border-radius: 8px;
    }
    .layer-num {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--signal, var(--accent));
      flex-shrink: 0;
    }
    .layer-body {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .layer-name {
      font-weight: 600;
      color: var(--ink, var(--text));
    }
    .layer-focus {
      color: var(--ink-2, var(--text-2));
      font-size: 0.88rem;
      line-height: 1.45;
    }
    .meta p {
      color: var(--ink, var(--text));
      max-width: 65ch;
      line-height: 1.6;
    }
    .meta p + p { margin-top: 0.85rem; }
    .evidence {
      margin-top: 1.5rem;
      padding: 1.25rem 1.5rem;
      background: var(--panel, var(--surface-2));
      border: 1px solid var(--rule, var(--border));
      border-radius: 8px;
    }
    .evidence h3 {
      margin: 0 0 0.85rem;
      font-size: 1.05rem;
    }
    .evidence dl {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: 0.5rem 1.5rem;
      margin: 0;
    }
    .evidence dt {
      color: var(--ink-2, var(--text-2));
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    .evidence dd {
      margin: 0;
      color: var(--ink, var(--text));
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.92rem;
    }
    .evidence.pending ol {
      padding-left: 1.25rem;
    }
    .evidence.pending li {
      margin: 0.4rem 0;
      color: var(--ink, var(--text));
      line-height: 1.55;
    }
    .evidence code {
      background: var(--bg, var(--surface));
      padding: 0.1em 0.4em;
      border-radius: 4px;
      font-size: 0.85em;
    }
    .back {
      margin: 3rem 0 1rem;
    }
    .back-link {
      color: var(--signal, var(--accent));
      text-decoration: none;
      font-weight: 600;
    }
    .back-link:hover { text-decoration: underline; }
  </style>
</BaseLayout>
