---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = `${post.data.title} — Tons of Skills Changelog`;
const description = post.data.description;
const dateFormatted = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": description,
      "datePublished": post.data.date,
      "url": `https://tonsofskills.com/changelog/${post.slug}`,
      "author": { "@type": "Person", "name": "Jeremy Longshore" },
      "publisher": { "@type": "Organization", "name": "Claude Code Plugins", "url": "https://tonsofskills.com" }
    })} />
  </Fragment>

  <article class="post">
    <header class="post-header">
      <div class="post-header-inner">
        <a href="/changelog" class="back-link">Back to Changelog</a>
        <div class="post-meta">
          <time datetime={post.data.date}>{dateFormatted}</time>
          {post.data.version && <span class="version-badge">v{post.data.version}</span>}
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <div class="post-body">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    background: linear-gradient(180deg, var(--surface) 0%, var(--surface-1) 100%);
    padding: 4rem 1.5rem 3rem;
    border-bottom: 1px solid var(--border);
  }
  .post-header-inner {
    max-width: 48rem;
    margin: 0 auto;
  }
  .back-link {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-3);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--gold); }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  time {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-3);
  }
  .version-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: rgba(234, 170, 0, 0.12);
    color: var(--gold);
    border-radius: 4px;
  }
  .post-header h1 {
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
    margin-bottom: 0.75rem;
    letter-spacing: 0;
  }
  .post-desc {
    color: var(--text-2);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: var(--surface-3);
    color: var(--text-3);
    border-radius: 4px;
  }

  .post-body {
    padding: 3rem 1.5rem 4rem;
  }
  .prose {
    max-width: 48rem;
    margin: 0 auto;
    color: var(--text-2);
    line-height: 1.8;
    font-size: 1rem;
  }
  .prose :global(h2) {
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin: 2.5rem 0 1rem;
    letter-spacing: 0;
  }
  .prose :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }
  .prose :global(p) {
    margin-bottom: 1rem;
  }
  .prose :global(ul), .prose :global(ol) {
    margin: 0.5rem 0 1rem 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.35rem;
  }
  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .prose :global(code) {
    font-family: 'DM Mono', monospace;
    font-size: 0.88em;
    background: var(--surface-3);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    color: var(--gold);
  }
  .prose :global(a) {
    color: var(--gold);
    text-decoration: none;
  }
  .prose :global(a:hover) {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .post-header { padding: 3rem 1rem 2rem; }
    .post-body { padding: 2rem 1rem 3rem; }
  }
</style>
