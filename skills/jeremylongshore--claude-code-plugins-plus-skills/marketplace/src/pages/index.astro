---
// Claude Code Plugins Marketplace - Homepage
import BaseLayout from '../layouts/BaseLayout.astro';
import StackBuilder from '../components/StackBuilder.astro';
import CollectionsGrid from '../components/CollectionsGrid.astro';
import CoworkGrid from '../components/CoworkGrid.astro';
import KillerSkills from '../components/KillerSkills.astro';
import JeremysStash from '../components/JeremysStash.astro';
import searchIndex from '../data/unified-search-index.json';

// Dynamic stats from search index (updated at build time)
const totalSkills = searchIndex.stats.totalSkills;
const totalPlugins = searchIndex.stats.totalPlugins;
const totalCategories = searchIndex.stats.categories.length;
const totalAgents = searchIndex.stats.totalAgents || 0;
const totalHooks = searchIndex.stats.totalHooks || 0;

// npm download stats (refreshed daily by .github/workflows/update-npm-stats.yml)
// Falls back to empty shape so the first build before the cron runs doesn't fail.
let npmStats: {
  publishedCount?: number;
  totalDay?: number;
  totalWeek?: number;
  totalMonth?: number;
  top?: Array<{ name: string; lastMonth: number }>;
} = {};
try {
  npmStats = (await import('../data/npm-stats.json')).default as typeof npmStats;
} catch {
  npmStats = {};
}
const npmPublished = npmStats.publishedCount ?? 0;
const npmMonth = npmStats.totalMonth ?? 0;
const npmTop = (npmStats.top ?? []).slice(0, 8);
const fmtNum = (n: number) => n.toLocaleString('en-US');
---

<BaseLayout
    title="Claude Code Skills Hub | Plugins & Agent Skills"
    description={`Search ${totalSkills} skills with fuzzy search and filters. Learn with interactive tutorials. All open source and production-ready.`}
>
    <script type="application/ld+json" slot="head" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Claude Code Skills Hub",
        "url": "https://tonsofskills.com",
        "description": "The largest open-source marketplace for Claude Code plugins and agent skills",
        "sameAs": ["https://github.com/jeremylongshore/claude-code-plugins-plus-skills"]
    })} />
    <style>
        /* ========================================
           HOMEPAGE-SPECIFIC STYLES
           ======================================== */

        /* Prevent horizontal scroll on mobile */
        html, body {
            overflow-x: hidden;
            max-width: 100%;
            width: 100%;
        }

        /* Ensure all sections respect viewport width */
        section {
            max-width: 100vw;
            overflow-x: hidden;
        }

        /* ========================================
           HERO — minimal, centered, dark
           ======================================== */
        .hero {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            text-align: left;
            padding: 5rem 3rem 2rem;
            position: relative;
            max-width: 1200px;
            margin: 0 auto;
        }

        .hero-inner {
            width: 100%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
        }

        /* H1 — Instrument Sans, large, split color */
        .hero h1 {
            font-family: 'Instrument Sans', system-ui, sans-serif;
            font-size: var(--text-4xl);
            font-weight: 700;
            line-height: 0.95;
            letter-spacing: -0.04em;
            margin: 0 0 1.5rem;
            color: var(--primary);
            animation: fadeInUp 0.7s var(--ease-out) forwards;
            opacity: 0;
        }

        .hero-text-muted { color: var(--text); }
        .hero-text-primary { color: var(--primary); }

        .hero-byline {
            font-family: 'DM Mono', monospace;
            font-size: 0.7rem;
            color: var(--text-3);
            margin: -1rem 0 1.5rem;
            letter-spacing: 0.02em;
            animation: fadeInUp 0.7s var(--ease-out) 0.05s forwards;
            opacity: 0;
        }
        .hero-byline a {
            color: var(--text-3);
            text-decoration: none;
            border-bottom: 1px dotted var(--border);
            transition: color 0.2s, border-color 0.2s;
        }
        .hero-byline a:hover {
            color: var(--primary);
            border-color: var(--primary);
        }

        .hero-sponsor-marquee {
            margin-top: 0.5rem;
            overflow: hidden;
            max-width: 400px;
            animation: fadeInUp 0.7s var(--ease-out) 0.1s forwards;
            opacity: 0;
        }
        .hero-sponsor-label {
            font-family: 'DM Mono', monospace;
            font-size: 0.55rem;
            color: var(--text-3);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 0.35rem;
        }
        .hero-sponsor-track {
            display: flex;
            gap: 3rem;
            animation: sponsorScroll 18s linear infinite;
        }
        .hero-sponsor-link {
            flex-shrink: 0;
            color: var(--text-2);
            text-decoration: none;
            transition: color 0.2s;
            display: flex;
            align-items: center;
            opacity: 0.6;
        }
        .hero-sponsor-link:hover {
            color: var(--primary);
            opacity: 1;
        }
        /* Stats marquee (second row, under partners) — runs slightly slower
           so the longer text strings stay readable. */
        .hero-stats-marquee {
            margin-top: 0.35rem;
            max-width: 520px;
        }
        .hero-stats-marquee .hero-sponsor-track {
            animation-duration: 28s;
        }
        .hero-stats-link .hero-sponsor-text {
            font-family: 'DM Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.01em;
        }
        .hero-sponsor-text {
            font-family: 'Source Sans 3', system-ui, sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
        }
        @keyframes sponsorScroll {
            from { transform: translateX(0); }
            to { transform: translateX(-50%); }
        }

        /* Spotlight eyebrow pill */
        .spotlight-badge {
            display: inline-block;
            font-family: 'DM Mono', monospace;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--primary);
            background: var(--primary-tint);
            border: 1px solid var(--primary-tint-border);
            padding: 0.35rem 0.75rem;
            border-radius: 9999px;
            margin-bottom: 1rem;
        }

        /* Subtitle */
        .hero-subtitle {
            font-family: 'Source Sans 3', system-ui, sans-serif;
            font-size: var(--text-lg);
            color: var(--text-2);
            max-width: 500px;
            margin: 0 0 2.5rem;
            line-height: 1.6;
            animation: fadeInUp 0.7s var(--ease-out) 0.1s forwards;
            opacity: 0;
        }

        .hero-cowork-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.5rem 1.25rem;
            border: 1px solid var(--primary-border);
            border-radius: 8px;
            color: var(--primary);
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            margin-bottom: 1.25rem;
            transition: background var(--duration-fast), border-color var(--duration-fast);
            animation: fadeInUp 0.7s var(--ease-out) 0.15s forwards;
            opacity: 0;
        }
        .hero-cowork-btn:hover {
            background: var(--primary-tint);
            border-color: var(--primary);
        }

        /* Search */
        .hero-search {
            width: 100%;
            max-width: 640px;
            margin: 0 0 2.5rem;
            position: relative;
            animation: fadeInUp 0.7s var(--ease-out) 0.2s forwards;
            opacity: 0;
        }

        .search-container {
            position: relative;
            background: var(--surface-2);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            transition: border-color 0.2s ease;
            cursor: pointer;
        }

        .search-container:hover {
            border-color: var(--gold);
        }

        .search-container:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px oklch(62% 0.16 35 / 0.12);
        }

        .search-icon {
            position: absolute;
            left: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-3);
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            padding: 1.15rem 3rem 1.15rem 3.5rem;
            border: none;
            background: transparent;
            font-size: 1rem;
            font-family: 'Source Sans 3', system-ui, sans-serif;
            color: var(--text);
            outline: none;
        }

        /* Adjust padding on larger screens where toggle buttons fit */
        @media (min-width: 640px) {
            .search-input {
                padding-right: 15rem;
            }
        }

        .search-input::placeholder {
            color: var(--text-3);
        }

        .search-toggle {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            display: none;
            gap: 0.5rem;
            background: var(--surface-3);
            padding: 0.25rem;
            border-radius: 8px;
            z-index: 10;
            pointer-events: auto;
        }

        @media (min-width: 640px) {
            .search-toggle {
                display: flex;
            }
        }

        .toggle-btn {
            padding: 0.5rem 1rem;
            border: none;
            background: transparent;
            color: var(--text-3);
            font-family: 'Source Sans 3', system-ui, sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .toggle-btn:hover {
            color: var(--text);
        }

        .toggle-btn.active {
            background: var(--surface-1);
            color: var(--gold);
        }

        .search-results {
            position: absolute;
            top: calc(100% + 0.5rem);
            left: 0;
            right: 0;
            background: var(--surface-2);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
            max-height: 400px;
            overflow-y: auto;
            z-index: 100;
        }

        .search-results.hidden {
            display: none;
        }

        .search-result-item {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            transition: background 0.15s ease;
            text-decoration: none;
            display: block;
            color: inherit;
        }

        .search-result-item:last-child {
            border-bottom: none;
        }

        .search-result-item:hover {
            background: var(--surface-3);
        }

        .result-type-badge {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
            font-family: 'DM Mono', monospace;
            letter-spacing: 0.05em;
        }

        .result-type-badge.plugin {
            background: rgba(68, 147, 248, 0.15);
            color: var(--brand-blue);
        }

        .result-type-badge.skill {
            background: rgba(234, 170, 0, 0.15);
            color: var(--gold);
        }

        .result-name {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text);
            margin: 0.25rem 0;
        }

        .result-description {
            font-size: 0.875rem;
            color: var(--text-2);
            margin: 0.25rem 0;
            line-height: 1.4;
        }

        .result-plugin-info {
            font-size: 0.8125rem;
            color: var(--brand-blue);
            margin-top: 0.5rem;
        }

        /* Install box */
        .install-box {
            width: 100%;
            max-width: 650px;
            padding: 1.5rem;
            background: var(--surface-2);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
            opacity: 0;
        }

        .install-label {
            font-family: 'DM Mono', monospace;
            color: var(--text-3);
            font-size: 0.75rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.5rem;
        }

        .install-command {
            font-family: 'DM Mono', 'SF Mono', 'Fira Code', monospace;
            color: var(--text);
            font-size: 0.95rem;
            user-select: all;
            cursor: pointer;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ========================================
           FEATURES SECTION
           ======================================== */
        .features {
            padding: 3rem 2rem;
            background: var(--surface);
        }

        .section-label {
            font-family: 'DM Mono', monospace;
            color: var(--primary);
            font-size: 0.75rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .section-title {
            font-size: clamp(1.8rem, 3vw, 2.5rem);
            font-weight: 600;
            letter-spacing: -0.02em;
            margin-bottom: 2rem;
            max-width: 700px;
            line-height: 1.2;
            color: var(--text);
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .feature-card {
            padding: 2rem;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 14px;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
            text-align: center;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--primary);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform var(--duration-normal) var(--ease-out);
        }

        .feature-card:hover {
            transform: translateY(-6px);
            border-color: var(--border-bright);
            box-shadow: 0 16px 48px rgba(234, 170, 0, 0.08);
        }

        .feature-card:hover::before {
            transform: scaleX(1);
        }

        .feature-icon {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            background: oklch(62% 0.16 35 / 0.1);
            border-radius: 10px;
            margin-left: auto;
            margin-right: auto;
        }

        .feature-card h3 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--text);
        }

        .feature-card p {
            color: var(--text-2);
            line-height: 1.7;
            margin: 0;
        }

        /* Client showcase removed — sponsor now inline in hero */

        /* ========================================
           SAAS SKILL PACKS SECTION
           ======================================== */
        .saas-packs-section {
            padding: 3rem 2rem;
            background: var(--surface);
        }

        .saas-packs-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .saas-packs-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .saas-badge {
            background: oklch(62% 0.16 35 / 0.12);
            color: var(--primary);
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
            font-family: 'DM Mono', monospace;
        }

        .saas-title {
            color: var(--text);
            font-size: clamp(2rem, 4vw, 2.8rem);
            margin: 1rem 0 0.5rem;
            font-weight: 700;
        }

        .saas-subtitle {
            color: var(--text-2);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

        .saas-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .saas-card {
            background: var(--surface-1);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .saas-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
        }

        .saas-card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .saas-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .saas-card h3 {
            color: var(--text);
            margin: 0;
            font-size: 1.2rem;
        }

        .saas-tier {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--gold);
            font-family: 'DM Mono', monospace;
        }

        .saas-desc {
            color: var(--text-2);
            font-size: 0.9rem;
            margin-bottom: 1rem;
            line-height: 1.5;
        }

        .saas-commands {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .saas-cmd {
            background: var(--surface-2);
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            font-size: 0.8rem;
            color: var(--text-2);
            cursor: pointer;
            transition: background 0.2s;
            border: none;
            font-family: 'DM Mono', monospace;
            text-align: left;
        }

        .saas-cmd:hover {
            background: var(--surface-3);
        }

        .saas-cmd.primary {
            background: rgba(234, 170, 0, 0.1);
            color: var(--gold);
            border: 1px solid rgba(234, 170, 0, 0.2);
        }

        .saas-cmd.primary:hover {
            background: rgba(234, 170, 0, 0.18);
        }

        .saas-card.coming-soon {
            background: var(--surface-3);
            border: 1px dashed var(--border);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .coming-soon-icon {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
        }

        .saas-card.coming-soon h3 {
            color: var(--text);
            margin: 0 0 0.5rem;
            font-size: 1.1rem;
        }

        .saas-card.coming-soon p {
            color: var(--text-3);
            font-size: 0.85rem;
            margin: 0;
        }

        .saas-cta {
            text-align: center;
        }

        .saas-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: white;
            color: #8B0A2D;
            padding: 0.875rem 1.75rem;
            border-radius: 8px;
            font-weight: 700;
            text-decoration: none;
            font-size: 1rem;
            font-family: 'Source Sans 3', system-ui, sans-serif;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .saas-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }

        @media (max-width: 768px) {
            .saas-packs-section {
                padding: 3rem 1.5rem;
            }

            .saas-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ========================================
           COWORK DOWNLOADS SECTION (Homepage)
           ======================================== */
        .cowork-home-section {
            padding: 3rem 2rem;
            background: var(--surface-2);
        }

        .cowork-home-container {
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .cowork-home-badge {
            background: oklch(72% 0.18 160 / 0.12);
            color: var(--accent);
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
            font-family: 'DM Mono', monospace;
        }

        .cowork-home-title {
            color: var(--text);
            font-size: clamp(2rem, 4vw, 2.8rem);
            margin: 1rem 0 0.5rem;
            font-weight: 700;
        }

        .cowork-home-subtitle {
            color: var(--text-2);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto 2.5rem;
        }

        .cowork-home-cta {
            text-align: center;
            margin-top: 2.5rem;
        }

        .cowork-home-button {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            background: var(--accent);
            color: var(--surface);
            padding: 1rem 2.5rem;
            border-radius: 10px;
            font-weight: 700;
            text-decoration: none;
            font-size: 1.1rem;
            font-family: 'Source Sans 3', system-ui, sans-serif;
            transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
        }

        .cowork-home-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
            color: var(--surface);
        }

        @media (max-width: 768px) {
            .cowork-home-section {
                padding: 3rem 1.5rem;
            }
        }

        /* ========================================
           EMAIL SIGNUP SECTION
           ======================================== */
        .signup-section {
            padding: 3rem 2rem;
            background: var(--surface);
        }

        .signup-inner {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }

        .signup-title {
            margin-left: auto;
            margin-right: auto;
        }

        .signup-desc {
            color: var(--text-2);
            margin-bottom: 2rem;
            font-size: 1rem;
            line-height: 1.6;
        }

        .signup-form {
            display: flex;
            gap: 0.75rem;
            max-width: 480px;
            margin: 0 auto;
        }

        .signup-form input {
            flex: 1;
            padding: 0.75rem 1rem;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.95rem;
            font-family: 'Source Sans 3', system-ui, sans-serif;
            outline: none;
            transition: border-color 0.2s;
        }

        .signup-form input:focus {
            border-color: var(--gold);
        }

        .signup-form button {
            padding: 0.75rem 1.5rem;
            background: var(--gold);
            color: var(--navy, #0C2340);
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            font-family: 'Source Sans 3', system-ui, sans-serif;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .signup-form button:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(234, 170, 0, 0.3);
        }

        .signup-note {
            margin-top: 1rem;
            font-size: 0.75rem;
            color: var(--text-3);
            font-family: 'DM Mono', monospace;
        }

        /* ========================================
           PRODUCTS & SERVICES SECTION
           ======================================== */
        .products-section {
            padding: 3rem 2rem;
            background: var(--surface);
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            max-width: 1100px;
            margin: 3rem auto 0;
        }

        .product-card {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .product-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #f97316, #fb923c);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .product-card.service-card::before {
            background: linear-gradient(90deg, var(--positive), #4ade80);
        }

        .product-card:hover {
            border-color: rgba(249, 115, 22, 0.3);
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(249, 115, 22, 0.1);
        }

        .product-card.service-card:hover {
            border-color: rgba(63, 185, 80, 0.3);
            box-shadow: 0 12px 40px rgba(63, 185, 80, 0.1);
        }

        .product-card:hover::before {
            opacity: 1;
        }

        .product-card h3 {
            color: var(--text);
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .product-price {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .product-price .amount {
            font-size: 1.5rem;
            font-weight: 800;
            color: #f97316;
        }

        .service-card .product-price .amount {
            color: var(--positive);
        }

        .product-price .label {
            font-size: 0.75rem;
            color: var(--text-3);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            background: rgba(249, 115, 22, 0.15);
            padding: 2px 8px;
            border-radius: 4px;
            font-family: 'DM Mono', monospace;
        }

        .service-card .product-price .label {
            background: rgba(63, 185, 80, 0.15);
        }

        .product-features {
            list-style: none;
            padding: 0;
            margin: 1.25rem 0;
        }

        .product-features li {
            color: var(--text-2);
            font-size: 0.9rem;
            padding: 0.4rem 0;
            padding-left: 1.5rem;
            position: relative;
        }

        .product-features li::before {
            content: '\2713';
            position: absolute;
            left: 0;
            color: #f97316;
            font-weight: 700;
        }

        .service-card .product-features li::before {
            color: var(--positive);
        }

        .product-cta {
            display: block;
            width: 100%;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s ease;
            background: linear-gradient(135deg, #f97316, #ea580c);
            color: white;
        }

        .product-cta:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 20px rgba(249, 115, 22, 0.4);
        }

        .product-cta.service-cta {
            background: linear-gradient(135deg, var(--positive), #16a34a);
        }

        .product-cta.service-cta:hover {
            box-shadow: 0 4px 20px rgba(63, 185, 80, 0.4);
        }

        @media (max-width: 768px) {
            .products-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ========================================
           SCROLL REVEAL ANIMATIONS
           ======================================== */
        .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
        }

        .reveal.revealed {
            opacity: 1;
            transform: translateY(0);
        }

        .reveal-stagger > * {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
        }

        .reveal-stagger.revealed > *:nth-child(1) { transition-delay: 0ms; }
        .reveal-stagger.revealed > *:nth-child(2) { transition-delay: 80ms; }
        .reveal-stagger.revealed > *:nth-child(3) { transition-delay: 160ms; }
        .reveal-stagger.revealed > *:nth-child(4) { transition-delay: 240ms; }
        .reveal-stagger.revealed > *:nth-child(5) { transition-delay: 320ms; }
        .reveal-stagger.revealed > *:nth-child(6) { transition-delay: 400ms; }
        .reveal-stagger.revealed > *:nth-child(7) { transition-delay: 480ms; }
        .reveal-stagger.revealed > *:nth-child(8) { transition-delay: 560ms; }
        .reveal-stagger.revealed > *:nth-child(9) { transition-delay: 640ms; }

        .reveal-stagger.revealed > * {
            opacity: 1;
            transform: translateY(0);
        }

        /* ========================================
           MOBILE RESPONSIVE
           ======================================== */
        @media (max-width: 768px) {
