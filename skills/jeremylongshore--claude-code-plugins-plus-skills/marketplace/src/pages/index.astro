---
// Claude Code Plugins Marketplace - Homepage
import BaseLayout from '../layouts/BaseLayout.astro';
import StackBuilder from '../components/StackBuilder.astro';
import CollectionsGrid from '../components/CollectionsGrid.astro';
import CoworkGrid from '../components/CoworkGrid.astro';
import KillerSkills from '../components/KillerSkills.astro';
import JeremysStash from '../components/JeremysStash.astro';
import PartnerBar from '../components/PartnerBar.astro';
import PluginCard from '../components/PluginCard.astro';
import searchIndex from '../data/unified-search-index.json';
import heatCheck from '../data/heat-check.json';

// Dynamic stats from search index (updated at build time)
const totalSkills = searchIndex.stats.totalSkills;
const totalPlugins = searchIndex.stats.totalPlugins;
const totalCategories = searchIndex.stats.categories.length;
const totalAgents = searchIndex.stats.totalAgents || 0;
const totalHooks = searchIndex.stats.totalHooks || 0;

// npm download stats (refreshed daily by .github/workflows/update-npm-stats.yml)
// Falls back to empty shape so the first build before the cron runs doesn't fail.
let npmStats: {
  publishedCount?: number;
  totalDay?: number;
  totalWeek?: number;
  totalMonth?: number;
  top?: Array<{ name: string; lastMonth: number }>;
} = {};
try {
  npmStats = (await import('../data/npm-stats.json')).default as typeof npmStats;
} catch {
  npmStats = {};
}
const npmPublished = npmStats.publishedCount ?? 0;
const npmMonth = npmStats.totalMonth ?? 0;
const npmTop = (npmStats.top ?? []).slice(0, 8);
const fmtNum = (n: number) => n.toLocaleString('en-US');
---

<BaseLayout
    title="Claude Code Skills Hub | Plugins & Agent Skills"
    description={`Search ${totalSkills} skills with fuzzy search and filters. Learn with interactive tutorials. All open source and production-ready.`}
>
    <script type="application/ld+json" slot="head" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Claude Code Skills Hub",
        "url": "https://tonsofskills.com",
        "description": "The largest open-source marketplace for Claude Code plugins and agent skills",
        "sameAs": ["https://github.com/jeremylongshore/claude-code-plugins-plus-skills"]
    })} />
    <style>
        /* ========================================
           HOMEPAGE-SPECIFIC STYLES
           ======================================== */

        /* Prevent horizontal scroll on mobile */
        html, body {
            overflow-x: hidden;
            max-width: 100%;
            width: 100%;
        }

        /* Ensure all sections respect viewport width */
        section {
            max-width: 100vw;
            overflow-x: hidden;
        }

        /* ========================================
           HERO — two-column at ≥1024px, single-column below
           ======================================== */
        .hero {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            text-align: left;
            padding: 5rem 1.5rem 2rem;
            position: relative;
            max-width: 1280px;
            margin: 0 auto;
        }

        .hero-inner {
            width: 100%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
        }

        @media (min-width: 1024px) {
            .hero {
                display: grid;
                grid-template-columns: 58fr 42fr;
                column-gap: 4rem;
                align-items: start;
                padding: 5rem 2rem 2rem;
            }
            .hero-inner {
                grid-column: 1;
                max-width: none;
            }
            .hero-stat-block {
                grid-column: 2;
                align-self: center;
            }
        }

        /* Stat block — right column at ≥1024px, hidden below */
        .hero-stat-block {
            display: none;
        }
        @media (min-width: 1024px) {
            .hero-stat-block {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 1.5rem;
                width: 100%;
                animation: fadeInUp 0.7s var(--ease-out) 0.25s forwards;
                opacity: 0;
            }
        }
        .hero-stat-cell {
            border-top: 1px solid var(--rule);
            padding-top: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }
        .hero-stat-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: clamp(2rem, 3.5vw, 3rem);
            font-weight: 600;
            line-height: 1;
            color: var(--signal);
            letter-spacing: -0.02em;
        }
        :global([data-theme="light"]) .hero-stat-number {
            color: var(--signal-deep);
        }
        .hero-stat-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--ink-3);
        }

        /* H1 — Inter Tight, large, split color */
        .hero h1 {
            font-family: 'Inter Tight', system-ui, sans-serif;
            font-size: var(--text-4xl);
            font-weight: 700;
            line-height: 0.95;
            letter-spacing: -0.04em;
            margin: 0 0 1.5rem;
            color: var(--primary);
            animation: fadeInUp 0.7s var(--ease-out) forwards;
            opacity: 0;
        }

        .hero-text-muted { color: var(--text); }
        .hero-text-primary { color: var(--primary); }
        /* Explicit override: signal-deep on light bg keeps "SKILLS" legible
           (--primary already remaps to --signal-deep in tokens.css, but we
           pin it explicitly here so the H1 can't drift if --primary moves) */
        :global([data-theme="light"]) .hero-text-primary {
            color: var(--signal-deep);
        }

        .hero-byline {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: var(--text-3);
            margin: -1rem 0 1.5rem;
            letter-spacing: 0.02em;
            animation: fadeInUp 0.7s var(--ease-out) 0.05s forwards;
            opacity: 0;
        }
        .hero-byline a {
            color: var(--text-3);
            text-decoration: none;
            border-bottom: 1px dotted var(--border);
            transition: color 0.2s, border-color 0.2s;
        }
        .hero-byline a:hover {
            color: var(--primary);
            border-color: var(--primary);
        }
        /* Light-theme hover: yellow on white is illegible — fall back to ink */
        :global([data-theme="light"]) .hero-byline a:hover {
            color: var(--ink);
            border-color: var(--ink-3);
        }

        .hero-sponsor-marquee {
            margin-top: 0.5rem;
            overflow: hidden;
            max-width: 480px;
            animation: fadeInUp 0.7s var(--ease-out) 0.1s forwards;
            opacity: 0;
        }
        .hero-sponsor-label {
            display: block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.6rem;
            color: var(--text-3);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 0.55rem;
        }
        .hero-sponsor-track {
            display: flex;
            gap: 3rem;
            animation: sponsorScroll 11s linear infinite;
        }
        .hero-sponsor-link {
            flex-shrink: 0;
            color: var(--text-2);
            text-decoration: none;
            transition: color 0.2s;
            display: flex;
            align-items: center;
            opacity: 0.6;
        }
        .hero-sponsor-link:hover {
            color: var(--primary);
            opacity: 1;
        }
        /* Light-theme hover: ink, not yellow */
        :global([data-theme="light"]) .hero-sponsor-link:hover {
            color: var(--ink);
        }
        /* Stats marquee (second row, under partners). Visually separated from
           the partner marquee with a subtle divider + breathing room — they
           used to stack at margin-top: 0.35rem (~5.6px) which read as one
           jammed element. Speed bumped from 28s → 16s per design feedback;
           still slower than partners (11s) because the text strings are longer
           and need to stay readable. */
        .hero-stats-marquee {
            margin-top: 1.25rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
            max-width: 520px;
        }
        .hero-stats-marquee .hero-sponsor-track {
            animation-duration: 16s;
        }
        .hero-stats-link .hero-sponsor-text {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.01em;
        }
        .hero-sponsor-text {
            font-family: 'Inter', system-ui, sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
        }
        @keyframes sponsorScroll {
            from { transform: translateX(0); }
            to { transform: translateX(-50%); }
        }

        /* Spotlight eyebrow pill */
        /* Subtitle */
        .hero-subtitle {
            font-family: 'Inter', system-ui, sans-serif;
            font-size: var(--text-lg);
            color: var(--text-2);
            max-width: 500px;
            margin: 0 0 2.5rem;
            line-height: 1.6;
            animation: fadeInUp 0.7s var(--ease-out) 0.1s forwards;
            opacity: 0;
        }

        /* Demoted from yellow CTA box to inline tertiary note —
           sits below the search bar as a quiet pointer, not a competing
           call-to-action against the install box / spotlight card */
        .hero-cowork-note {
            font-family: 'Inter', system-ui, sans-serif;
            font-size: 0.8rem;
            color: var(--ink-3);
            margin: 0.75rem 0 1.5rem;
            animation: fadeInUp 0.7s var(--ease-out) 0.25s forwards;
            opacity: 0;
        }
        .hero-cowork-note a {
            color: var(--ink-link);
            text-decoration: underline;
            text-underline-offset: 2px;
        }
        .hero-cowork-note a:hover {
            color: var(--ink-link-hover);
        }

        /* Search */
        .hero-search {
            width: 100%;
            max-width: 640px;
            margin: 0 0 2.5rem;
            position: relative;
            animation: fadeInUp 0.7s var(--ease-out) 0.2s forwards;
            opacity: 0;
        }

        .search-container {
            position: relative;
            background: var(--surface-2);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            transition: border-color 0.2s ease;
            cursor: pointer;
        }

        .search-container:hover {
            border-color: var(--gold);
        }

        .search-container:focus-within {
            border-color: var(--primary);
            
        }

        .search-icon {
            position: absolute;
            left: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-3);
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            padding: 1.15rem 3rem 1.15rem 3.5rem;
            border: none;
            background: transparent;
            font-size: 1rem;
            font-family: 'Inter', system-ui, sans-serif;
            color: var(--text);
            outline: none;
        }

        /* Adjust padding on larger screens where toggle buttons fit */
        @media (min-width: 640px) {
            .search-input {
                padding-right: 15rem;
            }
        }

        .search-input::placeholder {
            color: var(--text-3);
        }

        .search-toggle {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            display: none;
            gap: 0.5rem;
            background: var(--surface-3);
            padding: 0.25rem;
            border-radius: 8px;
            z-index: 10;
            pointer-events: auto;
        }

        @media (min-width: 640px) {
            .search-toggle {
                display: flex;
            }
        }

        .toggle-btn {
            padding: 0.5rem 1rem;
            border: none;
            background: transparent;
            color: var(--text-3);
            font-family: 'Inter', system-ui, sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .toggle-btn:hover {
            color: var(--text);
        }

        /* Active tab — DESIGN.md §4 badges/tags active pattern:
           signal-tint background + signal-edge border + ink text.
           Replaces previous --gold text-on-light-bg which fell below AA. */
        .toggle-btn.active {
            background: var(--signal-tint);
            border: 1px solid var(--signal-edge);
            color: var(--ink);
        }

        .search-results {
            position: absolute;
            top: calc(100% + 0.5rem);
            left: 0;
            right: 0;
            background: var(--surface-2);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            
            max-height: 400px;
            overflow-y: auto;
            z-index: 100;
        }

        .search-results.hidden {
            display: none;
        }

        .search-result-item {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            transition: background 0.15s ease;
            text-decoration: none;
            display: block;
            color: inherit;
        }

        .search-result-item:last-child {
            border-bottom: none;
        }

        .search-result-item:hover {
            background: var(--surface-3);
        }

        .result-type-badge {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 0.05em;
        }

        .result-type-badge.plugin {
            background: rgba(68, 147, 248, 0.15);
            color: var(--brand-blue);
        }

        .result-type-badge.skill {
            background: rgba(234, 170, 0, 0.15);
            color: var(--gold);
        }

        .result-name {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text);
            margin: 0.25rem 0;
        }

        .result-description {
            font-size: 0.875rem;
            color: var(--text-2);
            margin: 0.25rem 0;
            line-height: 1.4;
        }

        .result-plugin-info {
            font-size: 0.8125rem;
            color: var(--brand-blue);
            margin-top: 0.5rem;
        }

        /* Install box */
        .install-box {
            width: 100%;
            max-width: 650px;
            padding: 1.5rem;
            background: var(--surface-2);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
            opacity: 0;
        }

        .install-label {
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-3);
            font-size: 0.75rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.5rem;
        }

        .install-command {
            font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
            color: var(--text);
            font-size: 0.95rem;
            user-select: all;
            cursor: pointer;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ========================================
           FEATURES SECTION
           ======================================== */
        .features {
            padding: 3rem 2rem;
            background: var(--surface);
        }


        .section-title {
            font-size: clamp(1.8rem, 3vw, 2.5rem);
            font-weight: 600;
            letter-spacing: -0.02em;
            margin-bottom: 2rem;
            max-width: 700px;
            line-height: 1.2;
            color: var(--text);
        }

        /* Numbered list — rules over boxes (DESIGN.md 2026-05-31 changelog).
           Replaces the prior 3-column emoji-icon feature-card grid (Signals 1/6/7 from
           the VibeCheck 25/100 audit). Each row separated by hairline rule; mono
           numeric kicker; no box chrome, no decorative icons. */
        .features-list {
            list-style: none;
            padding: 0;
            margin: 0;
            border-top: 1px solid var(--border);
        }

        .feature-row {
            display: grid;
            grid-template-columns: 64px 1fr;
            gap: 1.5rem;
            padding: 1.5rem 0;
            border-bottom: 1px solid var(--border);
            align-items: baseline;
        }

        .feature-row:hover {
            background: var(--surface-2);
        }

        .feature-kicker {
            font-family: var(--font-mono, 'JetBrains Mono', monospace);
            font-size: 0.8rem;
            color: var(--text-2);
            letter-spacing: 0.05em;
            font-variant-numeric: tabular-nums;
        }

        .feature-row h3 {
            font-size: 1.15rem;
            font-weight: 600;
            margin: 0 0 0.35rem 0;
            color: var(--text);
        }

        .feature-row p {
            color: var(--text-2);
            line-height: 1.6;
            margin: 0;
            max-width: 60ch;
        }

        /* Client showcase removed — sponsor now inline in hero */

        /* ========================================
           SAAS SKILL PACKS SECTION
           ======================================== */
        .saas-packs-section {
            padding: 3rem 2rem;
            background: var(--surface);
        }

        .saas-packs-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .saas-packs-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .saas-title {
            color: var(--text);
            font-size: clamp(2rem, 4vw, 2.8rem);
            margin: 1rem 0 0.5rem;
            font-weight: 700;
        }

        .saas-subtitle {
            color: var(--text-2);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

        .saas-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .saas-card {
            background: var(--surface-1);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .saas-card:hover {
            transform: translateY(-4px);
            
        }

        .saas-card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .saas-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .saas-card h3 {
            color: var(--text);
            margin: 0;
            font-size: 1.2rem;
        }

        .saas-tier {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--gold);
            font-family: 'JetBrains Mono', monospace;
        }

        .saas-desc {
            color: var(--text-2);
            font-size: 0.9rem;
            margin-bottom: 1rem;
            line-height: 1.5;
        }

        .saas-commands {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .saas-cmd {
            background: var(--surface-2);
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            font-size: 0.8rem;
            color: var(--text-2);
            cursor: pointer;
            transition: background 0.2s;
            border: none;
            font-family: 'JetBrains Mono', monospace;
            text-align: left;
        }

        .saas-cmd:hover {
            background: var(--surface-3);
        }

        .saas-cmd.primary {
            background: rgba(234, 170, 0, 0.1);
            color: var(--gold);
            border: 1px solid rgba(234, 170, 0, 0.2);
        }

        .saas-cmd.primary:hover {
            background: rgba(234, 170, 0, 0.18);
        }

        .saas-card.coming-soon {
            background: var(--surface-3);
            border: 1px dashed var(--border);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .coming-soon-icon {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
        }

        .saas-card.coming-soon h3 {
            color: var(--text);
            margin: 0 0 0.5rem;
            font-size: 1.1rem;
        }

        .saas-card.coming-soon p {
            color: var(--text-3);
            font-size: 0.85rem;
            margin: 0;
        }

        .saas-cta {
            text-align: center;
        }

        .saas-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: white;
            color: #8B0A2D;
            padding: 0.875rem 1.75rem;
            border-radius: 8px;
            font-weight: 700;
            text-decoration: none;
            font-size: 1rem;
            font-family: 'Inter', system-ui, sans-serif;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .saas-button:hover {
            transform: translateY(-2px);
            
        }

        @media (max-width: 768px) {
            .saas-packs-section {
                padding: 3rem 1.5rem;
            }

            .saas-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ========================================
           COWORK DOWNLOADS SECTION (Homepage)
           ======================================== */
        .cowork-home-section {
            padding: 3rem 2rem;
            background: var(--surface-2);
        }

        .cowork-home-container {
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .cowork-home-title {
            color: var(--text);
            font-size: clamp(2rem, 4vw, 2.8rem);
            margin: 1rem 0 0.5rem;
            font-weight: 700;
        }

        .cowork-home-subtitle {
            color: var(--text-2);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto 2.5rem;
        }

        .cowork-home-cta {
            text-align: center;
            margin-top: 2.5rem;
        }

        .cowork-home-button {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            background: var(--accent);
            color: var(--surface);
            padding: 1rem 2.5rem;
            border-radius: 10px;
            font-weight: 700;
            text-decoration: none;
            font-size: 1.1rem;
            font-family: 'Inter', system-ui, sans-serif;
            transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
        }

        .cowork-home-button:hover {
            transform: translateY(-2px);
            
            color: var(--surface);
        }

        @media (max-width: 768px) {
            .cowork-home-section {
                padding: 3rem 1.5rem;
            }
        }

        /* ========================================
           HEAT CHECK SECTION — editorial curated picks (was Phase 4C "starter pack")
           ======================================== */
        .heat-check-section {
            padding: 4rem 2rem;
            background: var(--surface);
            border-top: 1px solid var(--border, var(--rule));
            border-bottom: 1px solid var(--border, var(--rule));
        }

        .heat-check-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .heat-check-header {
            text-align: left;
            margin-bottom: 2.5rem;
            max-width: 720px;
        }

        .heat-check-title {
            color: var(--text, var(--ink));
            font-size: clamp(1.75rem, 3vw, 2.25rem);
            font-weight: 700;
            margin: 0 0 0.5rem;
            letter-spacing: -0.02em;
        }

        .heat-check-subtitle {
            color: var(--text-2, var(--ink-2));
            font-size: 1.05rem;
            line-height: 1.55;
            margin: 0;
        }

        .heat-check-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            margin-bottom: 2rem;
        }

        @media (min-width: 768px) {
            .heat-check-grid {
                grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
