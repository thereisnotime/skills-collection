    <!-- JavaScript for interactions -->
    <script is:inline>
        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Scroll reveal observer
        var revealObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el) {
            revealObserver.observe(el);
        });

        // Copy install command(s) on click
        document.querySelectorAll('.install-command').forEach((el) => {
            el.addEventListener('click', function() {
                const text = this.dataset.copy || this.textContent;
                navigator.clipboard.writeText(text).then(() => {
                    const original = this.textContent;
                    this.textContent = '✓ Copied to clipboard!';
                    this.style.color = 'var(--positive)';
                    if (window.trackEvent) {
                        window.trackEvent('install_copied', { plugin_name: text, source: 'homepage_install' });
                    }
                    setTimeout(() => {
                        this.textContent = original;
                        this.style.color = '';
                    }, 2000);
                });
            });
        });

        // Track SaaS pack copy clicks
        document.querySelectorAll('.saas-cmd').forEach(function(el) {
            el.addEventListener('click', function() {
                if (window.trackEvent) {
                    var packName = this.textContent.replace('/plugin install ', '').replace('npm i ', '').trim();
                    window.trackEvent('install_copied', { plugin_name: packName, source: 'homepage_saas_pack' });
                }
            });
        });

        // Track CTA clicks
        document.querySelectorAll('.hero-cta-group a, .cowork-home-cta a, .saas-cta a').forEach(function(link) {
            link.addEventListener('click', function() {
                if (window.trackEvent) {
                    window.trackEvent('cta_click', {
                        cta_name: this.textContent.trim().substring(0, 50),
                        cta_url: this.getAttribute('href')
                    });
                }
            });
        });

        // Homepage search is a redirect surface (search happens on /explore)
        const searchInput = document.getElementById('hero-search-input');
        const toggleBtns = document.querySelectorAll('.toggle-btn');
        let activeType = 'all';

        // Toggle button handling
        toggleBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                toggleBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                activeType = btn.dataset.type;

                const url = new URL('/explore', window.location.origin);
                if (activeType && activeType !== 'all') url.searchParams.set('type', activeType);
                window.location.assign(url.toString());
            });
        });

        const redirectToExplore = () => {
            const url = new URL('/explore', window.location.origin);
            if (activeType && activeType !== 'all') url.searchParams.set('type', activeType);
            window.location.assign(url.toString());
        };

        // Make entire search container clickable
        const searchContainer = document.querySelector('.search-container');
        if (searchContainer) {
            searchContainer.addEventListener('click', (e) => {
                // Don't redirect if clicking toggle buttons (they have their own handlers)
                if (!e.target.closest('.toggle-btn')) {
                    redirectToExplore();
                }
            });
        }

        if (searchInput) {
            searchInput.addEventListener('focus', redirectToExplore);
        }
    </script>


    <!-- Stack Builder Component -->
    <StackBuilder />
