        .level-up-field {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .level-up-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--ink-3, var(--text-3));
