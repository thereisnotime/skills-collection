{
  "$schema": "Severity thresholds and escalation trigger definitions",
  "cluster_match_threshold": 0.70,
  "repo_scan_confidence_threshold": 0.70,
  "escalation_triggers": {
    "report_velocity_spike": {
      "count": 50,
      "window_minutes": 30
    },
    "data_loss_language": {
      "keywords": ["lost", "deleted", "gone", "disappeared", "missing conversations"]
    },
    "security_privacy_language": {
      "keywords": ["unauthorized", "leaked", "exposed"]
    },
    "auth_billing_cascade": {
      "count": 20,
      "window_minutes": 60
    },
    "cross_surface_failure": {
      "min_surfaces": 3
    },
    "enterprise_blocking": {
      "keywords": ["enterprise", "API-critical", "workflow blocked"]
    }
  },
  "viral_thread_circuit_breaker": {
    "max_replies_per_hour": 500,
    "sample_size": 100
  }
}
