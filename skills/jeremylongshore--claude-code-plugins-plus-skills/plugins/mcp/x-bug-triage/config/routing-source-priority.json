{
  "$schema": "Strict ordering of routing signal sources from highest to lowest confidence",
  "precedence": [
    {
      "level": 1,
      "source": "service_owner",
      "description": "Active service/component ownership metadata",
      "confidence_modifier": 1.0
    },
    {
      "level": 2,
      "source": "oncall",
      "description": "Current oncall/escalation metadata",
      "confidence_modifier": 0.9
    },
    {
      "level": 3,
      "source": "codeowners",
      "description": "CODEOWNERS file analysis",
      "confidence_modifier": 0.8
    },
    {
      "level": 4,
      "source": "recent_assignees",
      "description": "Issue/PR assignees in last 30 days",
      "confidence_modifier": 0.6
    },
    {
      "level": 5,
      "source": "recent_committers",
      "description": "Committers to affected paths in last 14 days",
      "confidence_modifier": 0.5
    },
    {
      "level": 6,
      "source": "fallback_mapping",
      "description": "Static fallback team/component mapping",
      "confidence_modifier": 0.3
    }
  ],
  "staleness_threshold_days": 30
}
