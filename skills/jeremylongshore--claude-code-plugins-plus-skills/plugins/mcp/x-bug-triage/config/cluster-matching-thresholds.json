{
  "$schema": "Thresholds for cluster signature matching and signal weights",
  "signature_overlap_threshold": 0.70,
  "signal_weights": {
    "high_weight_deterministic": {
      "exact_error_string": 1.0,
      "linked_url_match": 0.9,
      "shared_conversation_id": 0.95,
      "same_media_fingerprint": 0.85,
      "known_issue_link": 1.0
    },
    "medium_weight_semantic": {
      "symptom_phrase_similarity": 0.6,
      "feature_area_match": 0.5,
      "surface_match": 0.4,
      "repro_hint_overlap": 0.55
    },
    "supporting_temporal": {
      "same_release_window": 0.3,
      "concentrated_time_burst": 0.25
    }
  },
  "candidate_dedup": {
    "enabled": true,
    "hybrid_similarity_threshold": 0.70
  },
  "anti_clustering": {
    "different_surface_penalty": -0.5,
    "contradictory_repro_penalty": -0.8,
    "mutually_exclusive_platform_penalty": -0.7,
    "different_family_block": true
  }
}
