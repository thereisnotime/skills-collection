{
  "name": "@claude-code-plugins-plus/project-health-auditor",
  "version": "1.0.0",
  "description": "Analyze local repos for code health, complexity, test coverage gaps",
  "type": "module",
  "main": "dist/servers/code-metrics.js",
  "scripts": {
    "dev": "tsx watch servers/code-metrics.ts",
    "build": "tsc",
    "test": "vitest",
    "test:ci": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "code-health",
    "metrics",
    "complexity",
    "coverage"
  ],
  "author": "Intent Solutions IO",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "glob": "^13.0.6",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
