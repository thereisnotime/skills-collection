{
  "name": "pr-to-spec",
  "version": "0.8.0",
  "description": "Convert code changes into structured, agent-consumable spec artifacts",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pr-to-spec": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write src/ tests/",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "bundle:action": "pnpm build && ncc build dist/action/index.js -o dist/action-bundle --minify",
    "prepublishOnly": "pnpm check && pnpm build"
  },
  "keywords": [
    "github",
    "pull-request",
    "prompt",
    "spec",
    "ai",
    "code-review",
    "claude",
    "llm",
    "developer-tools"
  ],
  "author": "Jeremy Longshore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/pr-to-spec.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^21.1.1",
    "commander": "^13.1.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.19.19",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
