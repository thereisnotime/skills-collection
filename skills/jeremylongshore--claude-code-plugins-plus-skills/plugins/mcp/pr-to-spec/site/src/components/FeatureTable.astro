---
interface Props {
  title: string;
  items: { name: string; description: string; badge?: string }[];
  columns?: number;
}

const { title, items, columns = 2 } = Astro.props;
const gridCols = columns === 3 ? 'md:grid-cols-3' : 'md:grid-cols-2';
---

<section class="py-12">
  <h2 class="text-2xl font-bold tracking-tight mb-8">{title}</h2>
  <div class={`grid grid-cols-1 ${gridCols} gap-4`}>
    {items.map(item => (
      <div class="p-5 rounded-lg border border-border bg-card hover:bg-card-hover hover:border-border-bright transition-all duration-200">
        <div class="flex items-start gap-3">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-mono text-sm font-semibold text-primary">{item.name}</h3>
              {item.badge && (
                <span class="px-1.5 py-0.5 rounded text-[10px] font-mono font-semibold bg-primary/10 text-primary uppercase">
                  {item.badge}
                </span>
              )}
            </div>
            <p class="text-sm text-text-2 leading-relaxed">{item.description}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
