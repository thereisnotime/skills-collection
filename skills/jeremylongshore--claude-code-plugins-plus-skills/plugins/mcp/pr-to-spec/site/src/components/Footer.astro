---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const versionPath = resolve(process.cwd(), '..', 'VERSION');
const version = readFileSync(versionPath, 'utf-8').trim();
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-border bg-surface-1 mt-20">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-3">
      <div class="flex items-center gap-4">
        <span class="font-mono text-text-2">pr-to-spec</span>
        <span class="px-2 py-0.5 rounded bg-surface-2 font-mono text-xs text-primary">v{version}</span>
        <span>MIT License</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="https://github.com/jeremylongshore/pr-to-prompt" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">GitHub</a>
        <a href="https://www.npmjs.com/package/pr-to-spec" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">npm</a>
        <a href="https://gist.github.com/jeremylongshore/5b2de7ba9baca1eaaa0a757b5b0c48db" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">Gist</a>
      </div>
    </div>
  </div>
</footer>
