---
interface Props {
  code: string;
  lang?: string;
  title?: string;
}

const { code, lang = 'bash', title } = Astro.props;
const id = `code-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="rounded-lg border border-border bg-surface-2 overflow-hidden">
  {title && (
    <div class="flex items-center justify-between px-4 py-2 border-b border-border bg-surface-1">
      <span class="text-xs font-mono text-text-3">{title}</span>
      <button
        class="text-xs px-2 py-1 rounded text-text-3 hover:text-text hover:bg-surface-3 transition-colors copy-code-btn"
        data-target={id}
      >
        Copy
      </button>
    </div>
  )}
  {!title && (
    <div class="flex justify-end px-4 py-1">
      <button
        class="text-xs px-2 py-1 rounded text-text-3 hover:text-text hover:bg-surface-3 transition-colors copy-code-btn"
        data-target={id}
      >
        Copy
      </button>
    </div>
  )}
  <pre class="px-4 py-3 overflow-x-auto text-sm leading-relaxed"><code id={id} class={`language-${lang} text-text`}>{code}</code></pre>
</div>

<script is:inline>
  document.querySelectorAll('.copy-code-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = document.getElementById(btn.getAttribute('data-target'));
      if (!target) return;
      navigator.clipboard.writeText(target.textContent).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });
</script>
