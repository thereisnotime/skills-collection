---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}audit/`, label: 'Audit' },
  { href: `${base}changelog/`, label: 'Changelog' },
];

const external = [
  { href: 'https://github.com/jeremylongshore/pr-to-prompt', label: 'GitHub' },
  { href: 'https://www.npmjs.com/package/pr-to-spec', label: 'npm' },
  { href: 'https://gist.github.com/jeremylongshore/5b2de7ba9baca1eaaa0a757b5b0c48db', label: 'Gist' },
];
---

<nav class="fixed top-0 w-full z-50 border-b border-transparent backdrop-blur-md transition-all duration-200" id="main-nav">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href={base} class="text-lg font-bold tracking-tight text-text hover:text-primary transition-colors">
      <span class="font-mono text-primary">pr-to-spec</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-6">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors',
            currentPath === link.href || (link.href !== base && currentPath.startsWith(link.href))
              ? 'text-primary'
              : 'text-text-2 hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
      <span class="w-px h-5 bg-border" />
      {external.map(link => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-text-2 hover:text-text transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button class="md:hidden p-2 text-text-2" aria-label="Toggle menu" id="mobile-toggle">
      <svg class="w-5 h-5" id="menu-open-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg class="w-5 h-5 hidden" id="menu-close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="hidden md:hidden border-t border-border bg-surface" id="mobile-menu">
    <div class="px-6 py-4 flex flex-col gap-3">
      {links.map(link => (
        <a href={link.href} class="text-sm text-text-2 hover:text-text py-1">{link.label}</a>
      ))}
      <hr class="border-border" />
      {external.map(link => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-sm text-text-2 hover:text-text py-1">{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<script is:inline>
  (function() {
    var nav = document.getElementById('main-nav');
    var toggle = document.getElementById('mobile-toggle');
    var menu = document.getElementById('mobile-menu');
    var openIcon = document.getElementById('menu-open-icon');
    var closeIcon = document.getElementById('menu-close-icon');

    window.addEventListener('scroll', function() {
      if (window.scrollY > 20) {
        nav.classList.add('bg-surface', 'border-border');
      } else {
        nav.classList.remove('bg-surface', 'border-border');
      }
    }, { passive: true });

    toggle.addEventListener('click', function() {
      var isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  })();
</script>
