---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureTable from '../components/FeatureTable.astro';
import CodeBlock from '../components/CodeBlock.astro';
import { parseReadme } from '../lib/parse-readme';

const readme = parseReadme();

const features = [
  { name: 'PR Analysis', description: 'Analyze any GitHub PR into a structured spec with risk classification', badge: 'core' },
  { name: 'Local Scan', description: 'Analyze local branches, staged changes, or last N commits', badge: 'core' },
  { name: 'Intent Declaration', description: 'Declare expected scope, risk ceiling, and change type', badge: 'core' },
  { name: 'Drift Detection', description: 'Detect scope creep, forbidden touches, risk escalation', badge: 'core' },
  { name: 'MCP Server', description: '6-tool Model Context Protocol server for IDE integration', badge: 'new' },
  { name: 'Verification Contracts', description: 'Declarative rules: no_new_dependencies, max_files_changed, etc.', badge: 'v0.7' },
  { name: 'Intent DAG', description: 'Graph-based intent tracking with decision taxonomy', badge: 'v0.7' },
  { name: 'Agent Protocol', description: 'JSON envelope with version, status, exit codes, signals', badge: 'core' },
  { name: 'Risk Classification', description: '10 categories from authentication to large-change', badge: 'core' },
  { name: 'AI Enhancement', description: 'Optional Anthropic/OpenAI summaries with --ai-enhance', badge: 'opt' },
  { name: 'GitHub Action', description: 'Automated PR spec generation in CI/CD pipelines', badge: 'core' },
];

const riskItems = readme.riskClassification.map(r => ({
  name: r.category,
  description: r.triggers,
  badge: r.severity,
}));
---

<BaseLayout title="Operator Audit — pr-to-spec" description="Feature breakdown, architecture, risk classification, and security posture for pr-to-spec.">
  <!-- Header -->
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-border bg-surface-2/50 text-xs font-mono text-text-2 mb-4">
      Operator Audit
    </div>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Feature Breakdown & Architecture</h1>
    <p class="text-lg text-text-2 max-w-2xl">
      A complete inventory of what pr-to-spec does, how it's built, and what risks it classifies.
    </p>
  </section>

  <!-- Features -->
  <section class="max-w-4xl mx-auto px-6">
    <FeatureTable title="Features" items={features} columns={2} />
  </section>

  <!-- Architecture -->
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold tracking-tight mb-6">Architecture</h2>
    <CodeBlock code={readme.architecture} title="Source tree" />

    <div class="mt-8">
      <h3 class="text-lg font-semibold mb-4">Design Principles</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {readme.designPrinciples.map(principle => {
          const [bold, ...rest] = principle.split(':');
          return (
            <div class="p-4 rounded-lg border border-border bg-card">
              <span class="font-semibold text-primary">{bold.replace(/\*\*/g, '')}</span>
              {rest.length > 0 && <span class="text-text-2">:{rest.join(':')}</span>}
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Before/After -->
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold tracking-tight mb-6">Before & After</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-danger uppercase tracking-wider mb-3">Before pr-to-spec</h3>
        <div class="p-5 rounded-lg border border-danger/30 bg-danger/5">
          <ul class="space-y-2 text-sm text-text-2">
            <li>Agent reads raw diffs — no structure, no risk signals</li>
            <li>No intent declaration — scope creep undetected</li>
            <li>Manual PR review copy-paste to LLM context</li>
            <li>No exit codes — agents can't gate on risk</li>
            <li>No audit trail — "what did the agent see?"</li>
          </ul>
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-positive uppercase tracking-wider mb-3">After pr-to-spec</h3>
        <div class="p-5 rounded-lg border border-positive/30 bg-positive/5">
          <ul class="space-y-2 text-sm text-text-2">
            <li>Structured JSON envelope — version, status, signals</li>
            <li>Intent + drift detection catches scope creep early</li>
            <li>One command: pr-to-spec check --json | agent review</li>
            <li>Clean exit codes: 0 clean, 2 high-risk, 3 drift, 4 gate fail</li>
            <li>Full spec artifact — reproducible, auditable, deterministic</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Risk Classification -->
  <section class="max-w-4xl mx-auto px-6">
    <FeatureTable title="Risk Classification" items={riskItems} columns={2} />
  </section>

  <!-- Security Posture -->
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold tracking-tight mb-6">Security Posture</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {[
        { title: 'No Execution', desc: 'Never runs code — metadata and diffs only' },
        { title: 'Read-Only Default', desc: 'Only reads PRs and diffs, writes nothing unless --comment' },
        { title: 'Zod-Validated Output', desc: 'All spec output is schema-validated before rendering' },
        { title: 'SSRF Prevention', desc: 'Webhook URLs validated: HTTPS required, private IPs blocked' },
        { title: 'No Command Injection', desc: 'custom_command contract type removed, always fails' },
        { title: 'Prototype Pollution Guard', desc: '--field extraction blocks __proto__ traversal' },
      ].map(item => (
        <div class="p-4 rounded-lg border border-border bg-card">
          <h3 class="font-semibold text-sm text-accent mb-1">{item.title}</h3>
          <p class="text-sm text-text-2">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Quality Grade -->
  <section class="max-w-4xl mx-auto px-6 py-12 text-center">
    <div class="inline-flex flex-col items-center p-8 rounded-xl border border-primary/30 bg-primary/5">
      <span class="text-6xl font-bold text-primary mb-2">A</span>
      <span class="text-sm text-text-2">Quality Grade</span>
      <span class="text-xs text-text-3 mt-1">384 tests passing · MIT licensed · Deterministic output</span>
    </div>
  </section>
</BaseLayout>
