---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureTable from '../components/FeatureTable.astro';
import CodeBlock from '../components/CodeBlock.astro';
import { parseReadme } from '../lib/parse-readme';

const readme = parseReadme();

const mcpItems = readme.mcpTools.map(t => ({
  name: t.tool,
  description: t.description,
}));

const exitCodeItems = readme.exitCodes.map(e => ({
  name: `Exit ${e.code}`,
  description: e.meaning,
}));

const driftItems = readme.driftSignals.map(d => ({
  name: d.signal,
  description: d.trigger,
}));
---

<BaseLayout title="pr-to-spec — The Flight Envelope for Agentic Coding">
  <Hero tagline="Turn code changes into agent-consumable specs" description={readme.description} />

  <!-- What It Does -->
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold tracking-tight mb-6">What It Does</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      {[
        { step: '1', title: 'Declare intent', desc: 'Tell pr-to-spec what you\'re building, scope, and risk ceiling' },
        { step: '2', title: 'Make changes', desc: 'Work normally in your branch' },
        { step: '3', title: 'Check drift', desc: 'pr-to-spec check --json produces a structured spec + drift signals' },
        { step: '4', title: 'Agent consumes', desc: 'Any agent reads the envelope and acts accordingly' },
      ].map(item => (
        <div class="relative p-5 rounded-lg border border-border bg-card">
          <div class="text-3xl font-bold text-primary/20 absolute top-3 right-4">{item.step}</div>
          <h3 class="font-semibold text-sm mb-1">{item.title}</h3>
          <p class="text-sm text-text-2">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Quick Start -->
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold tracking-tight mb-8">Quick Start</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-text-2 uppercase tracking-wider mb-3">Local Diff</h3>
        <CodeBlock code={readme.quickStart.local} lang="bash" />
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text-2 uppercase tracking-wider mb-3">Intent + Drift</h3>
        <CodeBlock code={readme.quickStart.intent} lang="bash" />
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text-2 uppercase tracking-wider mb-3">GitHub PR</h3>
        <CodeBlock code={readme.quickStart.githubPR} lang="bash" />
      </div>
    </div>
  </section>

  <!-- MCP Server -->
  <section class="max-w-4xl mx-auto px-6">
    <FeatureTable title="MCP Server Tools" items={mcpItems} columns={2} />

    <div class="mt-6">
      <h3 class="text-sm font-semibold text-text-2 uppercase tracking-wider mb-3">Plugin Installation</h3>
      <CodeBlock code="claude plugin add jeremylongshore/pr-to-spec" lang="bash" title="Claude Code" />
    </div>
  </section>

  <!-- Agent Protocol -->
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold tracking-tight mb-6">Agent Protocol</h2>
    <CodeBlock code={readme.agentProtocol} lang="json" title="Envelope format" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
      <FeatureTable title="Exit Codes" items={exitCodeItems} columns={1} />
      <FeatureTable title="Drift Signals" items={driftItems} columns={1} />
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-6 py-16 text-center">
    <h2 class="text-2xl font-bold tracking-tight mb-4">Get Started</h2>
    <p class="text-text-2 mb-8">Install from npm and start generating specs in seconds.</p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="https://github.com/jeremylongshore/pr-to-prompt"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 rounded-lg bg-primary text-surface font-semibold hover:opacity-90 transition-opacity"
      >
        View on GitHub
      </a>
      <a
        href="https://www.npmjs.com/package/pr-to-spec"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 rounded-lg border border-border text-text-2 hover:text-text hover:border-border-bright transition-colors"
      >
        npm Package
      </a>
      <a
        href={`${import.meta.env.BASE_URL}changelog/`}
        class="px-6 py-3 rounded-lg border border-border text-text-2 hover:text-text hover:border-border-bright transition-colors"
      >
        Changelog
      </a>
    </div>
  </section>
</BaseLayout>
