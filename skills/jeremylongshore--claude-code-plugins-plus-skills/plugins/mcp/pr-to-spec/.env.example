# Required: GitHub personal access token with `repo` scope (or fine-grained with PR read access)
GITHUB_TOKEN=ghp_your_token_here

# Optional: Anthropic API key for AI-enhanced summaries (MVP works without this)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Enable AI-enhanced summary generation (requires ANTHROPIC_API_KEY)
# PR_TO_PROMPT_AI_ENHANCE=true
