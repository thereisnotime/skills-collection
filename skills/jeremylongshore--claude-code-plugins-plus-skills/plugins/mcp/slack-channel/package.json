{
  "name": "claude-channel-slack",
  "version": "0.9.0",
  "description": "Slack channel for Claude Code — two-way chat via Socket Mode",
  "type": "module",
  "bin": "./server.ts",
  "scripts": {
    "start": "bun install --frozen-lockfile --no-summary && bun server.ts",
    "start:node": "npx tsx server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@slack/socket-mode": "2.0.6",
    "@slack/web-api": "7.15.0",
    "tsx": "^4.21.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bun": "1.3.11",
    "dependency-cruiser": "^17.3.10",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "5.9.3"
  },
  "license": "MIT",
  "author": {
    "name": "Jeremy Longshore",
    "email": "jeremy@intentsolutions.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/claude-code-slack-channel.git"
  },
  "lint-staged": {
    "*.{ts,js,json}": "bunx @biomejs/biome check --write --no-errors-on-unmatched"
  }
}
