rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Block ALL direct client access.
    // All writes go through Cloud Functions (server-side, validated).
    // The Admin SDK used by Cloud Functions bypasses these rules entirely,
    // so the functions will still work.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
