rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /email-signups/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /nominations/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
