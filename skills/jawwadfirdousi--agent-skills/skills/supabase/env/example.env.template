# Copy this file to skills/supabase/env/<project>-<env>.env and fill in values.
# Example: skills/supabase/env/my-project-dev.env
#
# Files matching env/*.env are gitignored; this template is the only file in
# env/ that is tracked.

# Supabase project URL. The script derives the project ref from the hostname.
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=""

# Supabase personal access token with management API access (sbp_...).
# Treat as admin-level: it can run arbitrary SQL against the project.
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=""
