{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/api/schema/stryker-core.json",
  "_about": "v7.4.10: mutation testing config. Run via .github/workflows/mutation-testing.yml or `npx stryker run` locally. Uses bun's test runner via the command runner since there is no native stryker-bun plugin.",
  "packageManager": "npm",
  "testRunner": "command",
  "commandRunner": {
    "command": "bun test"
  },
  "reporters": ["clear-text", "html", "json"],
  "concurrency": 4,
  "timeoutMS": 30000,
  "mutate": [
    "src/runner/state.ts",
    "src/runner/build_prompt.ts",
    "src/runner/providers.ts",
    "src/runner/budget.ts",
    "src/runner/checkpoint.ts",
    "src/util/shell.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "htmlReporter": {
    "fileName": "mutation/index.html"
  },
  "jsonReporter": {
    "fileName": "mutation/report.json"
  },
  "tempDirName": ".stryker-tmp"
}
