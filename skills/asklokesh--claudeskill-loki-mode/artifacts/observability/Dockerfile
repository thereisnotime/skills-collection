# Autonomi Founder Observability Dashboard
# Serves index.html + data.json (generated by fetch-data.sh on the host)
# Port: 58080 (not 57374/57375 which loki uses)

FROM nginx:1.27-alpine

LABEL org.opencontainers.image.title="Autonomi Observability"
LABEL org.opencontainers.image.description="Founder observability dashboard for loki-mode / Autonomi"

# Remove default nginx site
RUN rm -f /etc/nginx/conf.d/default.conf

# Minimal nginx config: serve static files on port 58080
RUN printf 'server {\n\
    listen 58080;\n\
    server_name localhost;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    gzip on;\n\
    gzip_types text/plain text/html text/css application/javascript application/json;\n\
    location / {\n\
        try_files $uri $uri/ =404;\n\
        add_header Cache-Control "no-store, no-cache, must-revalidate";\n\
    }\n\
    error_page 404 /index.html;\n\
}\n' > /etc/nginx/conf.d/observability.conf

# Copy static files (index.html + data.json must be present at build time)
COPY index.html /usr/share/nginx/html/
COPY data.json /usr/share/nginx/html/

EXPOSE 58080

CMD ["nginx", "-g", "daemon off;"]
