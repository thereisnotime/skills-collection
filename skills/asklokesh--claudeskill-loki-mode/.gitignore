.DS_Store

# OS files
*.DS_Store

# Secrets -- never commit. .env holds ANTHROPIC_API_KEY for docker compose;
# .loki-oauth-credentials.json holds a live Claude Code OAuth token (Auth
# Option 2). .env.example is the committed placeholder template.
.env
.env.*
!.env.example
.loki-oauth-credentials.json

# Python virtualenv
.venv/
dashboard/.venv/

# Node.js
node_modules/
*.log
*.tgz
# v7.5.10: package-lock.json is now committed (was gitignored prior).
# Required for `npm audit` to scan production deps; also gives
# reproducible installs for users who consume `npm install -g loki-mode`.

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Build outputs
dist/
!web-app/dist/
*.vsix

# Local development (not tracked)
the_app/
wiki-repo/

# Runtime state (regenerated each session)
# Source hooks live in autonomy/hooks/ (tracked)
.loki/

# Runtime state in subdirectories
dashboard-ui/.loki/
vscode-extension/.loki/

# Hermetic test fixtures under loki-ts/ are intentionally tracked
!loki-ts/tests/fixtures/**/.loki/
!loki-ts/tests/fixtures/**/.loki/**

# Claude Code harness scheduled-tasks lock (transient, per-session)
.claude/scheduled_tasks.lock

# Test artifacts
**/test-results/
.aider*

# Stray test artifacts (accidentally committed in v6.50.0; ignore going forward)
.loki-test-tmp/
.gstack/
internal/
