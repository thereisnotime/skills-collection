[MAIN]
py-version=3.13
fail-under=10

[FORMAT]
max-line-length=127

[MESSAGES CONTROL]
disable=raw-checker-failed,
        bad-inline-option,
        locally-disabled,
        file-ignored,
        suppressed-message,
        useless-suppression,
        deprecated-pragma,
        use-symbolic-message-instead,
        duplicate-code,
        wrong-import-position

[DESIGN]
max-args=10
max-attributes=12
max-branches=15
max-locals=20
max-nested-blocks=5
max-statements=50
