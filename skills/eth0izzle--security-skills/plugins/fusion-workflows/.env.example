# CrowdStrike API credentials for Fusion SOAR workflow scripts.
# Copy this file to .env and fill in your values.
#
# To create an API client:
#   1. Log in to the Falcon console
#   2. Navigate to Support and resources > API clients and keys
#   3. Create a client with the scopes your skills need:
#        - Fusion workflows:  Workflow:Read  (+ Workflow:Write for import/execute)
#        - Lookup files:      NGSIEM:Read    (+ NGSIEM:Write for create/update/delete)
#
# See README.md for full setup instructions and scope details.

CS_CLIENT_ID=your_client_id_here
CS_CLIENT_SECRET=your_client_secret_here

# Base URL varies by CrowdStrike cloud:
#   US-1:     https://api.crowdstrike.com
#   US-2:     https://api.us-2.crowdstrike.com
#   EU-1:     https://api.eu-1.crowdstrike.com
#   US-GOV-1: https://api.laggar.gcw.crowdstrike.com
CS_BASE_URL=https://api.crowdstrike.com
