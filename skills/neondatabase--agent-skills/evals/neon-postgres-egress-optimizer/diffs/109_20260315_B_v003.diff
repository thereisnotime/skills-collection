@@ -4,8 +4,16 @@ import { categories } from "../db/schema";
 
 export const categoriesRoute = new Hono();
 
+let categoriesCache: { id: number; name: string; slug: string }[] | null = null;
+let cacheExpiresAt = 0;
+const CACHE_TTL_MS = 5 * 60 * 1000; // 5 minutes
+
 // GET /categories — list all categories
 categoriesRoute.get("/", async (c) => {
-  const allCategories = await db.select().from(categories);
-  return c.json(allCategories);
+  const now = Date.now();
+  if (!categoriesCache || now > cacheExpiresAt) {
+    categoriesCache = await db.select().from(categories);
+    cacheExpiresAt = now + CACHE_TTL_MS;
+  }
+  return c.json(categoriesCache);
 });
