{
  "hooks": {
    "UserPromptSubmit": [
      {"hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/user-prompt-submit", "timeout": 5}]}
    ],
    "Stop": [
      {"hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/stop", "timeout": 10}]}
    ],
    "StopFailure": [
      {"hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/stop-failure", "timeout": 5}]}
    ],
    "SessionStart": [
      {"hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/session-start", "timeout": 5}]}
    ],
    "PostCompact": [
      {"hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/session-start", "timeout": 5}]}
    ],
    "SubagentStop": [
      {"hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/subagent-stop", "timeout": 5}]}
    ],
    "PreToolUse": [
      {"matcher": "Skill",     "hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/pre-tool-use", "timeout": 1}]},
      {"matcher": "TodoWrite", "hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/pre-tool-use", "timeout": 1}]},
      {"matcher": "Agent",     "hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/pre-tool-use", "timeout": 1}]}
    ],
    "PostToolUse": [
      {"matcher": "Skill", "hooks": [{"type": "http", "url": "http://127.0.0.1:${RELAY_HOOK_PORT}/hook/post-tool-use", "timeout": 1}]}
    ]
  }
}
