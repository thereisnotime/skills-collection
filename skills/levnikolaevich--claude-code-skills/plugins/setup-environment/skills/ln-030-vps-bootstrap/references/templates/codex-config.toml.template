# Headless agent defaults — unattended inside the outer project sandbox.
# Verified against https://developers.openai.com/codex/config-reference (2026-05).
# `workspace-write` keeps Codex writes project-scoped; the outer bubblewrap
# wrapper is still the hard boundary for filesystem reads and host resources.
model = "gpt-5.5"
model_reasoning_effort = "xhigh"
approval_policy = "never"
sandbox_mode = "workspace-write"

[sandbox_workspace_write]
network_access = true
exclude_slash_tmp = true
exclude_tmpdir_env_var = true
writable_roots = ["${PROJECT_DIR}"]

# notify hook is installed conditionally by ln-032 (only if TELEGRAM_BOT_TOKEN
# is set AND operator opted in). ln-032 appends:
#   notify = ["bash", "/home/${BOT_USER}/.codex/notify.sh"]

[projects."/home/${BOT_USER}"]
trust_level = "trusted"

[projects."${PROJECT_DIR}"]
trust_level = "trusted"

[tui.model_availability_nux]
"gpt-5.5" = 2

[plugins."hugging-face@openai-curated"]
enabled = true

[plugins."github@openai-curated"]
enabled = true

# BEGIN ln-030 managed LevNikolaevich marketplace
[plugins."agile-workflow@levnikolaevich-skills-marketplace"]
enabled = true
# Enable additional entries during Step 5b rendering when AGENT_SKILLS_PLUGINS
# is `all` or an explicit comma-list. Do not enable optional plugins silently.
# [plugins."documentation-pipeline@levnikolaevich-skills-marketplace"]
# enabled = true
# [plugins."codebase-audit-suite@levnikolaevich-skills-marketplace"]
# enabled = true
# [plugins."project-bootstrap@levnikolaevich-skills-marketplace"]
# enabled = true
# [plugins."optimization-suite@levnikolaevich-skills-marketplace"]
# enabled = true

[marketplaces.levnikolaevich-skills-marketplace]
source_type = "git"
source = "${AGENT_SKILLS_REPO_URL}"
ref = "${AGENT_SKILLS_REF}"
# END ln-030 managed LevNikolaevich marketplace

