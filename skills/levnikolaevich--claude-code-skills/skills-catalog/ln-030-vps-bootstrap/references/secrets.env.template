# Secrets for ${PROJECT_NAME} god-session.
# Install path: /etc/${PROJECT_NAME}/secrets.env  (chown root:${BOT_USER}, chmod 0640)
# Sourced by /usr/local/bin/${SERVICE_PREFIX}-god, ${SERVICE_PREFIX}-relay-bot.service,
# /usr/local/bin/${SERVICE_PREFIX}-mint-gh-token, and /home/${BOT_USER}/.codex/notify.sh.
#
# Replace each <PLACEHOLDER> with the real value AFTER this file lands on the VPS.
# DO NOT commit real values to git — only this template ships in the skill.

# === Telegram bot (optional; leave blank to disable Telegram integration) ===
TELEGRAM_BOT_TOKEN=<bot-token-from-BotFather>
TELEGRAM_CHAT_ID=<operator-chat-id-numeric>
TELEGRAM_BOT_USERNAME=<bot-username-without-@>
RELAY_HOOK_PORT=9999

# === Communication policy ===
# RELAY_VERBOSITY controls how much of claude's progress reaches Telegram:
#   quiet   = only L1 inbound-ack reaction + L5 final reply (closest to silent)
#   normal  = + L2 Skill announcements + L3 TodoWrite transitions + L4 SubagentStop
#   verbose = + Bash whitelist + PostToolUse Skill duration
# Apply changes via `systemctl restart ${SERVICE_PREFIX}-relay-bot.service`.
RELAY_VERBOSITY=normal
# Inbound-ack reactions: comma-separated set; relay-bot picks one at random
# per ack so the chat doesn't feel robotic. Bots can set 1 reaction per message.
# If the chat blocks any emoji here, falls back to ❤, then logs and skips.
# Cosmetic — failures never affect delivery status.
# Customise to taste; unset = use the curated default list below.
RELAY_INBOUND_REACTIONS=👀,👍,✅,🫡,🤝,✍,🆒,👌,🙏

# === Identity vars set elsewhere — DO NOT add here ===
# `BOT_USER`, `PROJECT_NAME`, `PROJECT_DIR`, `SERVICE_PREFIX` are set by
# systemd `Environment=` directives in each unit file (single source of truth).
# Duplicating them here would shadow the unit definitions and silently
# desync services from their unit files.

# === GitHub App (optional; only when GIT_PROVIDER=github AND App auth is desired) ===
# Leave blank if project hosts on GitLab/Gitea/etc, or if you prefer PAT/Deploy Token.
GITHUB_APP_ID=<numeric-app-id>
GITHUB_APP_CLIENT_ID=<Iv23li...>
GITHUB_APP_PRIVATE_KEY_PATH=/etc/${PROJECT_NAME}/github-app.pem
GITHUB_INSTALLATION_ID=<numeric-installation-id>
REPO_SLUG=<owner/repo>

# === GitLab (optional; only when GIT_PROVIDER=gitlab) ===
# `GITLAB_HOST` is the hostname (`gitlab.com` for SaaS, or self-hosted like `gitlab.example.com`).
# Deploy Token (Project or Group, scopes `read_repository`+`write_repository`):
#   - Operator can extract from local Git Credential Manager:
#       printf 'protocol=https\nhost=<your-gitlab-domain>\nusername=gitlab+deploy-token-N\n\n' \
#         | git credential fill | awk -F= '/^password=/{print substr($0,10)}'
#   - After landing on VPS, configure git to use it:
#       git config --global credential.helper store
#       echo "https://${GITLAB_DEPLOY_TOKEN_USER}:${GITLAB_DEPLOY_TOKEN}@${GITLAB_HOST}" > ~/.git-credentials
#       chmod 600 ~/.git-credentials
# `GITLAB_API_TOKEN` is a Personal Access Token (or Project Access Token) with `api` scope —
# required for the dispatcher's `queue` subcommand (`glab issue list`) and for opening MRs.
# Without it, the dispatcher falls back to "manual" mode (queue enumeration disabled).
GITLAB_HOST=gitlab.example.com
GITLAB_REPO_URL=https://gitlab.example.com/<owner>/<repo>.git
GITLAB_DEPLOY_TOKEN_USER=gitlab+deploy-token-N
GITLAB_DEPLOY_TOKEN=<gldt-...>
GITLAB_API_TOKEN=<glpat-...>

# === Cloudflare (optional; leave blank to disable Cloudflare-related ops) ===
# CLOUDFLARE_API_TOKEN=<cf-api-token>
# CLOUDFLARE_ZONE_NAME=<zone.example.com>

# === MCP server keys (optional; leave blank to skip the corresponding server) ===
# REF_API_KEY=<ref-tools-key>
# CONTEXT7_API_KEY=<context7-key>
