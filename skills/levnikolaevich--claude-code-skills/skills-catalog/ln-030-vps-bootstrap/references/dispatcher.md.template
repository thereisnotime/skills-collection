## status

```bash
mcp__hex-ssh__remote-ssh:
  "echo '=== systemctl ===' && systemctl status ${VPS_SERVICE_PREFIX}-god.service ${VPS_SERVICE_PREFIX}-dispatch.timer ${VPS_SERVICE_PREFIX}-relay-bot.service agent-update.timer --no-pager | head -40 ; \
   echo '=== timers ===' && systemctl list-timers ${VPS_SERVICE_PREFIX}-dispatch.timer agent-update.timer --no-pager ; \
   echo '=== tmux ===' && sudo -u ${VPS_BOT_USER} tmux ls 2>&1 ; \
   echo '=== claude proc ===' && pgrep -af 'claude --dangerously' | head -2 ; \
   echo '=== skills repo ===' && sudo -u ${VPS_BOT_USER} bash -lc 'cd ${VPS_AGENT_SKILLS_DIR} && git status --short && git rev-parse --abbrev-ref HEAD && git rev-parse --short HEAD' ; \
   echo '=== claude plugins ===' && sudo -u ${VPS_BOT_USER} bash -lc '. /home/${VPS_BOT_USER}/.nvm/nvm.sh && claude plugin list --json' | jq -c . ; \
   echo '=== codex plugins ===' && sudo -u ${VPS_BOT_USER} grep -E 'levnikolaevich-skills-marketplace|@openai-curated' /home/${VPS_BOT_USER}/.codex/config.toml ; \
   echo '=== last agent update ===' && systemctl show agent-update.service -p Result -p ExecMainStatus -p ActiveEnterTimestamp --no-pager ; \
   echo '=== relay health ===' && curl -fsS http://127.0.0.1:${VPS_RELAY_HOOK_PORT}/health | jq -c . ; \
   echo '=== queue ===' && if [ "$VPS_GIT_PROVIDER" = "gitlab" ]; then sudo -u ${VPS_BOT_USER} bash -lc 'set -a && . /etc/${VPS_PROJECT_NAME}/secrets.env && set +a && [ -n "\$GITLAB_API_TOKEN" ] && GITLAB_TOKEN=\$GITLAB_API_TOKEN glab issue list --repo ${VPS_REPO_SLUG} --opened --output json | jq "[.[] | .labels[]?] | group_by(.) | map({label: .[0], count: length}) | .[]"' || echo "(GITLAB_API_TOKEN unset; queue enumeration disabled)"; else sudo -u ${VPS_BOT_USER} bash -lc 'export GH_TOKEN=\$(${VPS_SERVICE_PREFIX}-mint-gh-token); gh issue list --repo ${VPS_REPO_SLUG} --state open --json labels --jq \"[.[] | .labels[].name] | group_by(.) | map({label: .[0], count: length}) | .[]\"'; fi ; \
   echo '=== recent dispatches ===' && curl -fsS http://127.0.0.1:${VPS_RELAY_HOOK_PORT}/dispatch/recent?n=3 | jq '.runs[] | {id, ts_started, status, issue_number, pr_number}' ; \
   echo '=== last log ===' && tail -3 /var/log/${VPS_PROJECT_NAME}-god.log ; \
   echo '=== ram ===' && free -h | awk '/^Mem:/ {print \$7\" available out of \"\$2}'"
```

Render as a 6-row dashboard.

