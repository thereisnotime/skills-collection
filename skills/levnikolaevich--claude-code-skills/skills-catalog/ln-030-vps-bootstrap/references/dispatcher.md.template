## queue

Provider-conditional: uses `gh` for GitHub, `glab` for GitLab. GitLab requires `GITLAB_API_TOKEN` (PAT with `api` scope) in `/etc/${VPS_PROJECT_NAME}/secrets.env`; without it, the deploy-token cannot enumerate issues and this subcommand falls back to a clear "unsupported" message.

### GitHub (`VPS_GIT_PROVIDER=github`)

```bash
mcp__hex-ssh__remote-ssh:
  "sudo -u ${VPS_BOT_USER} bash -lc 'export GH_TOKEN=\$(${VPS_SERVICE_PREFIX}-mint-gh-token); gh issue list --repo ${VPS_REPO_SLUG} --state open --json number,title,labels,createdAt --jq \".[] | \\\"#\\(.number) [\\(.labels | map(.name) | join(\\\",\\\"))] \\(.title)\\\"\"'"
```

### GitLab (`VPS_GIT_PROVIDER=gitlab`)

```bash
mcp__hex-ssh__remote-ssh:
  "sudo -u ${VPS_BOT_USER} bash -lc 'set -a && . /etc/${VPS_PROJECT_NAME}/secrets.env && set +a && if [ -z \"\$GITLAB_API_TOKEN\" ]; then echo \"GITLAB_API_TOKEN unset in /etc/${VPS_PROJECT_NAME}/secrets.env — queue enumeration unsupported. Add a GitLab PAT with api scope to enable.\"; exit 0; fi; GITLAB_TOKEN=\$GITLAB_API_TOKEN glab issue list --repo ${VPS_REPO_SLUG} --opened --output json | jq -r \".[] | \\\"#\\(.iid) [\\(.labels | join(\\\",\\\"))] \\(.title)\\\"\"'"
```

## pause / resume

```bash
mcp__hex-ssh__remote-ssh: "systemctl stop ${VPS_SERVICE_PREFIX}-god.service && echo paused"
mcp__hex-ssh__remote-ssh: "systemctl start ${VPS_SERVICE_PREFIX}-god.service && sleep 5 && systemctl is-active ${VPS_SERVICE_PREFIX}-god.service"
```

## install

Idempotent verify. Does NOT touch secrets, App PEM, user data; only paths/perms/services.

```bash
mcp__hex-ssh__remote-ssh:
  "test -x /usr/local/bin/${VPS_SERVICE_PREFIX}-god || echo 'wrapper MISSING — re-run ln-030-vps-bootstrap Step 7' ; \
   test -r /home/${VPS_BOT_USER}/.claude/commands/${VPS_DISPATCH_COMMAND_NAME}.md || echo '${VPS_DISPATCH_COMMAND_NAME}.md MISSING' ; \
   test -r /etc/systemd/system/${VPS_SERVICE_PREFIX}-god.service || echo 'god service MISSING' ; \
   test -r /etc/systemd/system/${VPS_SERVICE_PREFIX}-dispatch.timer || echo 'dispatch timer MISSING' ; \
   test -r /etc/systemd/system/agent-update.timer || echo 'agent-update.timer (system-wide) MISSING' ; \
   test -x /usr/local/bin/agent-update || echo 'agent-update script (system-wide) MISSING' ; \
   test -r ${VPS_AGENT_SKILLS_DIR}/.claude-plugin/marketplace.json || echo 'Claude marketplace repo MISSING' ; \
   test -r ${VPS_AGENT_SKILLS_DIR}/.agents/plugins/marketplace.json || echo 'Codex marketplace repo MISSING' ; \
   test -f /opt/${VPS_SERVICE_PREFIX}-relay-bot/dist/index.js || echo 'relay-bot build MISSING' ; \
   install -d -o ${VPS_BOT_USER} -g ${VPS_BOT_USER} -m 755 /var/lib/${VPS_PROJECT_NAME} && \
   touch /var/log/${VPS_PROJECT_NAME}-god.log && chown ${VPS_BOT_USER}:${VPS_BOT_USER} /var/log/${VPS_PROJECT_NAME}-god.log && \
   loginctl enable-linger ${VPS_BOT_USER} && \
   systemctl daemon-reload && \
   systemctl enable --now ${VPS_SERVICE_PREFIX}-god.service ${VPS_SERVICE_PREFIX}-dispatch.timer ${VPS_SERVICE_PREFIX}-relay-bot.service agent-update.timer && \
   echo installed"
```

