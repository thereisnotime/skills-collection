# Headless agent defaults — full autonomy, deepest reasoning.
# Verified against https://developers.openai.com/codex/config-reference (2026-04).
# `approval_policy = "never"` + `sandbox_mode = "danger-full-access"` = the
# unattended-agent contract: no interactive prompts, full filesystem + network.
# Only safe inside an isolated VPS dedicated to this workload.
model = "gpt-5.5"
model_reasoning_effort = "xhigh"
approval_policy = "never"
sandbox_mode = "danger-full-access"
notify = ["bash", "/home/${BOT_USER}/.codex/notify.sh"]

[projects."/home/${BOT_USER}"]
trust_level = "trusted"

[projects."${PROJECT_DIR}"]
trust_level = "trusted"

[tui.model_availability_nux]
"gpt-5.5" = 2

[plugins."hugging-face@openai-curated"]
enabled = true

[plugins."github@openai-curated"]
enabled = true

