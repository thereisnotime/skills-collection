{
  "version": "5.0.0",
  "agents": {
    "codex": {
      "name": "Codex CLI",
      "command": "codex",
      "args": ["exec", "--full-auto", "--color", "never", "-C", "{cwd}", "-o", "{output_file}"],
      "resume_args": ["exec", "resume", "{session_id}", "--full-auto", "-o", "{output_file}"],
      "resume_prompt_delivery": "positional",
      "session_id_capture": {
        "strategy": "from_log",
        "pattern": "session.id:\\s*([0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+)"
      },
      "env_override": {},
      "hard_timeout_seconds": 1800,
      "skill_groups": ["200", "300", "310", "510"],
      "health_check": "codex --version",
      "focus_hint": "Primary focus: correctness bugs, schema feasibility, data integrity, error handling, code-level edge cases"
    },
    "gemini": {
      "name": "Gemini CLI",
      "command": "gemini",
      "args": ["--approval-mode", "yolo", "-p", ""],
      "resume_args": ["--resume", "{session_id}", "--approval-mode", "yolo", "-p", ""],
      "resume_prompt_delivery": "flag",
      "session_id_capture": {
        "strategy": "from_list_command",
        "command": "gemini --list-sessions",
        "parse": "first_uuid"
      },
      "env_override": {"GOOGLE_CLOUD_PROJECT": ""},
      "hard_timeout_seconds": 1800,
      "skill_groups": ["200", "300", "310", "510"],
      "health_check": "gemini --version",
      "focus_hint": "Primary focus: performance at scale, security/isolation, resource management, architectural patterns"
    },
    "claude-builtin": {
      "name": "Claude (built-in only)",
      "command": "claude",
      "args": ["-p", "--strict-mcp-config", "--settings", "{\"disableAllHooks\":true}", "--output-format", "json", "--dangerously-skip-permissions", "--max-turns", "30"],
      "hard_timeout_seconds": 600,
      "normal_prompt_delivery": "positional",
      "skill_groups": ["840"],
      "health_check": "claude --version",
      "focus_hint": "Built-in tools only (Read, Edit, Grep, Write, Bash, Glob). No MCP servers."
    },
    "claude-hexline": {
      "name": "Claude (hex-line)",
      "command": "claude",
      "args": ["-p", "--strict-mcp-config", "--mcp-config", "skills-catalog/ln-840-benchmark-compare/references/mcp-bench.json", "--output-format", "json", "--dangerously-skip-permissions", "--max-turns", "30"],
      "hard_timeout_seconds": 600,
      "normal_prompt_delivery": "positional",
      "skill_groups": ["840"],
      "health_check": "claude --version",
      "focus_hint": "Hex-line MCP tools (read_file, edit_file, grep_search, outline, verify, bulk_replace, etc.)"
    }
  }
}
