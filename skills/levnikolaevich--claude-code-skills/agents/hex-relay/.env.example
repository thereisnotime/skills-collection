TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PROJECT_NAME=local-dev
PROJECT_DIR=/tmp/local-dev
SERVICE_PREFIX=local-dev
BOT_USER=local-dev
RELAY_HOOK_PORT=9999
RELAY_HTTP_TOKEN=replace-with-at-least-32-random-characters
RELAY_VERBOSITY=normal
RELAY_INBOUND_REACTIONS=
RELAY_IDLE_SHUTDOWN_ENABLED=true
RELAY_IDLE_SHUTDOWN_SEC=600
RELAY_IDLE_TICK_SEC=60
RELAY_IDLE_BOOT_GRACE_SEC=120
RELAY_VOICE_TRANSCRIPTION=off
FFMPEG_BIN=ffmpeg
WHISPER_CPP_BIN=/opt/whisper.cpp/build/bin/whisper-cli
WHISPER_CPP_MODEL=/opt/whisper.cpp/models/ggml-small-q5_1.bin
RELAY_VOICE_MAX_DURATION_SEC=90
RELAY_VOICE_TRANSCRIBE_TIMEOUT_SEC=120
LOG_LEVEL=info
GIT_PROVIDER=github
REPO_SLUG=
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITLAB_HOST=
GITLAB_API_TOKEN=
