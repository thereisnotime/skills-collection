{
  "name": "@levnikolaevich/hex-ssh-mcp",
  "version": "1.4.1",
  "mcpName": "io.github.levnikolaevich/hex-ssh-mcp",
  "description": "Token-efficient SSH MCP server with hash-verified file operations. 8 tools: remote-ssh, ssh-read-lines, ssh-edit-block, ssh-search-code, ssh-write-chunk, ssh-upload, ssh-download, ssh-verify.",
  "type": "module",
  "main": "dist/server.mjs",
  "bin": {
    "hex-ssh-mcp": "dist/server.mjs"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "start": "node server.mjs",
    "build": "node build.mjs",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test test/smoke.mjs test/schema-contract.mjs",
    "test:interop": "node --test test/interop.mjs",
    "test:all": "npm test && npm run test:interop",
    "check": "node --check server.mjs",
    "benchmark": "node -e \"console.error('hex-ssh-mcp does not publish a comparative workflow benchmark yet. Run npm run benchmark:diagnostic for normalization diagnostics.'); process.exit(1)\"",
    "benchmark:diagnostic": "node benchmark.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "_dep_notes": {
    "zod": "Tracks Zod 4 natively with the current MCP SDK. Schema descriptions are contract-tested through listTools() output."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^8.0.4",
    "ssh-config": "^5.1.0",
    "ssh2": "^1.17.0",
    "zod": "^4.3.6"
  },
  "author": "Lev Nikolaevich <https://github.com/levnikolaevich>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/levnikolaevich/claude-code-skills/issues"
  },
  "keywords": [
    "mcp",
    "ssh",
    "remote",
    "hash-verified",
    "token-efficient",
    "model-context-protocol",
    "hex-ssh",
    "claude",
    "ai",
    "llm",
    "coding-agent",
    "remote-editing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/levnikolaevich/claude-code-skills",
    "directory": "mcp/hex-ssh-mcp"
  },
  "homepage": "https://github.com/levnikolaevich/claude-code-skills/tree/master/mcp/hex-ssh-mcp",
  "devDependencies": {
    "eslint": "^10.2.0"
  }
}
