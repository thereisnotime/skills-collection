{
  "name": "mcp-workspace",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "hex-common",
    "hex-line-mcp",
    "hex-ssh-mcp",
    "hex-graph-mcp",
    "hex-research-mcp"
  ],
  "scripts": {
    "build:tree-sitter-artifacts": "node hex-common/scripts/build-tree-sitter-artifacts.mjs",
    "build": "npm --workspaces --if-present run build",
    "check": "node check-output-contracts.mjs && npm --workspaces --if-present run check",
    "test": "node check-output-contracts.mjs && npm --workspace @levnikolaevich/hex-common test && npm --workspace @levnikolaevich/hex-line-mcp test && npm --workspace @levnikolaevich/hex-graph-mcp run test:unit && npm --workspace @levnikolaevich/hex-ssh-mcp test && npm --workspace @levnikolaevich/hex-research-mcp test",
    "test:full": "npm run test && npm --workspace @levnikolaevich/hex-graph-mcp test"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@hono/node-server": "^1.19.13",
    "brace-expansion": "^5.0.5",
    "hono": "^4.12.12",
    "minimatch": {
      "brace-expansion": "^5.0.5"
    },
    "path-to-regexp": "^8.4.2",
    "router": {
      "path-to-regexp": "^8.4.2"
    },
    "zod": "^4.3.6",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
