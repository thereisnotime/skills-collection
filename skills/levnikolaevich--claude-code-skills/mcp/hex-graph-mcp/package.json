{
  "name": "@levnikolaevich/hex-graph-mcp",
  "version": "0.11.0",
  "mcpName": "io.github.levnikolaevich/hex-graph-mcp",
  "type": "module",
  "description": "Deterministic layered code graph MCP server. Indexes codebases into a SQLite graph via tree-sitter AST, canonical symbol identities, semantic overlays, capability-first quality tooling, and optional SCIP interoperability.",
  "main": "dist/server.mjs",
  "bin": {
    "hex-graph-mcp": "dist/server.mjs"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "start": "node server.mjs",
    "build": "node build.mjs",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node scripts/generate-quality-report.mjs && node --test test/*.mjs && node scripts/sync-quality-docs.mjs --check && node scripts/validate-ln012-skill.mjs",
    "test:unit": "node --test test/*.mjs",
    "check": "node --check server.mjs",
    "evals": "node scripts/generate-quality-report.mjs && node evals/index.mjs",
    "docs:quality": "node scripts/generate-quality-report.mjs && node scripts/sync-quality-docs.mjs",
    "docs:quality:check": "node scripts/generate-quality-report.mjs --check && node scripts/sync-quality-docs.mjs --check",
    "validate:ln012": "node scripts/validate-ln012-skill.mjs",
    "corpora:materialize": "node scripts/materialize-corpora.mjs",
    "benchmark": "node benchmark/index.mjs",
    "benchmark:diagnostic": "node benchmark/index.mjs --diagnostics"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "_dep_notes": {
    "web-tree-sitter": "Tracks the latest stable runtime together with the repo-owned first-party grammar WASM bundle. Keep runtime upgrades coupled to grammar load/parse validation across Windows, macOS, and Linux.",
    "zod": "Tracks Zod 4 natively with the current MCP SDK. Schema descriptions are contract-tested through listTools() output."
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "picomatch": "^4.0.4",
    "typescript": "^6.0.2",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.3.6"
  },
  "author": "Lev Nikolaevich <https://github.com/levnikolaevich>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/levnikolaevich/claude-code-skills/issues"
  },
  "keywords": [
    "mcp",
    "codegraph",
    "knowledge-graph",
    "tree-sitter",
    "code-intelligence",
    "blast-radius",
    "dependency-graph",
    "model-context-protocol",
    "claude",
    "ai",
    "llm",
    "coding-agent",
    "code-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/levnikolaevich/claude-code-skills",
    "directory": "mcp/hex-graph-mcp"
  },
  "homepage": "https://github.com/levnikolaevich/claude-code-skills/tree/master/mcp/hex-graph-mcp",
  "devDependencies": {
    "eslint": "^10.2.0"
  }
}
