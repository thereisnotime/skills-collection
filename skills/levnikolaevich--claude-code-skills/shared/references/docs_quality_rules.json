{
  "scopeTag": {
    "required": true,
    "withinFirstLines": 12
  },
  "metadataMarkers": [
    "DOC_KIND",
    "DOC_ROLE",
    "READ_WHEN",
    "SKIP_WHEN",
    "PRIMARY_SOURCES"
  ],
  "metadataWithinFirstLines": 20,
  "requiredTopSections": [
    "## Quick Navigation",
    "## Agent Entry",
    "## Maintenance"
  ],
  "maintenanceMarkers": [
    "Update Triggers",
    "Verification",
    "Last Updated"
  ],
  "placeholderDenylist": [
    "[TBD:",
    "TODO",
    "Coming soon",
    "Lorem ipsum",
    "{{",
    "}}"
  ],
  "templateMetadataDenylist": [
    "Template Last Updated:",
    "Template Version:"
  ],
  "placeholderAllowlist": [
    "docs/tasks/README.md",
    "docs/tasks/kanban_board.md"
  ],
  "allowedFenceLanguages": [
    "bash",
    "sh",
    "shell",
    "yaml",
    "yml",
    "json",
    "toml",
    "ini",
    "env",
    "mermaid",
    "text",
    "plaintext"
  ],
  "allowedDocKinds": [
    "index",
    "reference",
    "how-to",
    "explanation",
    "record"
  ],
  "allowedDocRoles": [
    "canonical",
    "navigation",
    "working",
    "derived"
  ],
  "docRegistryPath": "docs/project/.context/doc_registry.json",
  "staleDays": 180,
  "pathRules": [
    {
      "match": "AGENTS.md",
      "class": "root",
      "requiresScope": true,
      "requiresMetadata": true,
      "requiresTopSections": true,
      "requiresMaintenance": true,
      "docKind": "index",
      "docRole": "canonical"
    },
