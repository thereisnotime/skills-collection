{
  "name": "wechat-scraper-cloud",
  "version": "1.0.0",
  "description": "WeChat Article Scraper - Cloud Deployment",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy": "vercel --prod",
    "analyze": "next build && npm run analyze:report",
    "analyze:report": "echo 'Bundle analysis complete'",
    "db:migrate": "supabase db push",
    "db:migrate:test": "supabase db push --db-url $DATABASE_URL",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/supabase.ts",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:benchmark": "npm run test:benchmark:scrape && npm run test:benchmark:annotation",
    "test:benchmark:scrape": "vitest run tests/benchmark/scrape-benchmark.ts",
    "test:benchmark:annotation": "vitest run tests/benchmark/annotation-accuracy.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@headlessui/react": "^1.7.0",
    "@notionhq/client": "^2.2.0",
    "@rangy/core": "^1.3.0",
    "@supabase/realtime-js": "^2.9.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/dompurify": "^3.0.5",
    "date-fns": "^3.0.0",
    "dompurify": "^3.0.6",
    "framer-motion": "^10.16.0",
    "jszip": "^3.10.0",
    "lucide-react": "^0.300.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-query": "^3.39.0",
    "slate": "^0.101.0",
    "slate-history": "^0.100.0",
    "slate-react": "^0.101.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "tailwindcss": "^3.4.0",
    "y-protocols": "^1.0.6",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "supabase": "^1.127.0",
    "typescript": "^5.3.0",
    "vercel": "^33.0.0"
  }
}
