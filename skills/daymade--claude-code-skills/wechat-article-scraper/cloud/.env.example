# Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WeChat Mini Program (微信小程序)
WECHAT_MINIAPP_APPID=wx_your_miniapp_appid
WECHAT_MINIAPP_SECRET=your_miniapp_secret

# WeChat Official Account (微信公众号)
WECHAT_OFFICIAL_APPID=wx_your_official_appid
WECHAT_OFFICIAL_SECRET=your_official_secret
WECHAT_OFFICIAL_TOKEN=your_webhook_token

# External APIs (Optional)
JINA_AI_API_KEY=your_jina_ai_api_key
OPENAI_API_KEY=your_openai_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# TTS Services (Optional)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus

# Sentry (Optional)
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
