{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "1.0.0",
  "default_locale": "zh_CN",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://mp.weixin.qq.com/*",
    "https://*.zhihu.com/*",
    "https://*.juejin.cn/*",
    "https://*.csdn.net/*",
    "https://*.sspai.com/*",
    "http://localhost:*/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mp.weixin.qq.com/s*",
        "https://mp.weixin.qq.com/mp/*"
      ],
      "js": ["src/content-wechat.js"],
      "css": ["src/content-styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["src/content-universal.js"],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://mp.weixin.qq.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "__MSG_savePage__"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "save-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "__MSG_saveCurrentPage__"
    },
    "quick-annotate": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "__MSG_quickAnnotate__"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/injected.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://*.vercel.app/*",
      "http://localhost:*/*"
    ]
  }
}
